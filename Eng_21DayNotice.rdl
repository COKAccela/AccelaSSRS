                    <TablixCell />
                    <TablixCell />
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>1.1in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox42">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>As-built plans were not received and approved by the Engineering Department 30 days prior to the expiration date, so the bond must be extended.  As noted in our letter dated </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>=Fields!SixtyDay.Value</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, we must receive the enclosed document with </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>ORIGINAL </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>Underline</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>signatures and notary seals by noon on </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>=Fields!TenDay.Value</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <Format>d</Format>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, or we will begin collection procedures. The first notary page is for the Principal’s signature and the second is for the Surety’s.</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
                          </Paragraphs>
