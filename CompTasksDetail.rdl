<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Accela">
      <DataSourceReference>Accela</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>0dfecd8e-7e4d-4c5d-b6fc-6dcbbfaaed55</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Organ">
            <Value>=Parameters!Organ.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Tasks">
            <Value>=Parameters!Tasks.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@WorkCenter">
            <Value>=Parameters!WorkCenter.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Completed">
            <Value>=Parameters!Completed.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@emse_step">
            <Value>=Parameters!emse_step.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select
  BP.B1_ALT_ID WO_NUM,
  BP.b1_appl_status  B1_APPL_STATUS,
  ISNULL(ckbx_piv.[Work Order Type],'')  work_order_type_code, 
  gtyp.R3_SUBGROUP_DESC ASSIGNED_GROUP_DESCR,
  BP.REC_DATE CREATED_DATE,
  BP.B1_APPL_STATUS_DATE as STATUS_DATE,
  ISNULL(ckbx_piv.[Work Order Type], '-') AS Organ,
  ckbx_piv.[Work Center] Work_Center,
   ckbx_piv.[Assigned to Organization] Assigned_to_Organ,
  CASE when bp.b1_per_type = 'Work Order' then ckbx_piv.[Service Request Information] else NULL END as COMMENTS,
  got.G1_TASK_CODE Task,
  AD.B1_STR_NAME STREET_NAME, 
  CONVERT(VARCHAR,ISNULL(AD.B1_HSE_NBR_START,'0')) AS STREET_NUMBER,
  NULL AS PROD,
  NULL AS Labor,
  NULL AS Materials,
  NULL AS Equipment,
  NULL AS Rentals,
  NULL AS RTH,
  NULL as Parts,
  NULL AS Loads,
	  TRIM(APROD_U.[Ticket Number]) as TICKET_NUMBER,
  	  TRIM(APROD_U.[Truck Number]) as TRUCK_NUMBER, 
	  TRIM(APROD_U.Quantity) as TASK_QUANTITY, 
	  TRIM(APROD_U.Weight) AS TASK_WEIGHT,
	  TRIM(APROD_U.[Weight Unit]) AS TASK_WEIGHT_UNIT,
  NULL AS REG_HRS,
  NULL AS REG_HRS15,
  NULL AS REG_HRS2,
  2 as ORD
from B1PERMIT BP
LEFT OUTER JOIN     
      dbo.BPERMIT_DETAIL BPD
    ON
      BPD.SERV_PROV_CODE   = BP.SERV_PROV_CODE
    AND BPD.B1_PER_ID1     = BP.B1_PER_ID1
    AND BPD.B1_PER_ID2     = BP.B1_PER_ID2
    AND BPD.B1_PER_ID3     = BP.B1_PER_ID3
    LEFT OUTER JOIN
      dbo.G3DPTTYP gtyp
    ON
	gtyp.SERV_PROV_CODE = BPD.SERV_PROV_CODE
    and  gtyp.R3_DEPT_KEY      = BPD.B1_ASGN_DEPT
	-- only one address should ever be returned, but multiple primary addresses may be assigned to a b1permit entry 
	-- I've found at least one instance where this occurs)
LEFT OUTER JOIN
      dbo.B3ADDRES AD
    ON
    AD.SERV_PROV_CODE        = bp.SERV_PROV_CODE
    AND AD.B1_PER_ID1          = bp.B1_PER_ID1
    AND AD.B1_PER_ID2          = bp.B1_PER_ID2
    AND AD.B1_PER_ID3          = bp.B1_PER_ID3
	AND AD.B1_ADDRESS_NBR = 
	(select top 1 B1_ADDRESS_NBR
	from B3ADDRES  ojad
	where ojad.SERV_PROV_CODE = bp.SERV_PROV_CODE
	  AND ojad.B1_PER_ID1                  = bp.B1_PER_ID1
	  AND ojad.B1_PER_ID2                  = bp.B1_PER_ID2
	  AND ojad.B1_PER_ID3                  = bp.B1_PER_ID3
		and ojad.B1_PRIMARY_ADDR_FLG = 'Y'
		AND ojad.B1_STR_NAME IS NOT NULL
		order by ojad.B1_STR_NAME Asc)
	LEFT OUTER JOIN (
		SELECT
			SERV_PROV_CODE SERV_PROV_CODE    ,
			B1_PER_ID1 B1_PER_ID1            ,
			B1_PER_ID2 B1_PER_ID2            ,
			B1_PER_ID3 B1_PER_ID3            ,
			b1_checkbox_desc b1_checkbox_desc,
			b1_checklist_comment b1_checklist_comment
		FROM
			BCHCKBOX)
				  
			bcbox pivot ( max(b1_checklist_comment) for b1_checkbox_desc in ( 
			[Work Center],
			[Work Order Type],
			[Assigned to Organization],
			[Quantity],
			[Task],
			[Service Request Information]) ) ckbx_piv
	on
	BP.SERV_PROV_CODE = ckbx_piv.SERV_PROV_CODE
	AND BP.B1_PER_ID1   = ckbx_piv.B1_PER_ID1
	AND BP.B1_PER_ID2   = ckbx_piv.B1_PER_ID2
	AND BP.B1_PER_ID3   = ckbx_piv.B1_PER_ID3
LEFT OUTER JOIN
      dbo.GWORK_ORDER_TASK got
    ON
      got.SERV_PROV_CODE = BP.SERV_PROV_CODE
    AND got.B1_PER_ID1   = BP.B1_PER_ID1
    AND got.B1_PER_ID2   = BP.B1_PER_ID2
    AND got.B1_PER_ID3   = BP.B1_PER_ID3
inner JOIN BAPPSPECTABLE_VALUE BAPP
	ON BAPP.SERV_PROV_CODE = BP.SERV_PROV_CODE
	AND BAPP.B1_PER_ID1  = BP.B1_PER_ID1
	AND BAPP.B1_PER_ID2 = BP.B1_PER_ID2
	AND BAPP.B1_PER_ID3 = BP.B1_PER_ID3
	AND BAPP.ATTRIBUTE_VALUE = ISNULL(got.G1_TASK_CODE, '-1')
	AND BAPP.GROUP_NAME = 'WO_APU'
	AND BAPP.TABLE_NAME = 'ACTUAL PRODUCTION UNITS'
	AND BAPP.COLUMN_NAME = 'Task'
inner JOIN (
	SELECT
			SERV_PROV_CODE SERV_PROV_CODE ,
			B1_PER_ID1 B1_PER_ID1         ,
			B1_PER_ID2 B1_PER_ID2         ,
			B1_PER_ID3 B1_PER_ID3,
			GROUP_NAME,
			ROW_INDEX,
			COLUMN_NAME    COLUMN_NAME ,
			attribute_value   attribute_value

	FROM  BAPPSPECTABLE_VALUE 
	WHERE SERV_PROV_CODE = 'KNOXVILLE'
	and GROUP_NAME = 'WO_APU' AND 
	TABLE_NAME = 'ACTUAL PRODUCTION UNITS' ) as bat
	pivot ( max(ATTRIBUTE_VALUE) for COLUMN_NAME in (
	[Truck Number]  , 
	[Quantity]  , 
	[Weight Unit]  , 
	[Weight]  , 
	[Ticket Number] 
	)) as APROD_U
	ON APROD_U.SERV_PROV_CODE = BAPP.SERV_PROV_CODE
	AND APROD_U.B1_PER_ID1  = BAPP.B1_PER_ID1
	AND APROD_U.B1_PER_ID2 = BAPP.B1_PER_ID2
	AND APROD_U.B1_PER_ID3 = BAPP.B1_PER_ID3
	AND APROD_U.GROUP_NAME = BAPP.GROUP_NAME                  
    AND APROD_U.ROW_INDEX = BAPP.ROW_INDEX
	AND ( APROD_U.[Ticket Number] IS NOT NULL AND APROD_U.[Ticket Number] &lt;&gt; 'N/A')
WHERE BP.SERV_PROV_CODE = 'KNOXVILLE' 
AND BP.B1_PER_TYPE           = 'Work Order'
AND BP.B1_PER_SUB_TYPE         = 'Public Service'


AND (
    '&lt;All&gt;'                         IN (@Tasks)
  OR ISNULL(BAPP.ATTRIBUTE_VALUE , '-') in (@Tasks))
and ( 
	(@EndDate is not null and @StartDate is not null 
		and CONVERT(DATE, BP.B1_APPL_STATUS_DATE, 101) between
		CONVERT(DATE, @StartDate, 101) AND CONVERT(DATE, @EndDate, 101)
	)
		
    OR (
        @EndDate is null
    and @StartDate is not null
    and CONVERT(DATE, BP.B1_APPL_STATUS_DATE, 101) &gt;= CONVERT(DATE, @StartDate, 101))
    OR (
        @StartDate is null
    and @EndDate is not null
    and CONVERT(DATE, BP.B1_APPL_STATUS_DATE, 101) &lt;= CONVERT(DATE, @EndDate, 101)) )
AND (
    '&lt;All&gt;'                                IN (@Organ)
  OR ISNULL(gtyp.R3_SUBGROUP_DESC, '-') in (@Organ))
AND (
    '&lt;All&gt;'                         IN (@Tasks)
  OR ISNULL(got.G1_TASK_CODE , '-') in (@Tasks))
AND (
    '&lt;All&gt;'                      IN (@WorkCenter)
  OR ISNULL(ckbx_piv.[Work Center],'-') IN (@WorkCenter))
AND (
    (
      @Completed       = 'Yes'
    AND BP.B1_appl_status = 'Completed')
  OR (
      @Completed = 'No'
    AND BP.B1_appl_status in ('Under Review',
                          'In Progress'  ,
                          'In Queue'     ,
                          'Open'         ,
                          'Received')) )
and (
    '&lt;All&gt;'                               IN (@emse_step)
  OR ISNULL(ckbx_piv.[Work Order Type],'-') in (@emse_step))
UNION
  select
  BP.B1_ALT_ID WO_NUM,
  BP.b1_appl_status  B1_APPL_STATUS,
  ISNULL(ckbx_piv.[Work Order Type],'')  work_order_type_code, 
  gtyp.R3_SUBGROUP_DESC ASSIGNED_GROUP_DESCR,
  BP.REC_DATE CREATED_DATE,
  BP.B1_APPL_STATUS_DATE as STATUS_DATE,
  ISNULL(ckbx_piv.[Work Order Type], '-') AS Organ,
  ckbx_piv.[Work Center] Work_Center,
     ckbx_piv.[Assigned to Organization] Assigned_to_Organ,
  CASE when bp.b1_per_type = 'Work Order' then ckbx_piv.[Service Request Information] else NULL END as COMMENTS,
  got.G1_TASK_CODE Task,
  AD.B1_STR_NAME STREET_NAME, 
  CONVERT(VARCHAR,ISNULL(AD.B1_HSE_NBR_START,'0')) AS STREET_NUMBER,
    CONVERT(NUMERIC(10,2),ISNULL(
  (
    select
      ISNULL(SUM(CONVERT(NUMERIC(10,2),(ISNULL(TD.ATTRIBUTE_VALUE,0)))),0)
    FROM
      BAPPSPECTABLE_VALUE TC
    JOIN
      BAPPSPECTABLE_VALUE TD
    ON
      TD.SERV_PROV_CODE                = TC.SERV_PROV_CODE
    AND TD.B1_PER_ID1                  = TC.B1_PER_ID1
    AND TD.B1_PER_ID2                  = TC.B1_PER_ID2
    AND TD.B1_PER_ID3                  = TC.B1_PER_ID3
    AND TD.GROUP_NAME                  = 'WO_APU'
    AND TD.TABLE_NAME                  = 'ACTUAL PRODUCTION UNITS'
    AND TD.ROW_INDEX                   = TC.ROW_INDEX
    AND TD.COLUMN_NAME                 = 'Quantity'
    AND ISNULL(TD.ATTRIBUTE_VALUE,' ') &lt;&gt; ' '
    WHERE
      TC.SERV_PROV_CODE                = BP.SERV_PROV_CODE
    AND TC.B1_PER_ID1                  = BP.B1_PER_ID1
    AND TC.B1_PER_ID2                  = BP.B1_PER_ID2
    AND TC.B1_PER_ID3                  = BP.B1_PER_ID3
    AND TC.GROUP_NAME                  = 'WO_APU'
    AND TC.TABLE_NAME                  = 'ACTUAL PRODUCTION UNITS'
    AND TC.COLUMN_NAME                 = 'Task'
    AND ISNULL(TC.ATTRIBUTE_VALUE,' ') &lt;&gt; ' '
    AND TC.ATTRIBUTE_VALUE             = got.G1_TASK_CODE ),0)) + (BPD.B1_ACTUAL_PROD_UNITS) AS PROD,
  ISNULL(wot.Labor,0.00) as Labor,
  ISNULL(wot.Materials,0.00) as Materials,
  ISNULL(wot.Equipment,0.00) as Equipment,
  ISNULL(wot.Rentals,0.00) as Rentals,
  ISNULL(wot.Rentals + wot.contractor + wot.HR, 0.00) as RTH,
   CONVERT(NUMERIC,ISNULL(
  (
    SELECT
      ISNULL(SUM(ISNULL(gp.quantity,0) * ISNULL(gp.unit_cost,0)),0)
    from
      gpart_transaction gp
    WHERE
      gp.SERV_PROV_CODE     = BP.SERV_PROV_CODE
    and gp.B1_PER_ID1       = BP.B1_PER_ID1
    and gp.B1_PER_ID2       = BP.B1_PER_ID2
    and gp.b1_per_id3       = BP.b1_per_id3
    and gp.REC_STATUS       = 'A'
    and gp.TRANSACTION_TYPE = 'ISSUE'
    and (
        ISNULL(gp.Task_code,'-')  = '-'
      or ISNULL(gp.Task_code,'-') = got.G1_TASK_CODE)),0)) as Parts,
	    CONVERT(NUMERIC,ISNULL(
  (
    select
      ISNULL(SUM(CONVERT(NUMERIC(10,2),(ISNULL(TD.ATTRIBUTE_VALUE,0)))),0)
    FROM
      BAPPSPECTABLE_VALUE TC
    JOIN
      BAPPSPECTABLE_VALUE TD
    ON
      TD.SERV_PROV_CODE                = TC.SERV_PROV_CODE
    AND TD.B1_PER_ID1                  = TC.B1_PER_ID1
    AND TD.B1_PER_ID2                  = TC.B1_PER_ID2
    AND TD.B1_PER_ID3                  = TC.B1_PER_ID3
    AND TD.GROUP_NAME                  = 'WO_APU'
    AND TD.TABLE_NAME                  = 'ACTUAL PRODUCTION UNITS'
    AND TD.ROW_INDEX                   = TC.ROW_INDEX
    AND TD.COLUMN_NAME                 = 'Quantity'
    AND ISNULL(TD.ATTRIBUTE_VALUE,' ') &lt;&gt; ' '
    WHERE
      TC.SERV_PROV_CODE                = BP.SERV_PROV_CODE
    AND TC.B1_PER_ID1                  = BP.B1_PER_ID1
    AND TC.B1_PER_ID2                  = BP.B1_PER_ID2
    AND TC.B1_PER_ID3                  = BP.B1_PER_ID3
    AND TC.GROUP_NAME                  = 'WO_APU'
    AND TC.TABLE_NAME                  = 'ACTUAL PRODUCTION UNITS'
    AND TC.COLUMN_NAME                 = 'Task'
    AND ISNULL(TC.ATTRIBUTE_VALUE,' ') &lt;&gt; ' '
    AND TC.ATTRIBUTE_VALUE             = got.G1_TASK_CODE ),0)) AS Loads,
	NULL as TICKET_NUMBER,
  	NULL as TRUCK_NUMBER, 
	NULL TASK_QUANTITY, 
	NULL AS TASK_WEIGHT,
	NULL AS TASK_WEIGHT_UNIT,
	    CONVERT(NUMERIC,ISNULL(
  (
    SELECT
      CONVERT(NUMERIC(10,2),ISNULL(SUM(ISNULL(GC.cost_quantity,0)),0) )
    FROM
      GCOSTING_QUANTITY GC,
      GWORK_ORDER_COSTING b
    WHERE
      B.SERV_PROV_CODE = BP.SERV_PROV_CODE
    and B.B1_PER_ID1   = BP.B1_PER_ID1
    and B.B1_PER_ID2   = BP.B1_PER_ID2
    and B.B1_PER_ID3   = BP.B1_PER_ID3
    and B.COST_TYPE    = 'Labor'
    and (
        ISNULL(B.Task_code,'-')  = '-'
      or ISNULL(B.Task_code,'-') = got.G1_TASK_CODE)
    and GC.SERV_PROV_CODE        = B.SERV_PROV_CODE
    and GC.B1_PER_ID1            = B.B1_PER_ID1
    and GC.B1_PER_ID2            = B.B1_PER_ID2
    and GC.B1_PER_ID3            = B.B1_PER_ID3
    and GC.ENTITY_TYPE           = 'RECORD'
    and GC.ENTITY_ID             = b.cost_seq_nbr
    AND GC.REC_STATUS            = 'A'
    and (
        GC.COST_FACTOR = 1)),0)) AS REG_HRS,
  CONVERT(NUMERIC,ISNULL(
  (
    SELECT
      CONVERT(NUMERIC(10,2),ISNULL(SUM(ISNULL(GC.cost_quantity,0)),0) )
    FROM
      GCOSTING_QUANTITY GC,
      GWORK_ORDER_COSTING b
    WHERE
      B.SERV_PROV_CODE = BP.SERV_PROV_CODE
    and B.B1_PER_ID1   = BP.B1_PER_ID1
    and B.B1_PER_ID2   = BP.B1_PER_ID2
    and B.B1_PER_ID3   = BP.B1_PER_ID3
    and B.COST_TYPE    = 'Labor'
    and (
        ISNULL(B.Task_code,'-')  = '-'
      or ISNULL(B.Task_code,'-') = got.G1_TASK_CODE)
    and GC.SERV_PROV_CODE        = B.SERV_PROV_CODE
    and GC.B1_PER_ID1            = B.B1_PER_ID1
    and GC.B1_PER_ID2            = B.B1_PER_ID2
    and GC.B1_PER_ID3            = B.B1_PER_ID3
    and GC.ENTITY_TYPE           = 'RECORD'
    and GC.ENTITY_ID             = b.cost_seq_nbr
    AND GC.REC_STATUS            = 'A'
    and (
        GC.COST_FACTOR = 1.5)),0)) AS REG_HRS15,
  CONVERT(NUMERIC,ISNULL(
  (
    SELECT
      CONVERT(NUMERIC(10,2),ISNULL(SUM(ISNULL(GC.cost_quantity,0)),0) )
    FROM
      GCOSTING_QUANTITY GC,
      GWORK_ORDER_COSTING b
    WHERE
      B.SERV_PROV_CODE = BP.SERV_PROV_CODE
    and B.B1_PER_ID1   = BP.B1_PER_ID1
    and B.B1_PER_ID2   = BP.B1_PER_ID2
    and B.B1_PER_ID3   = BP.B1_PER_ID3
    and B.COST_TYPE    = 'Labor'
    and (
        ISNULL(B.Task_code,'-')  = '-'
      or ISNULL(B.Task_code,'-') = got.G1_TASK_CODE)
    and GC.SERV_PROV_CODE        = B.SERV_PROV_CODE
    and GC.B1_PER_ID1            = B.B1_PER_ID1
    and GC.B1_PER_ID2            = B.B1_PER_ID2
    and GC.B1_PER_ID3            = B.B1_PER_ID3
    and GC.ENTITY_TYPE           = 'RECORD'
    and GC.ENTITY_ID             = b.cost_seq_nbr
    AND GC.REC_STATUS            = 'A'
    and (
        GC.COST_FACTOR = 2)),0)) AS REG_HRS2,
	1 as ORD
from B1PERMIT BP
LEFT OUTER JOIN     
      dbo.BPERMIT_DETAIL BPD
    ON
      BPD.SERV_PROV_CODE   = BP.SERV_PROV_CODE
    AND BPD.B1_PER_ID1     = BP.B1_PER_ID1
    AND BPD.B1_PER_ID2     = BP.B1_PER_ID2
    AND BPD.B1_PER_ID3     = BP.B1_PER_ID3
LEFT OUTER JOIN
      dbo.G3DPTTYP gtyp
    ON
	gtyp.SERV_PROV_CODE = BPD.SERV_PROV_CODE
    and  gtyp.R3_DEPT_KEY      = BPD.B1_ASGN_DEPT
	-- only one address should ever be returned, but multiple primary addresses may be assigned to a b1permit entry 
	-- I've found at least one instance where this occurs)
LEFT OUTER JOIN
      dbo.B3ADDRES AD
    ON
    AD.SERV_PROV_CODE        = bp.SERV_PROV_CODE
    AND AD.B1_PER_ID1          = bp.B1_PER_ID1
    AND AD.B1_PER_ID2          = bp.B1_PER_ID2
    AND AD.B1_PER_ID3          = bp.B1_PER_ID3
	AND AD.B1_ADDRESS_NBR = 
	(select top 1 B1_ADDRESS_NBR
		from B3ADDRES  ojad
		where ojad.SERV_PROV_CODE = bp.SERV_PROV_CODE
			AND ojad.B1_PER_ID1                  = bp.B1_PER_ID1
			AND ojad.B1_PER_ID2                  = bp.B1_PER_ID2
			AND ojad.B1_PER_ID3                  = bp.B1_PER_ID3
			and ojad.B1_PRIMARY_ADDR_FLG = 'Y'
			AND ojad.B1_STR_NAME IS NOT NULL
			order by ojad.B1_STR_NAME Asc
	)

LEFT OUTER JOIN (
		SELECT
			SERV_PROV_CODE SERV_PROV_CODE    ,
			B1_PER_ID1 B1_PER_ID1            ,
			B1_PER_ID2 B1_PER_ID2            ,
			B1_PER_ID3 B1_PER_ID3            ,
			b1_checkbox_desc b1_checkbox_desc,
			b1_checklist_comment b1_checklist_comment
		FROM
			BCHCKBOX)
				  
			bcbox pivot ( max(b1_checklist_comment) for b1_checkbox_desc in ( 
			[Work Center],
			[Work Order Type],
			[Quantity],
			[Task],
			[Assigned to Organization],
			[Service Request Information]) ) ckbx_piv
	on
	BP.SERV_PROV_CODE = ckbx_piv.SERV_PROV_CODE
	AND BP.B1_PER_ID1   = ckbx_piv.B1_PER_ID1
	AND BP.B1_PER_ID2   = ckbx_piv.B1_PER_ID2
	AND BP.B1_PER_ID3   = ckbx_piv.B1_PER_ID3
LEFT OUTER JOIN
      dbo.GWORK_ORDER_TASK got
    ON
      got.SERV_PROV_CODE = BP.SERV_PROV_CODE
    AND got.B1_PER_ID1   = BP.B1_PER_ID1
    AND got.B1_PER_ID2   = BP.B1_PER_ID2
    AND got.B1_PER_ID3   = BP.B1_PER_ID3
LEFT OUTER JOIN
	(
		SELECT pwoc.SERV_PROV_CODE, pwoc.B1_PER_ID1, pwoc.B1_PER_ID2, pwoc.B1_PER_ID3, pwoc.TASK_CODE, pwoc.Task, pwoc.Labor, pwoc.Materials, pwoc.Equipment, pwoc.Rentals,  pwoc.[Third Party Contractor] as contractor, pwoc.[Human Resource] as HR
		FROM (
			select b1p.SERV_PROV_CODE, b1p.B1_PER_ID1, b1p.B1_PER_ID2, b1p.B1_PER_ID3, gwoc.TASK_CODE, gwoc.COST_TYPE COST_TYPE   , ISNULL(CONVERT(NUMERIC(10,2),SUM(
			CASE
				ISNULL(gwoc.cost_fix,0)
			WHEN 0
			THEN
				gwoc.cost_quantity * gwoc.cost_unit_cost
			ELSE
				gwoc.cost_fix
			END)
			),0.00) as total_cost
			from b1permit b1p
				LEFT OUTER JOIN dbo.GWORK_ORDER_TASK gwot
				on
					b1p.SERV_PROV_CODE = gwot.SERV_PROV_CODE
					AND b1p.B1_PER_ID1   = gwot.B1_PER_ID1
					AND b1p.B1_PER_ID2   = gwot.B1_PER_ID2
					AND b1p.B1_PER_ID3   = gwot.B1_PER_ID3
				left outer join dbo.GWORK_ORDER_COSTING gwoc on
					gwot.SERV_PROV_CODE = gwoc.SERV_PROV_CODE
					AND gwot.B1_PER_ID1   = gwoc.B1_PER_ID1
					AND gwot.B1_PER_ID2   = gwoc.B1_PER_ID2
					AND gwot.B1_PER_ID3   = gwoc.B1_PER_ID3
					and gwot.G1_TASK_CODE = gwoc.TASK_CODE
					and gwot.G1_TASK_CODE_INDEX = gwoc.TASK_CODE_INDEX
					and gwoc.REC_STATUS   = 'A'
			where ('&lt;All&gt;' IN (@Tasks) or isnull(gwot.G1_TASK_CODE, '-') in (@Tasks))
			group by b1p.SERV_PROV_CODE, b1p.B1_PER_ID1, b1p.B1_PER_ID2, b1p.B1_PER_ID3, gwoc.TASK_CODE, gwoc.COST_TYPE )
		gwoc pivot (SUM(total_cost) for COST_TYPE in ( 
			[Labor],
			[Materials],
			[Equipment],
			[Rentals],
			[Task],
			[Third Party Contractor],
			[Human Resource]) ) pwoc   	  
) wot
    ON
      wot.SERV_PROV_CODE = bp.SERV_PROV_CODE
    AND wot.B1_PER_ID1   = bp.B1_PER_ID1
    AND wot.B1_PER_ID2   = bp.B1_PER_ID2
    AND wot.B1_PER_ID3   = bp.B1_PER_ID3
	and wot.TASK_CODE = got.G1_TASK_CODE
WHERE BP.SERV_PROV_CODE = 'KNOXVILLE' 
AND BP.B1_PER_TYPE           = 'Work Order'
AND BP.B1_PER_SUB_TYPE         = 'Public Service'
and ( 
	(@EndDate is not null and @StartDate is not null 
		and CONVERT(DATE, BP.B1_APPL_STATUS_DATE, 101) between
		CONVERT(DATE, @StartDate, 101) AND CONVERT(DATE, @EndDate, 101)
	)
		
    OR (
        @EndDate is null
    and @StartDate is not null
    and CONVERT(DATE, BP.B1_APPL_STATUS_DATE, 101) &gt;= CONVERT(DATE, @StartDate, 101))
    OR (
        @StartDate is null
    and @EndDate is not null
    and CONVERT(DATE, BP.B1_APPL_STATUS_DATE, 101) &lt;= CONVERT(DATE, @EndDate, 101)) )
AND (
    '&lt;All&gt;'                                IN (@Organ)
  OR ISNULL(gtyp.R3_SUBGROUP_DESC, '-') in (@Organ))
AND (
    '&lt;All&gt;'                         IN (@Tasks)
  OR ISNULL(got.G1_TASK_CODE , '-') in (@Tasks))
AND (
    '&lt;All&gt;'                      IN (@WorkCenter)
  OR ISNULL(ckbx_piv.[Work Center],'-') IN (@WorkCenter))
AND (
    (
      @Completed       = 'Yes'
    AND BP.B1_appl_status = 'Completed')
  OR (
      @Completed = 'No'
    AND BP.B1_appl_status in ('Under Review',
                          'In Progress'  ,
                          'In Queue'     ,
                          'Open'         ,
                          'Received')) )
and (
    '&lt;All&gt;'                               IN (@emse_step)
  OR ISNULL(ckbx_piv.[Work Order Type],'-') in (@emse_step))

  order by ckbx_piv.[Assigned to Organization], 
    BP.REC_DATE,
  BP.B1_APPL_STATUS_DATE,
  WO_NUM asc,
  gtyp.R3_SUBGROUP_DESC,
  ckbx_piv.[Work Center],
  got.G1_TASK_CODE,
  ORD, 
  STREET_NAME, 
  STREET_NUMBER,
  TICKET_NUMBER</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="WO_NUM">
          <DataField>WO_NUM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
