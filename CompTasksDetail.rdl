    </DataSet>
    <DataSet Name="Organ">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <CommandText>select distinct(R3_SUBGROUP_DESC) AS ORGAN, 3 as SEQ
FROM  G3DPTTYP
WHERE     SERV_PROV_CODE = 'KNOXVILLE'  
AND   R3_BUREAU_CODE = 'PS' 
AND  REC_STATUS = 'A' 
AND R3_SUBGROUP_DESC &lt;&gt; 'Public Service'
UNION
SELECT     '&lt;All&gt;' AS ORGAN, 1 as SEQ
UNION
SELECT     '-' AS ORGAN, 2 as SEQ
order by SEQ, ORGAN</CommandText>
      </Query>
      <Fields>
        <Field Name="ORGAN">
          <DataField>ORGAN</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEQ">
          <DataField>SEQ</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Tasks">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <CommandText>SELECT   DISTINCT  R1_TASK_CODE AS Task, 2 AS ID
FROM         RWO_TASK
WHERE     (R1_TASK_CODE LIKE '%-%') AND (REC_STATUS = 'A') AND (R1_TASK_DESCRIPTION LIKE 'PS%')
UNION
SELECT     ' ' AS Task, 4 AS ID
UNION
SELECT     'No Tasks' AS Task, 3 AS ID
UNION
SELECT '&lt;All&gt;' AS Task, 1 AS ID
ORDER BY ID, Task</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Task">
          <DataField>Task</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID">
          <DataField>ID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="WorkCenter">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <CommandText>SELECT VALUE_ AS WorkCenter, 3 as SEQ
FROM V_STANDARD_CHOICE
WHERE    AGENCY_ID = 'KNOXVILLE'
AND  ITEM_DESCRIPTION = 'Work Centers'
UNION
SELECT     '&lt;All&gt;' AS WorkCenter, 1 as SEQ
UNION
SELECT     '-' AS WorkCenter, 2 as SEQ
order by SEQ, WorkCenter</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="WorkCenter">
          <DataField>WorkCenter</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEQ">
          <DataField>SEQ</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Completed">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <CommandText>SELECT  'Yes'  as Completed
UNION

SELECT  'No' as Completed</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Completed">
          <DataField>Completed</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="emse_step">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <CommandText>SELECT   value_ AS EMSE_STEP, 3 as SEQ
FROM       V_STANDARD_CHOICE
WHERE     AGENCY_ID = 'KNOXVILLE'
AND   ITEM_DESCRIPTION = 'WORK ORDER TYPES'
UNION
SELECT     '&lt;All&gt;' AS EMSE_STEP, 1 as SEQ
UNION
SELECT     '-' AS EMSE_STEP, 2 as SEQ
order by SEQ, EMSE_STEP</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="EMSE_STEP">
          <DataField>EMSE_STEP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SEQ">
          <DataField>SEQ</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
