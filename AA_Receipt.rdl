    <DataSet Name="PaymentData">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@agencyid">
            <Value>=Parameters!agencyid.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@receiptnbr">
            <Value>=Parameters!receiptnbr.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  	/*====Transaction Info*/ 
(CASE T.PAYMENT_STATUS WHEN 'VOIDED' THEN '0.00' ELSE (T.PAYMENT_AMOUNT) END) payment_amt
/*====Payment Details*/
,t.PAYMENT_METHOD Txn_type
,(CASE t.PAYMENT_METHOD WHEN 'Trust Account' THEN (t.ACCT_ID +' '+ t.PAYMENT_REF_NBR) ELSE (t.PAYMENT_REF_NBR +' '+ t.CC_AUTH_CODE) END) reference_nbr
,t.PAYMENT_COMMENT REFERENCE_COMMENT
,t.PAYMENT_STATUS
,T.RECEIPT_NBR
,t.payee
,t.CHECK_HOLDER_NAME
,t.STREET
,payee_address
,t.CITY
,t.STATE
,t.ZIP
,t.PHONE_NUMBER
,(CASE WHEN t.PAYMENT_STATUS = 'VOIDED' THEN t.PAYMENT_COMMENT ELSE '' END) void_comment
,a.b1_per_type
,a.b1_per_group
,CASE WHEN (t.B1_PER_ID1 LIKE '__POS') THEN T.PAYMENT_REF_NBR ELSE T.CHECK_NUMBER END CHECK_NUMBER
,t.PAYMENT_METHOD
,t.cc_auth_code Last4
,t.PAYMENT_REF_NBR
,right(R.ACCT_ID,3) as TrustNo
,t.POS_TRANS_SEQ POSNo
,t.PAYMENT_RECEIVED_CHANNEL CCType
,t.TRANSACTION_CODE PayPalTrans
,t.payment_change
,case when t.change_due &lt;&gt; 0 then t.change_due else 0.00 end as change_due
,t.reason
,t.CASHIER_ID
--,t.CONVENIENCE_FEE CCFee
,(SELECT TOP(1) CONVERT(Money,SUBSTRING(f4p.PAYMENT_COMMENT,CHARINDEX('$',f4p.PAYMENT_COMMENT)+1, LEN(f4p.PAYMENT_COMMENT)))
	FROM F4PAYMENT f4p
	WHERE t.SERV_PROV_CODE = f4p.SERV_PROV_CODE
	and t.BATCH_TRANSACTION_NBR = f4p.BATCH_TRANSACTION_NBR
	and f4p.CASHIER_ID like 'PUBLICUSER%'
	and f4p.PAYMENT_COMMENT like 'Service Fee%') AS CCFee
,t.serv_prov_code

,o.BALANCE Balance
,o.TOTAL_FEE TotFee
,o.TOTAL_PAY TotPay

FROM F4PAYMENT t

JOIN B1PERMIT a ON 
t.SERV_PROV_CODE = a.SERV_PROV_CODE AND 
t.B1_PER_ID1 = a.B1_PER_ID1 AND 
t.B1_PER_ID2 = a.B1_PER_ID2 AND 
t.B1_PER_ID3 = a.B1_PER_ID3

left outer join F4ACCT_TRANSACTION R on
t.SERV_PROV_CODE = R.SERV_PROV_CODE AND 
t.PAYMENT_SEQ_NBR=R.PAYMENT_SEQ_NBR AND
t.REC_STATUS=R.REC_STATUS

Left Outer Join BPERMIT_DETAIL o on
a.serv_prov_code = o.serv_prov_code
and a.b1_per_id1 = o.b1_per_id1
and a.b1_per_id2 = o.b1_per_id2
and a.b1_per_id3 = o.b1_per_id3
and o.rec_status &lt;&gt; 'I' 

--JOIN X4TRANS_PAYMENT X ON 
--T .SERV_PROV_CODE = X.SERV_PROV_CODE AND 
--T .TRANSACTION_SEQ_NBR = X.TRANSACTION_SEQ_NBR 

--JOIN F4PAYMENT P ON 
--X.SERV_PROV_CODE = P.SERV_PROV_CODE AND 
--X.B1_PER_ID1 = P.B1_PER_ID1 AND 
--X.B1_PER_ID2 = P.B1_PER_ID2 AND 
--X.B1_PER_ID3 = P.B1_PER_ID3 AND 
--X.PAYMENT_SEQ_NBR = P.PAYMENT_SEQ_NBR

WHERE  /*****Transaction ID OR Receipt Nbr criteria*/
T.SERV_PROV_CODE = @agencyid
--AND (T .TRANSACTION_SEQ_NBR = : TransactionId OR 
and T.RECEIPT_NBR = @receiptnbr



/*****Grouping needed as payment split to different CAPs must appear as one payment */ 

--GROUP by t.PAYMENT_METHOD
--,(CASE t.PAYMENT_METHOD WHEN 'Trust Account' THEN t.ACCT_ID +' '+ t.PAYMENT_REF_NBR ELSE t.PAYMENT_REF_NBR +' '+ t.CC_AUTH_CODE END)
--,t.PAYMENT_STATUS
--,(CASE WHEN t.PAYMENT_STATUS = 'VOIDED' THEN t.PAYMENT_COMMENT ELSE '' END)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="payment_amt">
          <DataField>payment_amt</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Txn_type">
          <DataField>Txn_type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REFERENCE_NBR">
          <DataField>reference_nbr</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
