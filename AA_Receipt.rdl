<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>/PRODUCTION/KNOXVILLE/KNOXVILLE</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>0f7c0c30-a63e-45ac-b3d0-69b22907c57e</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="RecordAndFeeData">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@agencyid">
            <Value>=Parameters!agencyid.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@receiptnbr">
            <Value>=Parameters!receiptnbr.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT distinct /*====Receipt Info*/  
T.TRAN_DATE receipt_date, d.CASHIER_ID, T.TERMINAL_ID, T.ACTION TRANSACTION_TYPE
	/*====Record Info*/ ,(CASE WHEN A.B1_PER_ID1 LIKE '__POS' THEN concat('Point of Sale Transaction #',d.POS_TRANS_SEQ) ELSE A.B1_ALT_ID END) record_id   

    	/*partial payments on fee prior to current payment*/ 
				,(SELECT sum(q.tran_amount) fee_due
        			FROM accounting_audit_trail q
        			WHERE q.serv_prov_code = T.SERV_PROV_CODE AND 
					q.b1_per_id1 = T.B1_PER_ID1 AND 
					q.b1_per_id2 = T.B1_PER_ID2 AND 
					q.b1_per_id3 = T.B1_PER_ID3 AND 
                    			q.feeitem_seq_nbr = T.FEEITEM_SEQ_NBR AND 
					q.acc_audit_seq_nbr &lt; T.ACC_AUDIT_SEQ_NBR AND 
					q.action LIKE('%Applied')) fee_due
		,A.b1_special_text record_name 
                ,dbo.FN_GET_ADDRESS_INFO(A.SERV_PROV_CODE, A.B1_PER_ID1, A.B1_PER_ID2, A.B1_PER_ID3, 'B','PartAddr_Line') SITE_ADDRESS

				,(SELECT min(y.b1_parcel_nbr) 
					--keep dense_rank last ORDER BY nvl(y.B1_PRIMARY_PAR_FLG, 'N')
					FROM b3parcel y
					WHERE A.SERV_PROV_CODE = y.serv_prov_code 
					AND A.B1_PER_ID1 = y.b1_per_id1 
					AND A.B1_PER_ID2 = y.b1_per_id2 AND 
					A.B1_PER_ID3 = y.b1_per_id3) parcel_number 

,a.serv_prov_code
,a.b1_per_group
,a.b1_per_id1
,a.b1_per_id2
,a.b1_per_id3
,a.B1_APP_TYPE_ALIAS RecordAlias
,E.RECEIPT_NBR
,t.TRAN_DATE INVOICE_DATE
,t.INVOICE_NBR
,t.GF_L1 as AcctCode
,t.GF_L3 FEE_DESCRIPTION
,t.GF_L3
,t.GF_DES
,t.GF_FEE - COALESCE((  
     --partial payments on fee prior to current payment
     select  sum(q.tran_amount)
     from    accounting_audit_trail q
     where   q.serv_prov_code=T.SERV_PROV_CODE
             AND q.b1_per_id1=T.B1_PER_ID1
             AND q.b1_per_id2=T.B1_PER_ID2
             AND q.b1_per_id3=T.B1_PER_ID3
             AND q.feeitem_seq_nbr=T.FEEITEM_SEQ_NBR
             AND q.acc_audit_seq_nbr &lt; T.ACC_AUDIT_SEQ_NBR
             AND q.action in ('Payment Applied','Refund Applied','Void Payment Applied')
  ),0) fee_paid
,t.TRAN_AMOUNT
,t.GF_COD FEE_CODE

,b.b1_owner_nbr
,b.b1_owner_full_name
,b.b1_mail_address1
,b.b1_mail_address2
,b.b1_mail_address3
,b.b1_mail_state
,b.b1_mail_zip
,b.b1_mail_city
,b.b1_primary_owner

,i.B1_CONTACT_TYPE CnsltRel
,i.B1_FNAME + ' ' + i.B1_LNAME CnsltName
,i.B1_FULL_NAME CnsltFullName
,i.B1_ADDRESS1 CnsltAddr1
,i.B1_ADDRESS2 CnsltAddr2
,i.B1_CITY CnsltCity
,i.B1_STATE CnsltState
,i.B1_ZIP CnsltZip

/* Not LP
,i.B1_LICENSE_TYPE CnsltRel
,i.B1_BUS_NAME CnsltName
,i.B1_ADDRESS1 CnsltAddr1
,i.B1_ADDRESS2 CnsltAddr2
,i.B1_CITY CnsltCity
,i.B1_STATE CnsltState
,i.B1_ZIP CnsltZip */

,o.TOTAL_FEE TotFee
,G.GF_DISPLAY fee_display_order
,G.FEEITEM_SEQ_NBR
,g.GF_UNIT FeeQty
,d.POS_TRANS_SEQ POSNo
,d.TRANSACTION_CODE PayPalTran

,t.GF_L1 as ItemNo

,UPPER(dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details','Jurisdiction')) as Jurisdiction

,UPPER(dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details',a.b1_per_group + '_Dept')) as Dept

,dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details',a.b1_per_group + '_Addr1') as Address1

,dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details',a.b1_per_group + '_CSZ') as CityStateZip

,dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details',a.b1_per_group + '_Phone') as PhoneMain

,dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details',a.b1_per_group + '_Fax') as PhoneFax

,g3c.G1_FNAME + ' ' + g3c.G1_LNAME as CashierACAName
,g3s.GA_FNAME + ' ' + g3s.GA_LNAME as CashierAAName
,g.FEE_NOTES FEE_NOTE

FROM ACCOUNTING_AUDIT_TRAIL T 

inner JOIN B1PERMIT A ON 
T.SERV_PROV_CODE = A.SERV_PROV_CODE AND 
T.B1_PER_ID1 = A.B1_PER_ID1 AND 
T.B1_PER_ID2 = A.B1_PER_ID2 AND 
T.B1_PER_ID3 = A.B1_PER_ID3 

inner JOIN F4PAYMENT D ON
t.SERV_PROV_CODE=D.SERV_PROV_CODE AND
t.B1_PER_ID1=D.B1_PER_ID1 AND
t.B1_PER_ID2=D.B1_PER_ID2 AND
t.B1_PER_ID3=D.B1_PER_ID3 AND
t.PAYMENT_SEQ_NBR=D.PAYMENT_SEQ_NBR AND
t.REC_STATUS=D.REC_STATUS  

inner JOIN F4RECEIPT E ON
D.SERV_PROV_CODE=E.SERV_PROV_CODE AND
D.RECEIPT_NBR=E.RECEIPT_NBR AND
D.REC_STATUS=E.REC_STATUS

left outer join b3owners b ON 
b.SERV_PROV_CODE = a.SERV_PROV_CODE
AND b.B1_PER_ID1 = a.B1_PER_ID1
AND b.B1_PER_ID2 = a.B1_PER_ID2
and b.b1_per_id3 = a.b1_per_id3
and b.rec_status = 'A'

Left Outer Join B3CONTACT i on
a.SERV_PROV_CODE = i.SERV_PROV_CODE AND 
a.B1_PER_ID1 = i.B1_PER_ID1 AND 
a.B1_PER_ID2 = i.B1_PER_ID2 AND 
a.B1_PER_ID3 = i.B1_PER_ID3 AND
i.B1_CONTACT_TYPE = 'Applicant' AND
i.rec_status = 'A'

/* Not LP
Left Outer Join B3CONTRA i on
a.SERV_PROV_CODE = i.SERV_PROV_CODE AND 
a.B1_PER_ID1 = i.B1_PER_ID1 AND 
a.B1_PER_ID2 = i.B1_PER_ID2 AND 
a.B1_PER_ID3 = i.B1_PER_ID3 AND
i.B1_PRINT_FLAG = 'Y' AND
i.rec_status = 'A' */

Left Outer Join BPERMIT_DETAIL o on
a.serv_prov_code = o.serv_prov_code
and a.b1_per_id1 = o.b1_per_id1
and a.b1_per_id2 = o.b1_per_id2
and a.b1_per_id3 = o.b1_per_id3
and o.rec_status &lt;&gt; 'I' 

LEFT JOIN F4FEEITEM G ON 
T.SERV_PROV_CODE = G.SERV_PROV_CODE AND 
T.B1_PER_ID1 = G.B1_PER_ID1 AND 
T.B1_PER_ID2 = G.B1_PER_ID2 AND 
T.B1_PER_ID3 = G.B1_PER_ID3 
and T.FEEITEM_SEQ_NBR = G.FEEITEM_SEQ_NBR /*****Exclude voided fees*/  
and G.GF_ITEM_STATUS_FLAG = 'INVOICED' 

Left Outer Join X4FEEITEM_INVOICE v on
a.serv_prov_code = v.serv_prov_code
and a.b1_per_id1 = v.b1_per_id1
and a.b1_per_id2 = v.b1_per_id2
and a.b1_per_id3 = v.b1_per_id3
and v.rec_status &lt;&gt; 'I' 
and t.invoice_nbr = v.invoice_nbr 
and T.FEEITEM_SEQ_NBR = G.FEEITEM_SEQ_NBR 

left outer JOIN X4PAYMENT_INVOICE Z ON 
Z.SERV_PROV_CODE = v.SERV_PROV_CODE AND 
Z.INVOICE_NBR = v.INVOICE_NBR

LEFT OUTER JOIN G3STAFFS g3s on
t.SERV_PROV_CODE = g3s.SERV_PROV_CODE
and d.CASHIER_ID = g3s.USER_NAME
--and t.REC_FUL_NAM not like 'PUBLICUSER%'

LEFT OUTER JOIN PUBLICUSER pu on
g3s.GA_FNAME = pu.USER_ID
--Unable to link serv_prov_code here [does not exist in the pubicuser table]

LEFT OUTER JOIN XPUBLICUSER_PEOPLE xpup on
xpup.USER_SEQ_NBR = pu.USER_SEQ_NBR
AND xpup.AGENCY = @agencyid
--Unable to link serv_prov_code here [does not exist in the pubicuser table]

LEFT OUTER JOIN G3CONTACT g3c on
xpup.ENT_ID = g3c.G1_CONTACT_NBR
and xpup.AGENCY = g3c.SERV_PROV_CODE

WHERE  /*****Transaction ID OR Receipt Nbr criteria*/ 
(T.SERV_PROV_CODE = @agencyid 
AND T.ACTION in ('Payment Applied', 'Void Payment Applied', 'Refund Applied')
AND E.RECEIPT_NBR = @receiptnbr)
--and t.cashier_id = d.cashier_id)

UNION

SELECT distinct /*====Receipt Info*/  
T.TRAN_DATE receipt_date, T.CASHIER_ID, T.TERMINAL_ID, T.ACTION TRANSACTION_TYPE
	/*====Record Info*/ ,(CASE WHEN A.B1_PER_ID1 LIKE '__POS' THEN 'Point of Sale Transaction' ELSE A.B1_ALT_ID END) record_id   

    	/*partial payments on fee prior to current payment*/ 
				,(SELECT sum(q.tran_amount) fee_due
        			FROM accounting_audit_trail q
        			WHERE q.serv_prov_code = T.SERV_PROV_CODE AND 
					q.b1_per_id1 = T.B1_PER_ID1 AND 
					q.b1_per_id2 = T.B1_PER_ID2 AND 
					q.b1_per_id3 = T.B1_PER_ID3 AND 
                    			q.feeitem_seq_nbr = T.FEEITEM_SEQ_NBR AND 
					q.acc_audit_seq_nbr &lt; T.ACC_AUDIT_SEQ_NBR AND 
					q.action LIKE('%Applied')) fee_due
		,A.b1_special_text record_name 
                ,dbo.FN_GET_ADDRESS_INFO(A.SERV_PROV_CODE, A.B1_PER_ID1, A.B1_PER_ID2, A.B1_PER_ID3, 'B','PartAddr_Line') SITE_ADDRESS

				,(SELECT min(y.b1_parcel_nbr) 
					--keep dense_rank last ORDER BY nvl(y.B1_PRIMARY_PAR_FLG, 'N')
					FROM b3parcel y
					WHERE A.SERV_PROV_CODE = y.serv_prov_code 
					AND A.B1_PER_ID1 = y.b1_per_id1 
					AND A.B1_PER_ID2 = y.b1_per_id2 AND 
					A.B1_PER_ID3 = y.b1_per_id3) parcel_number 

,a.serv_prov_code
,a.b1_per_group
,a.b1_per_id1
,a.b1_per_id2
,a.b1_per_id3
,a.B1_APP_TYPE_ALIAS RecordAlias
,E.RECEIPT_NBR
,t.TRAN_DATE INVOICE_DATE
,t.INVOICE_NBR
,t.GF_L1 as AcctCode
,t.GF_L3 FEE_DESCRIPTION
,t.GF_L3
,t.GF_DES
,t.GF_FEE - COALESCE((  
     --partial payments on fee prior to current payment
     select  sum(q.tran_amount)
     from    accounting_audit_trail q
     where   q.serv_prov_code=T.SERV_PROV_CODE
             AND q.b1_per_id1=T.B1_PER_ID1
             AND q.b1_per_id2=T.B1_PER_ID2
             AND q.b1_per_id3=T.B1_PER_ID3
             AND q.feeitem_seq_nbr=T.FEEITEM_SEQ_NBR
             AND q.acc_audit_seq_nbr &lt; T.ACC_AUDIT_SEQ_NBR
             AND q.action in ('Payment Applied','Refund Applied','Void Payment Applied')
  ),0) fee_paid
,t.TRAN_AMOUNT
,t.GF_COD FEE_CODE

,b.b1_owner_nbr
,b.b1_owner_full_name
,b.b1_mail_address1
,b.b1_mail_address2
,b.b1_mail_address3
,b.b1_mail_state
,b.b1_mail_zip
,b.b1_mail_city
,b.b1_primary_owner

,i.B1_CONTACT_TYPE CnsltRel
,i.B1_FNAME + ' ' + i.B1_LNAME CnsltName
,i.B1_FULL_NAME CnsltFullName
,i.B1_ADDRESS1 CnsltAddr1
,i.B1_ADDRESS2 CnsltAddr2
,i.B1_CITY CnsltCity
,i.B1_STATE CnsltState
,i.B1_ZIP CnsltZip

/* Not LP
,i.B1_LICENSE_TYPE CnsltRel
,i.B1_BUS_NAME CnsltName
,i.B1_ADDRESS1 CnsltAddr1
,i.B1_ADDRESS2 CnsltAddr2
,i.B1_CITY CnsltCity
,i.B1_STATE CnsltState
,i.B1_ZIP CnsltZip */

,o.TOTAL_FEE TotFee
,G.GF_DISPLAY fee_display_order
,G.FEEITEM_SEQ_NBR
,g.GF_UNIT FeeQty
,d.POS_TRANS_SEQ POSNo
,d.TRANSACTION_CODE PayPalTran

,t.GF_L1 as ItemNo

,UPPER(dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details','Jurisdiction')) as Jurisdiction

,UPPER(dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details',a.b1_per_group + '_Dept')) as Dept

,dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details',a.b1_per_group + '_Addr1') as Address1

,dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details',a.b1_per_group + '_CSZ') as CityStateZip

,dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details',a.b1_per_group + '_Phone') as PhoneMain

,dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details',a.b1_per_group + '_Fax') as PhoneFax

,g3c.G1_FNAME + ' ' + g3c.G1_LNAME as CashierACAName
,g3s.GA_FNAME + ' ' + g3s.GA_LNAME as CashierAAName
,g.FEE_NOTES FEE_NOTE

FROM B1PERMIT A

INNER JOIN ACCOUNTING_AUDIT_TRAIL AT ON 
AT.SERV_PROV_CODE = A.SERV_PROV_CODE AND 
AT.B1_PER_ID1 = A.B1_PER_ID1 AND 
AT.B1_PER_ID2 = A.B1_PER_ID2 AND 
AT.B1_PER_ID3 = A.B1_PER_ID3 AND
AT.ACTION = 'Refund'

inner JOIN F4PAYMENT D ON
AT.SERV_PROV_CODE=D.SERV_PROV_CODE AND
AT.B1_PER_ID1=D.B1_PER_ID1 AND
AT.B1_PER_ID2=D.B1_PER_ID2 AND
AT.B1_PER_ID3=D.B1_PER_ID3 AND
AT.TRAN_AMOUNT = D.PAYMENT_AMOUNT and
AT.PAYMENT_SEQ_NBR = D.PAYMENT_SEQ_NBR and
AT.REC_STATUS=D.REC_STATUS  

inner JOIN F4RECEIPT E ON
D.SERV_PROV_CODE=E.SERV_PROV_CODE AND
D.RECEIPT_NBR=E.RECEIPT_NBR AND
D.PAYMENT_AMOUNT = E.RECEIPT_AMOUNT and
D.REC_STATUS=E.REC_STATUS

INNER JOIN ACCOUNTING_AUDIT_TRAIL T ON 
T.SERV_PROV_CODE = A.SERV_PROV_CODE AND 
T.B1_PER_ID1 = A.B1_PER_ID1 AND 
T.B1_PER_ID2 = A.B1_PER_ID2 AND 
T.B1_PER_ID3 = A.B1_PER_ID3 AND
T.ACTION = 'Refund Applied' and
(T.TRAN_SEQ_NBR = (AT.TRAN_SEQ_NBR - 1) or
T.TRAN_SEQ_NBR = (AT.TRAN_SEQ_NBR - 2) or
T.TRAN_SEQ_NBR = (AT.TRAN_SEQ_NBR - 3) or
T.TRAN_SEQ_NBR = (AT.TRAN_SEQ_NBR - 4))

left outer join b3owners b ON 
b.SERV_PROV_CODE = a.SERV_PROV_CODE
AND b.B1_PER_ID1 = a.B1_PER_ID1
AND b.B1_PER_ID2 = a.B1_PER_ID2
and b.b1_per_id3 = a.b1_per_id3
and b.rec_status = 'A'

Left Outer Join B3CONTACT i on
a.SERV_PROV_CODE = i.SERV_PROV_CODE AND 
a.B1_PER_ID1 = i.B1_PER_ID1 AND 
a.B1_PER_ID2 = i.B1_PER_ID2 AND 
a.B1_PER_ID3 = i.B1_PER_ID3 AND
i.B1_CONTACT_TYPE = 'Applicant' AND
i.rec_status = 'A'

/* Not LP
Left Outer Join B3CONTRA i on
a.SERV_PROV_CODE = i.SERV_PROV_CODE AND 
a.B1_PER_ID1 = i.B1_PER_ID1 AND 
a.B1_PER_ID2 = i.B1_PER_ID2 AND 
a.B1_PER_ID3 = i.B1_PER_ID3 AND
i.B1_PRINT_FLAG = 'Y' AND
i.rec_status = 'A' */

Left Outer Join BPERMIT_DETAIL o on
a.serv_prov_code = o.serv_prov_code
and a.b1_per_id1 = o.b1_per_id1
and a.b1_per_id2 = o.b1_per_id2
and a.b1_per_id3 = o.b1_per_id3
and o.rec_status &lt;&gt; 'I' 

LEFT JOIN F4FEEITEM G ON 
T.SERV_PROV_CODE = G.SERV_PROV_CODE AND 
T.B1_PER_ID1 = G.B1_PER_ID1 AND 
T.B1_PER_ID2 = G.B1_PER_ID2 AND 
T.B1_PER_ID3 = G.B1_PER_ID3 
and T.FEEITEM_SEQ_NBR = G.FEEITEM_SEQ_NBR /*****Exclude voided fees*/  
and G.GF_ITEM_STATUS_FLAG = 'INVOICED' 

Left Outer Join X4FEEITEM_INVOICE v on
a.serv_prov_code = v.serv_prov_code
and a.b1_per_id1 = v.b1_per_id1
and a.b1_per_id2 = v.b1_per_id2
and a.b1_per_id3 = v.b1_per_id3
and v.rec_status &lt;&gt; 'I' 
and t.invoice_nbr = v.invoice_nbr 
and T.FEEITEM_SEQ_NBR = G.FEEITEM_SEQ_NBR 

left outer JOIN X4PAYMENT_INVOICE Z ON 
Z.SERV_PROV_CODE = v.SERV_PROV_CODE AND 
Z.INVOICE_NBR = v.INVOICE_NBR and
t.PAYMENT_SEQ_NBR=z.PAYMENT_SEQ_NBR

LEFT OUTER JOIN G3STAFFS g3s on
t.SERV_PROV_CODE = g3s.SERV_PROV_CODE
and T.CASHIER_ID = g3s.USER_NAME
--and t.REC_FUL_NAM not like 'PUBLICUSER%'

LEFT OUTER JOIN PUBLICUSER pu on
g3s.GA_FNAME = pu.USER_ID
--Unable to link serv_prov_code here [does not exist in the pubicuser table]

LEFT OUTER JOIN XPUBLICUSER_PEOPLE xpup on
xpup.USER_SEQ_NBR = pu.USER_SEQ_NBR
AND xpup.AGENCY = @agencyid 
--Unable to link serv_prov_code here [does not exist in the pubicuser table]

LEFT OUTER JOIN G3CONTACT g3c on
xpup.ENT_ID = g3c.G1_CONTACT_NBR
and xpup.AGENCY = g3c.SERV_PROV_CODE

WHERE  /*****Transaction ID OR Receipt Nbr criteria*/ 
(T.SERV_PROV_CODE = @agencyid)
AND E.RECEIPT_NBR = @receiptnbr
--and t.cashier_id = d.cashier_id)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="FaxLabel">
          <Value>=iif(Fields!b1_per_group.Value &lt;&gt; "Utilities", "Fax", "")</Value>
        </Field>
        <Field Name="receipt_date">
          <DataField>receipt_date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="InvAcctCode">
          <Value>=iif(Fields!TRANSACTION_TYPE.Value like "Refund*", Fields!AcctCode.Value, Fields!INVOICE_NBR.Value)</Value>
        </Field>
        <Field Name="CASHIER_ID">
          <DataField>CASHIER_ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="InvAcctCodeLabel">
          <Value>=iif(Fields!TRANSACTION_TYPE.Value like "Refund*", "Account Code", "Invoice#")</Value>
        </Field>
        <Field Name="TERMINAL_ID">
          <DataField>TERMINAL_ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Grouping">
          <Value>=iif((IsNothing(Fields!FEE_NOTE.Value) or Fields!FEE_NOTE.Value = ""), Fields!GF_DES.Value, Fields!GF_DES.Value &amp; " (" &amp; Fields!FEE_NOTE.Value &amp; ")")</Value>
        </Field>
        <Field Name="TRANSACTION_TYPE">
          <DataField>TRANSACTION_TYPE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="record_id">
          <DataField>record_id</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="fee_due">
          <DataField>fee_due</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="record_name">
          <DataField>record_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SITE_ADDRESS">
          <DataField>SITE_ADDRESS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="parcel_number">
          <DataField>parcel_number</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="serv_prov_code">
          <DataField>serv_prov_code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_per_group">
          <DataField>b1_per_group</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_per_id1">
          <DataField>b1_per_id1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_per_id2">
          <DataField>b1_per_id2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_per_id3">
          <DataField>b1_per_id3</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RecordAlias">
          <DataField>RecordAlias</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RECEIPT_NBR">
          <DataField>RECEIPT_NBR</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
