<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Accela">
      <DataSourceReference>Accela</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>487d7596-8052-4de0-a03a-3fe85da40a70</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Inspector">
            <Value>=Parameters!Inspector.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT  
 B1PERMIT.B1_ALT_ID,
B1PERMIT.B1_PER_SUB_TYPE,
B1PERMIT.B1_APPL_STATUS,
TRIM(cast(ISNULL(B3ADDRES.B1_HSE_NBR_START,'') as varchar) + ' ' +
B3ADDRES.B1_STR_DIR ) + ' ' + B3ADDRES.B1_STR_NAME +  ' '  + B3ADDRES.B1_STR_SUFFIX + ' ' + B3ADDRES.B1_SITUS_CITY AS ADDRESS, 
G6ACTION.G6_ACT_TYP,
G6ACTION.G6_STATUS,
G6ACTION.G6_ACT_DD,
G6ACTION.GA_USERID
FROM   B1PERMIT,  
       G6ACTION,           
       B3ADDRES
WHERE   
 B1PERMIT.SERV_PROV_CODE = 'KNOXVILLE' and
 B1PERMIT.B1_PER_GROUP = 'Enforcement' and
 B1PERMIT.B1_PER_TYPE = 'Codes Enforcement' and
 G6ACTION.G6_STATUS in ('Pending', 'Under Review', 'Scheduled')  and
 B1PERMIT.B1_APPL_STATUS not in ('Completed', 'Duplicate - Closed', 'Transferred','Canceled','Closed - Towed') AND
 G6ACTION.REC_STATUS = 'A' AND
 G6ACTION.SERV_PROV_CODE = B1PERMIT.SERV_PROV_CODE AND
 G6ACTION.B1_PER_ID1 = B1PERMIT.B1_PER_ID1 AND
 G6ACTION.B1_PER_ID2 = B1PERMIT.B1_PER_ID2 AND
 G6ACTION.B1_PER_ID3 = B1PERMIT.B1_PER_ID3 AND
 G6ACTION.G6_COMPL_DD IS NULL AND
 CONVERT(date,G6ACTION.G6_ACT_DD) &lt;= CONVERT (date, GETDATE()) AND 
 B1PERMIT.SERV_PROV_CODE =  B3ADDRES.SERV_PROV_CODE AND
 B1PERMIT.B1_PER_ID1 =  B3ADDRES.B1_PER_ID1 AND 
 B3ADDRES.B1_PER_ID2  =  B3ADDRES.B1_PER_ID2 AND 
 B1PERMIT.B1_PER_ID3 =  B3ADDRES.B1_PER_ID3 AND
 G6ACTION.GA_USERID in (@Inspector)


ORDER BY G6_ACT_DD asc, G6ACTION.GA_USERID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="B1_ALT_ID">
          <DataField>B1_ALT_ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_APPL_STATUS">
          <DataField>B1_APPL_STATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_SUB_TYPE">
          <DataField>B1_PER_SUB_TYPE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="G6_ACT_TYP">
          <DataField>G6_ACT_TYP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="G6_STATUS">
          <DataField>G6_STATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="G6_ACT_DD">
          <DataField>G6_ACT_DD</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="ADDRESS">
          <DataField>ADDRESS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="GA_USERID">
          <DataField>GA_USERID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Inspector">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <CommandText>SELECT DISTINCT GA_USERID AS USER_NAME
FROM         G6ACTION
WHERE SERV_PROV_CODE = 'KNOXVILLE' and
	r3_division_code = 'CODES'
    and ga_fname is not null
ORDER BY GA_USERID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="USER_NAME">
          <DataField>USER_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
