        <Field Name="SERV_PROV_CODE">
          <DataField>SERV_PROV_CODE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_ID1">
          <DataField>B1_PER_ID1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
