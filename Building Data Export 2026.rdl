  <DataSets>
    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select LOGO_CONTENT
from rserv_logo
where serv_prov_code = 'KNOXVILLE'
and logo_type = 'Horizontal Black'
and rec_status = 'A'</CommandText>
      </Query>
      <Fields>
        <Field Name="LOGO_CONTENT">
          <DataField>LOGO_CONTENT</DataField>
          <rd:TypeName>System.Byte[]</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet6">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@altID">
            <Value>=Parameters!altID.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PermitIssuedGreater">
            <Value>=Parameters!PermitIssuedGreater.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ValuationGreater">
            <Value>=Parameters!ValuationGreater.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PermitIssuedLess">
            <Value>=Parameters!PermitIssuedLess.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ValuationLess">
            <Value>=Parameters!ValuationLess.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OpenedDateGreater">
            <Value>=Parameters!OpenedDateGreater.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OpenedDateLess">
            <Value>=Parameters!OpenedDateLess.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@RecordAlias">
            <Value>=Parameters!RecordAlias.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@RecordStatus">
            <Value>=Parameters!RecordStatus.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT a.SERV_PROV_CODE, a.B1_PER_ID1,a.B1_PER_ID2,a.B1_PER_ID3,
a.B1_ALT_ID RECORD_ID,
a.B1_APP_TYPE_ALIAS,
CONVERT(VARCHAR, A.B1_FILE_DD, 101) as openedDate,
a.B1_APPL_STATUS,
dbo.FN_GET_ADDRESS_INFO(a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3, '', '') firstAddress,
dbo.FN_GET_PARCEL_INFO(a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3, '') firstParcel,
dbo.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, 'Estimated Cost (Job Value)') valuation,
dbo.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, 'General Project Type') generalProjectType,
dbo.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, 'Permit Issued Date') permitIssuedDate,
dbo.FN_GET_INVOICED_FEE_TOTAL(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, '', '') totalInvoiced,
dbo.FN_GET_PAYMENT_APPLIED_TOTAL(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, '') totalPaid,
dbo.FN_GET_LICPROF_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, 'BusinessName', '', '', '') LPName,
dbo.FN_GET_LICPROF_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, 'FirstName', '', '', '') LPFirst,
dbo.FN_GET_LICPROF_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, 'LastName', '', '', '') LPLast,
dbo.FN_GET_LICPROF_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, 'LicenseType', '', '', '') LPType,
dbo.FN_GET_LICPROF_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, 'Email', '', '', '') LPEmail,
b.app_status_date lastStatusDate,
dbo.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, 'Permit Expiration Date') permitExpirationDate,
dbo.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3, 'Approved Scope of Work') approvedScopeOfWork
from b1permit a, bpermit_detail b, BCHCKBOX c, BCHCKBOX d
where a.serv_prov_code = 'KNOXVILLE'
and a.serv_prov_code = b.serv_prov_code
and a.serv_prov_code = c.serv_prov_code
and a.serv_prov_code = d.serv_prov_code
and a.b1_per_id1 = b.b1_per_id1
and a.b1_per_id2 = b.b1_per_id2
and a.b1_per_id3 = b.b1_per_id3
and a.rec_status = 'A'
and b.rec_status = 'A'
and a.b1_per_id1 = c.b1_per_id1
and a.b1_per_id2 = c.b1_per_id2
and a.b1_per_id3 = c.b1_per_id3
and c.rec_status = 'A'
and (@altID = '' or @altID IS NULL or a.B1_ALT_ID LIKE '%' + @altID + '%')
-- and a.b1_alt_id like @altID
and c.B1_CHECKBOX_DESC = 'Permit Issued Date'
--and convert(DATETIME, c.B1_CHECKLIST_COMMENT, 101) between '01/01/2023' and '01/31/2023'
and (@PermitIssuedGreater = '' or @PermitIssuedGreater IS NULL or convert(DATETIME, c.B1_CHECKLIST_COMMENT, 101) &gt;= @PermitIssuedGreater)
and (@PermitIssuedLess = '' or @PermitIssuedLess IS NULL or convert(DATETIME, c.B1_CHECKLIST_COMMENT, 101) &lt;= @PermitIssuedLess)
and a.b1_per_id1 = d.b1_per_id1
and a.b1_per_id2 = d.b1_per_id2
and a.b1_per_id3 = d.b1_per_id3
and d.rec_status = 'A'
and d.B1_CHECKBOX_DESC = 'Estimated Cost (Job Value)' 
--and cast(d.B1_CHECKLIST_COMMENT as numeric) between 0 and 1000000
and (@ValuationGreater = '' or @ValuationGreater IS NULL or cast(d.B1_CHECKLIST_COMMENT as numeric) &gt;= @ValuationGreater)
and (@ValuationLess = '' or @ValuationLess IS NULL or cast(d.B1_CHECKLIST_COMMENT as numeric) &lt;= @ValuationLess)
-- and a.b1_file_dd between '01/01/2022' and '12/31/2022'
and (@OpenedDateGreater = '' or @OpenedDateGreater IS NULL or a.b1_file_dd &gt;= @OpenedDateGreater)
and (@OpenedDateLess = '' or @OpenedDateLess IS NULL or a.b1_file_dd &lt;= @OpenedDateLess)
-- and a.b1_appl_status in ('CO Issued')
and a.b1_app_type_alias IN (@RecordAlias)
and a.b1_appl_status IN (@RecordStatus)
order by a.b1_alt_id</CommandText>
      </Query>
