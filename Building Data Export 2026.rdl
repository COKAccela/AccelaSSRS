          <DataField>generalProjectType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="permitIssuedDate">
          <DataField>permitIssuedDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="totalInvoiced">
          <DataField>totalInvoiced</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="totalPaid">
          <DataField>totalPaid</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="LPName">
          <DataField>LPName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LPFirst">
          <DataField>LPFirst</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LPLast">
          <DataField>LPLast</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LPType">
          <DataField>LPType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LPEmail">
          <DataField>LPEmail</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="lastStatusDate">
          <DataField>lastStatusDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="permitExpirationDate">
          <DataField>permitExpirationDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="approvedScopeOfWork">
          <DataField>approvedScopeOfWork</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct b1_app_type_alias
from b1permit
where serv_prov_code = 'KNOXVILLE'
and b1_module_name = 'Building'
and B1_APP_TYPE_ALIAS not in ('Add/Change Licensed Professional', 'Board of Zoning Appeal', 'BZA', 'Change of Contact Information - Permit', 'Inspection Inquiry', 
'License Professional Application')
and rec_status = 'A'
order by b1_app_type_alias</CommandText>
      </Query>
      <Fields>
        <Field Name="b1_app_type_alias">
          <DataField>b1_app_type_alias</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet3">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct b1_appl_status
from b1permit
where serv_prov_code = 'KNOXVILLE'
and b1_module_name = 'Building'
and rec_status = 'A'
and b1_appl_status &lt;&gt; 'OTC - Approved'
order by b1_appl_status</CommandText>
      </Query>
      <Fields>
        <Field Name="b1_appl_status">
          <DataField>b1_appl_status</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
