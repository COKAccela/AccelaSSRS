<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Accela">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=CITYSQL2019;Initial Catalog=AccelaSaaSSQL</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>bd9fc945-2bab-44ce-95c0-fb011daea200</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Status">
            <Value>=Parameters!Status.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--declare @StartDate Date          = '01/01/2024',
--  @EndDate         Date          = '01/31/2024',
--  @Status   varchar(1000) = 'Completed';

select a.b1_alt_id, a.B1_PER_ID1, a.B1_PER_ID2,a.B1_PER_ID3,
a.b1_special_text, a.b1_file_dd,  a.b1_appl_status, 
a.b1_appl_status_date, a.REC_FUL_NAM,  c.B1_WORK_DESC, d.b1_hse_nbr_start, d.b1_str_dir, d.b1_str_name, d.b1_str_suffix, d.b1_unit_type, d.b1_unit_start,
d.b1_situs_zip, e.b1_fname, e.b1_LName
, f.sr_group_desc, 
(SELECT TOP 1
	CASE WHEN b1.b1_special_text IN ('Trash/Recycling Missed', 'Trash Pickup Missed') and b.b1_checklist_comment in ('Curbside Household Trash', 'Trash Curbside') THEN 'aCURBSIDE TRASH'
			WHEN b1.b1_special_text IN ('Trash/Recycling Missed', 'Recycling Pickup Missed') and b.b1_checklist_comment in ('Recycle Curbside', 'Recycling Curbside') THEN 'bCURBSIDE RECYCLE'
			WHEN b1.b1_special_text IN ('Trash/Recycling Missed', 'Trash Pickup Missed') and b.b1_checklist_comment in ('Backdoor Household Trash', 'Trash Backdoor')  THEN 'cBACKDOOR TRASH'
			WHEN b1.b1_special_text IN ('Trash/Recycling Missed', 'Recycling Pickup Missed') and b.b1_checklist_comment in ('Recycle Backdoor', 'Recycling Backdoor')  THEN 'dBACKDOOR RECYCLE'
			WHEN b1.b1_special_text IN ('Trash Cart Issues','Trash/Recycling Missed','Trash Bulky','Trash Bulky Solid Waste') and b.b1_checklist_comment in ('7. Bulky Alert', 'Bulky', 'Bulky Alert') THEN 'eBULKY ALERT'
			WHEN b1.b1_special_text IN ('Trash Cart Issues', 'Trash/Recycling Missed', 'Trash Bulky', 'Trash Bulky Solid Waste') and b.b1_checklist_comment = 'Bulky Missed' THEN 'fBULKY MISSED'
			WHEN b1.b1_special_text IN ('Trash Cart Issues', 'Recycling Issues') and b.b1_checklist_comment in ('3. Stolen trash cart report', 'Stolen trash cart report', '4. No trash cart SFR (Single Family Resident)', '5. No trash cart MU (Multi Unit)', 'New construction; needs trash cart', 'New tenant; needs trash cart', 'Smaller trash cart request', 'Stolen recycling cart report', '4. Stolen Cart Report', 'Trash cart fell into truck')    THEN 'gTRASH CART DELIVERIES'
			WHEN b1.b1_special_text IN ('Recycling Cart Issues', 'Recycling Issues') and b.b1_checklist_comment in ('Stolen recycling cart report', '4. Stolen Cart Report', 'Recycling cart fell into truck') THEN 'hRECYCLING CART DELIVERIES' 
			WHEN b1.b1_special_text IN ('Trash Cart Issues', 'Recycling Issues') and b.b1_checklist_comment in ('1. Damaged trash cart', 'Damaged trash cart') THEN 'iBROKEN TRASH CARTS'
			WHEN b1.b1_special_text IN ('Recycling Cart Issues', 'Recycling Issues') and b.b1_checklist_comment in ('Damaged recycling cart', '3. Damaged Cart Report') THEN 'jBROKEN RECYCLING CARTS'
			WHEN b1.b1_special_text = 'Trash Cart Issues' and b.b1_checklist_comment in ('Other', 'Discontinue backdoor trash pickup; resume curbside') THEN 'kOTHER TRASH CART ISSUES' 
			WHEN b1.b1_special_text  = 'Recycling Cart Issues' and b.b1_checklist_comment = 'Other' THEN 'lOTHER RECYCLE CART ISSUES'
			WHEN b1.b1_special_text IN ('Trash Cart Issues', 'Recycling Issues', 'Recycling Cart Issues', 'Recycling Records') and b.b1_checklist_comment in ('6. Too many trash carts', 'Too many trash carts', 'Discontinue recycling; retrieve cart') THEN 'mRETRIEVALS'
			WHEN b1.b1_special_text = 'Recycling Records' and b.b1_checklist_comment in ('Recycling Sign Up; Need Cart', 'Moved; Update Address', 'Transfer Cart Ownership', 'Other') THEN 'nRECYCLING RECORDS'
			WHEN b1.b1_special_text  = 'Trash/Recycling Contractor Service Complaint' and b.b1_checklist_comment in ('Lid left open', 'Cart not returned properly', 'Property damage', 'Trash left on street', 'WC employee issue', 'Other') THEN 'oCONTRACT SER COMPLAINTS'
	ELSE 'pMISC'
	END AS ReportType 
 from b1permit b1
 LEFT OUTER JOIN bchckbox b ON
	 b1.serv_prov_code = b.SERV_PROV_CODE and
	 b1.b1_per_id1 = b.B1_PER_ID1 and
	 b1.b1_per_id2 = b.B1_PER_ID2 and
	 b1.b1_per_id3 = b.B1_PER_ID3 
 WHERE 
	 B1.SERV_PROV_CODE='KNOXVILLE' AND 
	 b1.b1_per_id1 = a.B1_PER_ID1 and
	 b1.b1_per_id2 = a.B1_PER_ID2 and
	 b1.b1_per_id3 = a.B1_PER_ID3 AND
	 b.b1_checklist_comment in ('1. Damaged trash cart', '2. Smaller trash cart request', '3. Stolen trash cart report','4. No trash cart SFR (Single Family Resident)','5. No trash cart MU (Multi Unit)', '6. Too many trash carts', 'Too many trash carts', '7. Bulky Alert','8. Discontinue backdoor trash pickup', '9. Other', 'Stolen trash cart report', 'Damaged trash cart', 'New construction; needs trash cart', 'New tenant; needs trash cart', 'Smaller trash cart request', 'Discontinue backdoor trash pickup; resume curbside', 'Stolen recycling cart report', 'Damaged recycling cart', 'Discontinue recycling; retrieve cart', 'Recycling Sign Up; Need Cart', 'Moved; Update Address', 'Transfer Cart Ownership', 'Other', 'Bulky Alert', '1. Discontinue Curbside Recycling','2. Discontinue Backdoor Recycling', '3. Damaged Cart Report','4. Stolen Cart Report','5. Other', 'Curbside Household Trash', 'Bulky', 'Bulky Missed', 'Backdoor Household Trash', 'Trash Curbside', 'Trash Backdoor', 'Recycling Curbside', 'Recycling Backdoor', 'Leaves', 'Construction Debris', 'Brush', 'Recycle Backdoor','Recycle Curbside', 'Backdoor Household Trash Signup', 'Curbside Recycling', 'Backdoor Recycling', '1. Curbside Recycling Sign-Up ¿ Need Cart', '2. Moved Update Address', '3. Transfer Cart Ownership', '4. Moved to Unqualified Location', '5. Approved for Cart from Waiting List', '6. Other', 'Lid left open', 'Cart not returned properly', 'Property damage', 'Trash left on street', 'WC employee issue', 'Trash cart fell into truck', 'Recycling cart fell into truck')
) ReportType,
STRING_AGG (concat(ISNULL(bcbox.B1_CHECKBOX_DESC,'n/a'),' - ',ISNULL(bcbox.B1_CHECKLIST_COMMENT,'n/a')), '&lt;br&gt;' )  as 'QA_DETAILS'
from b1permit a 
INNER JOIN BWORKDES c ON
	c.serv_prov_code = a.serv_prov_code and
	c.b1_per_id1 = a.b1_per_id1 and
	c.b1_per_id2 = a.b1_per_id2 and
	c.b1_per_id3 = a.b1_per_id3 
INNER JOIN b3addres d ON
	d.serv_prov_code = a.serv_prov_code and
	d.b1_per_id1 = a.b1_per_id1 and
	d.b1_per_id2 = a.b1_per_id2 and
	d.b1_per_id3 = a.b1_per_id3 and
	d.b1_primary_addr_flg = 'Y' 
INNER JOIN b3contact e ON
	e.serv_prov_code = a.serv_prov_code and
	e.b1_per_id1 = a.b1_per_id1 and
	e.b1_per_id2 = a.b1_per_id2 and
	e.b1_per_id3 = a.b1_per_id3 
--, xxcok.service_requests_vw f
INNER JOIN 
	(SELECT 
		a.SERV_PROV_CODE,
		a.B1_PER_ID1,
		a.B1_PER_ID2,
		a.B1_PER_ID3,
		a.B1_ALT_ID SERVICE_REQUEST_NUM,
		e.R3_SUBGROUP_DESC SR_GROUP_DESC
	  FROM B1PERMIT a
	  LEFT OUTER JOIN B3ADDRES b ON
		b.SERV_PROV_CODE                 = a.SERV_PROV_CODE
		AND b.B1_PER_ID1                      = a.B1_PER_ID1
		AND b.B1_PER_ID2                      = a.B1_PER_ID2
		AND b.B1_PER_ID3                      = a.B1_PER_ID3
	  LEFT OUTER JOIN R3APPTYP c ON
		c.SERV_PROV_CODE                 = a.SERV_PROV_CODE
		AND c.R1_PER_GROUP                    = a.B1_PER_GROUP
		AND c.R1_PER_TYPE                    = a.B1_PER_TYPE
		AND c.R1_PER_SUB_TYPE              = a.B1_PER_SUB_TYPE
		AND c.R1_PER_CATEGORY               = a.B1_PER_CATEGORY
	  LEFT OUTER JOIN BPERMIT_DETAIL d ON
		d.SERV_PROV_CODE                  = a.SERV_PROV_CODE
		AND d.B1_PER_ID1                     = a.B1_PER_ID1
		AND d.B1_PER_ID2                      = a.B1_PER_ID2
		AND d.B1_PER_ID3                      = a.B1_PER_ID3
	  LEFT OUTER JOIN g3dpttyp e ON
		e.serv_prov_code 		= d.serv_prov_code
		and e.r3_dept_key                    = d.b1_asgn_dept
	  LEFT OUTER JOIN r3bureau f ON
		f.R3_AGENCY_CODE                  = e.R3_AGENCY_CODE
		AND f.r3_bureau_code                  = e.r3_bureau_code
		AND f.serv_prov_code                 = e.serv_prov_code
	  LEFT OUTER JOIN r3divisn g ON
		G.R3_DIVISION_CODE               = E.R3_DIVISION_CODE
		AND G.R3_AGENCY_CODE                     = 'KNOX'
		AND g.serv_prov_code 	= e.serv_prov_code
	  LEFT OUTER JOIN BCHCKBOX servicearea ON
		servicearea.SERV_PROV_CODE        = a.SERV_PROV_CODE
		AND servicearea.B1_PER_ID1            = a.B1_PER_ID1
		AND servicearea.B1_PER_ID2            = a.B1_PER_ID2
		AND servicearea.B1_PER_ID3            = a.B1_PER_ID3
		AND servicearea.B1_CHECKBOX_DESC     = 'Service Area'
	  LEFT OUTER JOIN BCHCKBOX councildistrict ON
		councildistrict.SERV_PROV_CODE    = a.SERV_PROV_CODE
		AND councildistrict.B1_PER_ID1        = a.B1_PER_ID1
		AND councildistrict.B1_PER_ID2        = a.B1_PER_ID2
		AND councildistrict.B1_PER_ID3        = a.B1_PER_ID3
		AND councildistrict.B1_CHECKBOX_DESC  = 'Council District'
	  WHERE a.B1_PER_GROUP = 'ServiceRequest'
	  --AND a.b1_alt_id NOT IN (SELECT b1_alt_id FROM b1permit WHERE a.b1_appl_class = 'INCOMPLETE')
	  and a.b1_appl_class &lt;&gt; 'INCOMPLETE'
	  AND A.SERV_PROV_CODE='KNOXVILLE'
	  ) f ON f.service_request_num = a.b1_alt_id
 LEFT OUTER JOIN BCHCKBOX bcbox ON
 a.SERV_PROV_CODE = bcbox.SERV_PROV_CODE 
 AND a.B1_PER_ID1 = bcbox.B1_PER_ID1 
 AND a.B1_PER_ID2 = bcbox.B1_PER_ID2 
 AND a.B1_PER_ID3 = bcbox.B1_PER_ID3
 AND (bcbox.B1_CHECKLIST_COMMENT IN ('2nd Request', '3rd Request', 'Yes', 'Checked', 'CHECKED'))
where 
a.b1_per_group = 'ServiceRequest' and
A.SERV_PROV_CODE='KNOXVILLE'
and a.b1_appl_status in (@Status) 
AND a.b1_special_text in ('Trash Cart Issues', 'Recycling Cart Issues', 'Trash Pickup Missed', 'Recycling Pickup Missed', 'Recycling Issues', 'Recycling Records', 'Trash/Recycling Missed', 'Trash / Recycling Contractor Service Concern', 'Trash/Recycling Contractor Service Complaint', 'Trash / Recycling Contractor Ser', 'Trash/Recycling Contractor Com', 'Trash Bulky', 'Trash Bulky Solid Waste') 
and a.b1_file_dd between @StartDate and @EndDate
group by a.b1_alt_id,  a.B1_PER_ID1, a.B1_PER_ID2,a.B1_PER_ID3,
a.b1_special_text, a.b1_file_dd,  a.b1_appl_status, --b.b1_checkbox_desc , 
a.b1_appl_status_date, a.REC_FUL_NAM,  c.B1_WORK_DESC, d.b1_hse_nbr_start, d.b1_str_dir, d.b1_str_name, d.b1_str_suffix, d.b1_unit_type, d.b1_unit_start,d.b1_situs_zip, e.b1_fname, e.b1_LName
, f.sr_group_desc
</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="b1_alt_id">
          <DataField>b1_alt_id</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_ID1">
          <DataField>B1_PER_ID1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_ID2">
          <DataField>B1_PER_ID2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_ID3">
          <DataField>B1_PER_ID3</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_special_text">
          <DataField>b1_special_text</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_file_dd">
          <DataField>b1_file_dd</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="b1_appl_status">
          <DataField>b1_appl_status</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_appl_status_date">
          <DataField>b1_appl_status_date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="REC_FUL_NAM">
          <DataField>REC_FUL_NAM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_WORK_DESC">
          <DataField>B1_WORK_DESC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_hse_nbr_start">
          <DataField>b1_hse_nbr_start</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="b1_str_dir">
          <DataField>b1_str_dir</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_str_name">
          <DataField>b1_str_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_str_suffix">
          <DataField>b1_str_suffix</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_unit_type">
          <DataField>b1_unit_type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_unit_start">
          <DataField>b1_unit_start</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_situs_zip">
          <DataField>b1_situs_zip</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_fname">
          <DataField>b1_fname</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_LName">
          <DataField>b1_LName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="sr_group_desc">
          <DataField>sr_group_desc</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReportType">
          <DataField>ReportType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QA_DETAILS">
          <DataField>QA_DETAILS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Status">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <CommandText>SELECT        STATUS
FROM            APP_STATUS_GROUP
WHERE        (APP_STATUS_GROUP_CODE = 'Service Requests') AND (REC_STATUS = 'A') AND (STATUS IN ('Assigned To Dept', 'Completed'))
ORDER BY  STATUS</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="STATUS">
          <DataField>STATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
