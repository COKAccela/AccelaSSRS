  <DataSources>
    <DataSource Name="DataSource1">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=CitySQL2022;Initial Catalog=AccelaSaaSSQL</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>7503a12a-c9cc-4571-b566-2ddd812b6d62</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>--DECLARE @StartDate DATE = '2022-11-08';
--DECLARE @EndDate   DATE = '2026-01-26';

;WITH ReportData AS (
   select 
    a.B1_ALT_ID SR_NUMBER
	, a.B1_APPL_STATUS SR_STATUS
	 , a.REC_DATE DATE_SUBMITTED
   ,concat(b.B1_HSE_NBR_START,' ', b.B1_STR_NAME, ' ', b.B1_STR_SUFFIX, ', ' , b.B1_SITUS_ZIP) ADDRESS
  ,c.B1_WORK_DESC DESCRIPTION
  ,d.B1_FULL_NAME CONTACT_NAME
  ,d.B1_PHONE1  CONTACT_PHONE
  -- , dbo.FN_GET_APP_SPEC_INFO ('KNOXVILLE', a.B1_PER_ID1, a.B1_PER_ID2 ,a.B1_PER_ID3, 'Describe Problem in detail?') DETAILED_DESCRIPTION 
   from B1PERMIT a
   INNER JOIN B3ADDRES b
   ON a.B1_PER_ID1 = b.B1_PER_ID1
   and a.B1_PER_ID2 = b.B1_PER_ID2
   and a.B1_PER_ID3 = b.B1_PER_ID3
   and b.B1_PRIMARY_ADDR_FLG='Y'
   and b.SERV_PROV_CODE='KNOXVILLE'
   LEFT JOIN BWORKDES c
   ON a.B1_PER_ID1 = c.B1_PER_ID1
   and a.B1_PER_ID2 = c.B1_PER_ID2
   and a.B1_PER_ID3 = c.B1_PER_ID3
   and c.SERV_PROV_CODE='KNOXVILLE'
   LEFT JOIN B3CONTACT d
   ON a.B1_PER_ID1 = d.B1_PER_ID1
   and a.B1_PER_ID2 = d.B1_PER_ID2
   and a.B1_PER_ID3 = d.B1_PER_ID3
   and d.B1_FLAG='Y'
   and d.SERV_PROV_CODE='KNOXVILLE'
   WHERE
    a.SERV_PROV_CODE='KNOXVILLE'
   and a.B1_PER_TYPE='Parks Maintenance Request'
  -- and a.REC_DATE BETWEEN @StartDate AND @EndDate
    AND NOT (
    a.B1_APPL_STATUS IN ('Completed','Canceled')
    AND a.REC_DATE &lt; DATEADD(DAY, -2, GETDATE())
	)
)
SELECT *
FROM ReportData
order by DATE_SUBMITTED desc;</CommandText>
      </Query>
      <Fields>
        <Field Name="SR_NUMBER">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SR_NUMBER</DataField>
        </Field>
        <Field Name="SR_STATUS">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SR_STATUS</DataField>
        </Field>
        <Field Name="DATE_SUBMITTED">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>DATE_SUBMITTED</DataField>
        </Field>
        <Field Name="ADDRESS">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ADDRESS</DataField>
        </Field>
        <Field Name="DESCRIPTION">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DESCRIPTION</DataField>
        </Field>
        <Field Name="CONTACT_NAME">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CONTACT_NAME</DataField>
        </Field>
        <Field Name="CONTACT_PHONE">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CONTACT_PHONE</DataField>
        </Field>
      </Fields>
    </DataSet>
