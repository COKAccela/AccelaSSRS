      <am:Version>15.1.30001.02</am:Version>
    </am:UpdatedBy>
    <am:LastModifiedTimestamp>2026-07-21T18:13:12.9991655Z</am:LastModifiedTimestamp>
  </am:AuthoringMetadata>
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=CitySQL2022;Initial Catalog=AccelaSaaSSQL</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>8f313998-d641-49e9-8c03-ffff1fd9b46b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>--DECLARE @StartDate DATE = '2022-11-08';
--DECLARE @EndDate   DATE = '2026-01-26';
;WITH ReportData AS (
   select 
    a.B1_ALT_ID SR_NUMBER
	--, a.REC_DATE DATE_SUBMITTED
	,a.b1_appl_status_date STATUS_DATE
	,dbo.FN_GET_PARCEL_NBR ('KNOXVILLE', a.B1_PER_ID1, a.B1_PER_ID2 ,a.B1_PER_ID3) PARCEL
	,LTRIM(RTRIM(
    CONCAT(
        b.B1_HSE_NBR_START,' ',
        b.B1_STR_NAME,' ',
        b.B1_STR_SUFFIX,' ',
        b.B1_UNIT_START,' ',
        b.B1_UNIT_TYPE, ', ',
        b.B1_SITUS_ZIP
    )
)) AS ADDRESS
	,c.B1_WORK_DESC DESCRIPTION
	,d.B1_FULL_NAME CONTACT_NAME
	,d.B1_EMAIL CONTACT_EMAIL
	, dbo.FN_GET_APP_SPEC_INFO ('KNOXVILLE', a.B1_PER_ID1, a.B1_PER_ID2 ,a.B1_PER_ID3, 'Disturbed Acreage') DISTRIBUTED_ACREAGE
	,CASE
	 WHEN a.B1_ALT_ID LIKE 'LAND%' THEN dbo.FN_GET_APP_SPEC_INFO ('KNOXVILLE', a.B1_PER_ID1, a.B1_PER_ID2 ,a.B1_PER_ID3, 'Engineering Scope of Work')
	 WHEN  a.B1_ALT_ID LIKE '%IRC%' OR a.B1_ALT_ID LIKE '%IBC%' THEN  dbo.FN_GET_APP_SPEC_INFO ('KNOXVILLE', a.B1_PER_ID1, a.B1_PER_ID2 ,a.B1_PER_ID3, 'Approved Scope of Work')
	END AS SCOPE_OF_WORK
--	, a.B1_APPL_STATUS SR_STATUS
   from B1PERMIT a
   INNER JOIN
(
    SELECT *,
           ROW_NUMBER() OVER (
               PARTITION BY B1_PER_ID1, B1_PER_ID2, B1_PER_ID3
               ORDER BY CASE WHEN B1_PRIMARY_ADDR_FLG = 'Y' THEN 0 ELSE 1 END
           ) AS rn
    FROM B3ADDRES
    WHERE SERV_PROV_CODE = 'KNOXVILLE'
) b
   ON a.B1_PER_ID1 = b.B1_PER_ID1
   and a.B1_PER_ID2 = b.B1_PER_ID2
   and a.B1_PER_ID3 = b.B1_PER_ID3
   and b.rn=1
  -- and b.B1_PRIMARY_ADDR_FLG='Y'
   and b.SERV_PROV_CODE='KNOXVILLE'
   LEFT JOIN BWORKDES c
   ON a.B1_PER_ID1 = c.B1_PER_ID1
   and a.B1_PER_ID2 = c.B1_PER_ID2
   and a.B1_PER_ID3 = c.B1_PER_ID3
   and c.SERV_PROV_CODE='KNOXVILLE'
   LEFT JOIN B3CONTACT d
   ON a.B1_PER_ID1 = d.B1_PER_ID1
   and a.B1_PER_ID2 = d.B1_PER_ID2
   and a.B1_PER_ID3 = d.B1_PER_ID3
   and d.B1_FLAG='Y'
   and d.SERV_PROV_CODE='KNOXVILLE'
   WHERE
    a.SERV_PROV_CODE='KNOXVILLE'
	--and a.B1_PER_GROUP In ('EngDevServices','Building')
	AND (
    -- Rule 1: All LAND permits (no date restriction)
    a.B1_ALT_ID LIKE 'LAND%'

    OR

    -- Rule 2: IRC / IBC permits, but ONLY before 2026
    (
        (a.B1_ALT_ID LIKE '%IRC%' OR a.B1_ALT_ID LIKE '%IBC%')
        AND (
            a.B1_ALT_ID LIKE '%ALT%'
            OR a.B1_ALT_ID LIKE '%NEW%'
            OR a.B1_ALT_ID LIKE '%ADD%'
            OR a.B1_ALT_ID LIKE '%DEM%'
        )
        AND a.B1_FILE_DD &lt; '2026-01-01'
    )
)


	AND a.B1_APPL_STATUS='Inspection Phase'
    AND a.b1_appl_status_date &gt;= @StartDate
	AND a.b1_appl_status_date &lt;=  @EndDate

)
SELECT *
FROM ReportData
order by STATUS_DATE desc;</CommandText>
      </Query>
      <Fields>
        <Field Name="SR_NUMBER">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SR_NUMBER</DataField>
        </Field>
        <Field Name="STATUS_DATE">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>STATUS_DATE</DataField>
        </Field>
        <Field Name="PARCEL">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PARCEL</DataField>
        </Field>
        <Field Name="ADDRESS">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ADDRESS</DataField>
        </Field>
        <Field Name="DESCRIPTION">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DESCRIPTION</DataField>
        </Field>
        <Field Name="CONTACT_NAME">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CONTACT_NAME</DataField>
        </Field>
        <Field Name="CONTACT_EMAIL">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CONTACT_EMAIL</DataField>
        </Field>
        <Field Name="DISTRIBUTED_ACREAGE">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DISTRIBUTED_ACREAGE</DataField>
        </Field>
        <Field Name="SCOPE_OF_WORK">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>SCOPE_OF_WORK</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
