<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Accela">
      <DataSourceReference>Accela</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>4df22cd3-fdd9-4e1f-8a2a-1a27164d2a73</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AssetGroup">
            <Value>=Parameters!AssetGroup.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AssetType">
            <Value>=Parameters!AssetType.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT GAM.g1_asset_seq_nbr,
    GAM.G1_ASSET_ID,
    GAM.G1_ASSET_GROUP,
    GAM.G1_ASSET_TYPE,
	BP.L1_PARCEL_NBR Parcel_No,
    AD.B1_HSE_NBR_START street_no,
    ISNULL(AD.B1_STR_DIR,' ') prefix,
    AD.B1_STR_NAME street_name,
    AD.B1_STR_SUFFIX as STREET_TYPE
  FROM GASSET_MASTER GAM 
  INNER JOIN GASSET_LOCATION GAL
  ON GAM.SERV_PROV_CODE = GAL.serv_prov_code
  AND GAM.G1_ASSET_SEQ_NBR = GAL.G1_ASSET_SEQ_NBR
-- only one address should ever be returned so as to avoid a cartesian product
LEFT OUTER JOIN
      dbo.B3ADDRES AD
  ON GAL.SERV_PROV_CODE = AD.SERV_PROV_CODE
  and GAL.EXT_UID = AD.EXT_ADDRESS_UID
	AND AD.B1_ADDRESS_NBR = 
	(select top 1 B1_ADDRESS_NBR
	from B3ADDRES  BAD
	where BAD.SERV_PROV_CODE = 'KNOXVILLE'
	and BAD.SERV_PROV_CODE = GAL.SERV_PROV_CODE
	and GAL.EXT_UID = BAD.EXT_ADDRESS_UID
		AND BAD.B1_STR_NAME IS NOT NULL
		order by BAD.B1_STR_NAME Asc)
  left outer join B3PARCEL BP
  ON AD.SERV_PROV_CODE = BP.SERV_PROV_CODE
  AND AD.B1_PER_ID1 = BP.B1_PER_ID1
  AND AD.B1_PER_ID2 = BP.B1_PER_ID2
  AND AD.B1_PER_ID3 = BP.B1_PER_ID3
  and BP.B1_PARCEL_NBR = (SELECT MAX(B1_PARCEL_NBR) 
	FROM B3PARCEL B3P 
	WHERE 
	B3P.SERV_PROV_CODE = 'KNOXVILLE'
                AND AD.SERV_PROV_CODE = B3P.SERV_PROV_CODE
	  AND AD.B1_PER_ID1 = B3P.B1_PER_ID1
	  AND AD.B1_PER_ID2 = B3P.B1_PER_ID2
	  AND AD.B1_PER_ID3 = B3P.B1_PER_ID3)
  WHERE GAM.SERV_PROV_CODE = 'KNOXVILLE'
  AND   GAM.REC_STATUS    = 'A'
  AND    ( @AssetGroup in ('&lt;All&gt;') or GAM.G1_ASSET_GROUP in (@AssetGroup)) 
  AND   (@AssetType  in ('&lt;All&gt;') or GAM.G1_ASSET_TYPE in (@AssetType))
GROUP BY 
GAM.g1_asset_seq_nbr,
    GAM.G1_ASSET_ID,
    GAM.G1_ASSET_GROUP,
    GAM.G1_ASSET_TYPE,
	BP.L1_PARCEL_NBR,
    AD.B1_HSE_NBR_START,
    ISNULL(AD.B1_STR_DIR,' '),
    AD.B1_STR_NAME,
    AD.B1_STR_SUFFIX</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="G1_ASSET_SEQ_NBR">
          <DataField>g1_asset_seq_nbr</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="G1_ASSET_ID">
          <DataField>G1_ASSET_ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="G1_ASSET_GROUP">
          <DataField>G1_ASSET_GROUP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="G1_ASSET_TYPE">
          <DataField>G1_ASSET_TYPE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PARCEL_NO">
          <DataField>Parcel_No</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="STREET_NO">
          <DataField>street_no</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PREFIX">
          <DataField>prefix</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="STREET_NAME">
          <DataField>street_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="STREET_TYPE">
          <DataField>STREET_TYPE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="AssetGroup">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <CommandText>SELECT '&lt;All&gt;', 1 AS ORD
UNION
SELECT DISTINCT G1_ASSET_GROUP,  2 as ORD
FROM         GASSET_MASTER
where SERV_PROV_CODE = 'KNOXVILLE'
order by ORD</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ID">
          <DataField />
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ORD">
          <DataField>ORD</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="AssetType">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <CommandText>SELECT '&lt;All&gt;' as G1_ASSET_TYPE, 1 AS ORD
UNION
SELECT DISTINCT G1_ASSET_TYPE, 2 AS ORD
FROM         GASSET_MASTER
where SERV_PROV_CODE = 'KNOXVILLE'
ORDER BY ORD</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="G1_ASSET_TYPE">
          <DataField>G1_ASSET_TYPE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ORD">
          <DataField>ORD</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
