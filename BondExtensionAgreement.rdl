  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@altID">
            <Value>=Parameters!altID.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--declare @b1_alt_id as varchar(20);
--set @b1_alt_id = 'BOND-25-0300'

select p.serv_prov_code, p.b1_per_id1, p.b1_per_id2, p.b1_per_id3,p.B1_ALT_ID,
bi1.b1_checklist_comment as 'Bond Name',
bi2.b1_checklist_comment as 'Bond Type',
bi3.b1_checklist_comment as 'Issued To', 
kd1.b1_checklist_comment as 'Original Doc Date',
kd2.b1_checklist_comment as 'Original Expiration Date',
kd3.b1_checklist_comment as 'One Year Extension Date',
fi.b1_checklist_comment as 'Insurance Company',
c.B1_BUSINESS_NAME,
c.B1_FNAME,
c.B1_LNAME
from B1PERMIT p
LEFT OUTER JOIN BCHCKBOX bi1 on
bi1.SERV_PROV_CODE = p.SERV_PROV_CODE
and bi1.B1_PER_ID1 = p.B1_PER_ID1
and bi1.B1_PER_ID2 = p.B1_PER_ID2
and bi1.B1_PER_ID3 = p.B1_PER_ID3
and bi1.B1_CHECKBOX_TYPE = 'BOND INFORMATION'
and bi1.B1_CHECKBOX_DESC = 'Bond Name'
LEFT OUTER JOIN BCHCKBOX bi2 on
bi2.SERV_PROV_CODE = bi1.SERV_PROV_CODE
and bi2.B1_PER_ID1 = bi1.B1_PER_ID1
and bi2.B1_PER_ID2 = bi1.B1_PER_ID2
and bi2.B1_PER_ID3 = bi1.B1_PER_ID3
and bi2.B1_CHECKBOX_TYPE = 'BOND INFORMATION'
and bi2.B1_CHECKBOX_DESC = 'Bond Type'
LEFT OUTER JOIN BCHCKBOX bi3 on
bi3.SERV_PROV_CODE = bi2.SERV_PROV_CODE
and bi3.B1_PER_ID1 = bi2.B1_PER_ID1
and bi3.B1_PER_ID2 = bi2.B1_PER_ID2
and bi3.B1_PER_ID3 = bi2.B1_PER_ID3
and bi3.B1_CHECKBOX_TYPE = 'BOND INFORMATION'
and bi3.B1_CHECKBOX_DESC = 'Issued To'
LEFT OUTER JOIN BCHCKBOX kd1 on
kd1.SERV_PROV_CODE = bi3.SERV_PROV_CODE
and kd1.B1_PER_ID1 = bi3.B1_PER_ID1
and kd1.B1_PER_ID2 = bi3.B1_PER_ID2
and kd1.B1_PER_ID3 = bi3.B1_PER_ID3
and kd1.B1_CHECKBOX_TYPE = 'KEY DATES'
and kd1.B1_CHECKBOX_DESC = 'Original Document Date'
LEFT OUTER JOIN BCHCKBOX kd2 on
kd2.SERV_PROV_CODE = kd1.SERV_PROV_CODE
and kd2.B1_PER_ID1 = kd1.B1_PER_ID1
and kd2.B1_PER_ID2 = kd1.B1_PER_ID2
and kd2.B1_PER_ID3 = kd1.B1_PER_ID3
and kd2.B1_CHECKBOX_TYPE = 'KEY DATES'
and kd2.B1_CHECKBOX_DESC = 'Original Expiration Date'
LEFT OUTER JOIN BCHCKBOX kd3 on
kd3.SERV_PROV_CODE = kd2.SERV_PROV_CODE
and kd3.B1_PER_ID1 = kd2.B1_PER_ID1
and kd3.B1_PER_ID2 = kd2.B1_PER_ID2
and kd3.B1_PER_ID3 = kd2.B1_PER_ID3
and kd3.B1_CHECKBOX_TYPE = 'KEY DATES'
and kd3.B1_CHECKBOX_DESC = 'One Year Extension Date'
LEFT OUTER JOIN BCHCKBOX fi on
fi.SERV_PROV_CODE = kd3.SERV_PROV_CODE
and fi.B1_PER_ID1 = kd3.B1_PER_ID1
and fi.B1_PER_ID2 = kd3.B1_PER_ID2
and fi.B1_PER_ID3 = kd3.B1_PER_ID3
and fi.B1_CHECKBOX_TYPE = 'FINANCIAL INFORMATION'
and fi.B1_CHECKBOX_DESC = 'Insurance Company'
LEFT OUTER JOIN B3CONTACT c on
c.SERV_PROV_CODE = fi.SERV_PROV_CODE
and c.B1_PER_ID1 = fi.B1_PER_ID1
and c.B1_PER_ID2 = fi.B1_PER_ID2
and c.B1_PER_ID3 = fi.B1_PER_ID3
and c.B1_CONTACT_TYPE = 'Principal'
and c.B1_FLAG = 'Y'
where p.B1_ALT_ID = @altID </CommandText>
      </Query>
      <Fields>
        <Field Name="serv_prov_code">
          <DataField>serv_prov_code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_per_id1">
          <DataField>b1_per_id1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_per_id2">
          <DataField>b1_per_id2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_per_id3">
          <DataField>b1_per_id3</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_ALT_ID">
          <DataField>B1_ALT_ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Bond_Name">
          <DataField>Bond Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Bond_Type">
          <DataField>Bond Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Issued_To">
          <DataField>Issued To</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Original_Doc_Date">
          <DataField>Original Doc Date</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Original_Expiration_Date">
          <DataField>Original Expiration Date</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="One_Year_Extension_Date">
          <DataField>One Year Extension Date</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Insurance_Company">
          <DataField>Insurance Company</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_BUSINESS_NAME">
          <DataField>B1_BUSINESS_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_FNAME">
          <DataField>B1_FNAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_LNAME">
          <DataField>B1_LNAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="cmp_loc">
          <Value>=IIf(((Fields!Bond_Type.Value="L") AND (Fields!Issued_To.Value="Company")), True, False)</Value>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
