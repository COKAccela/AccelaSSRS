                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value> hereinafter called </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>AGREEMENT</Value>
