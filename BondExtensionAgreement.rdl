                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox35">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>THIS EXTENSION</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, by and between the </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>CITY OF KNOXVILLE</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, a municipal corporation organized and existing under the laws of the State of Tennessee, hereinafter referred to as CITY, and </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>prinFrstNm</Label>
                                  <Value>=Fields!B1_FNAME.Value</Value>
                                  <Style>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value xml:space="preserve"> </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>prinLastNm</Label>
                                  <Value>=Fields!B1_LNAME.Value</Value>
                                  <Style>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>PRINCIPAL, extends the Performance and Indemnity Agreement for </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>bondName</Label>
                                  <Value>=Fields!Bond_Name.Value</Value>
                                  <Style>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>,</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value> hereinafter called </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>AGREEMENT</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, between these parties made and entered into on </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>origDocDt</Label>
                                  <Value>=Fields!Original_Doc_Date.Value</Value>
                                  <Style>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>.</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Center</TextAlign>
                              </Style>
                            </Paragraph>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>  The parties hereby mutually understand and agree that where the Agreement of </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>origDocDt</Label>
                                  <Value>=Fields!Original_Doc_Date.Value</Value>
                                  <Style>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, required the completion of construction by </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>origExpDt</Label>
                                  <Value>=Fields!Original_Expiration_Date.Value</Value>
                                  <Style>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, that these completion dates are hereby extended so that the Agreement between the parties will hereafter require completion of services by </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>oneYrExtDt</Label>
                                  <Value>=Fields!One_Year_Extension_Date.Value</Value>
                                  <Style>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>.</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <HangingIndent>0.5in</HangingIndent>
                              <Style>
                                <TextAlign>Left</TextAlign>
                                <LineHeight>18pt</LineHeight>
                              </Style>
                            </Paragraph>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>   With the exception of the above changes in completion dates, all of the provisions of said Agreement and the exhibits thereto shall remain in full force and effect.</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <HangingIndent>0.5in</HangingIndent>
                              <Style>
                                <TextAlign>Left</TextAlign>
                                <LineHeight>18pt</LineHeight>
                              </Style>
                            </Paragraph>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value />
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <LeftIndent>1in</LeftIndent>
                              <Style>
                                <TextAlign>Left</TextAlign>
                                <LineHeight>18pt</LineHeight>
                              </Style>
                            </Paragraph>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>    IN WITNESS WHEREOF,</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value> the parties have executed this Extension as </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
