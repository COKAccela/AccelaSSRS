                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>THIS EXTENSION</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, by and between the </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>CITY OF KNOXVILLE</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, a municipal corporation organized and existing under the laws of the State of Tennessee, hereinafter referred to as CITY, and </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>ppl</Label>
                                  <Value>=Fields!B1_BUSINESS_NAME.Value</Value>
                                  <Style>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>, </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontWeight>Bold</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>PRINCIPAL, extends the Performance and Indemnity Agreement for </Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontWeight>Normal</FontWeight>
                                    <TextDecoration>None</TextDecoration>
                                    <Color>#000000</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>bondName</Label>
                                  <Value>=Fields!Bond_Name.Value</Value>
                                  <Style>
