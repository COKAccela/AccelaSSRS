<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=IKC2021\IKC2021;Initial Catalog=STANDARDDEMO</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>2982cc0c-99cc-4620-a5ed-2f3405ad4516</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@spc">
            <Value>=Parameters!spc.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@id1">
            <Value>=Parameters!id1.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@id2">
            <Value>=Parameters!id2.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@id3">
            <Value>=Parameters!id3.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>Select a.b1_alt_id AltId
,a.SERV_PROV_CODE
,a.B1_PER_ID1
,a.B1_PER_ID2
,a.B1_PER_ID3

,lg.LOGO_CONTENT Logo

,dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Jurisdiction') as Jurisdiction

,case when a.b1_per_id1 like '%POS' then dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Main' + '_Dept')
else 
dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', a.b1_per_group + '_Dept') end as Department

,case when a.b1_per_id1 like '%POS' then dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Main' + '_Div')
else 
dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', a.b1_per_group + '_Div') end as Division

,case when a.b1_per_id1 like '%POS' then dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Main' + '_Addr1')
else 
dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', a.b1_per_group + '_Addr1') end as Addr1

,case when a.b1_per_id1 like '%POS' then dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Main' + '_CSZ')
else 
dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', a.b1_per_group + '_CSZ') end as CSZ

,case when a.b1_per_id1 like '%POS' then dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Main' + '_Phone')
else 
dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', a.b1_per_group + '_Phone') end as Phone

,case when a.b1_per_id1 like '%POS' then dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Main' + '_Fax')
else 
dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', a.b1_per_group + '_Fax') end as Fax

,case when a.b1_per_id1 like '%POS' then dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Main' + '_Email')
else 
dbo.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', a.b1_per_group + '_Email') end as Email

From b1permit a

Left Outer Join RSERV_LOGO lg on
a.serv_prov_code = lg.serv_prov_code
and lg.LOGO_TYPE = 'Report Header'

where a.serv_prov_code = @spc
and a.b1_per_id1 = @id1
and a.b1_per_id2 = @id2
and a.b1_per_id3 = @id3</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="AltId">
          <DataField>AltId</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_ID1">
          <DataField>B1_PER_ID1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_ID2">
          <DataField>B1_PER_ID2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_ID3">
