  <DataSources>
    <DataSource Name="Accela">
      <DataSourceReference>/Data Sources/Accela</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>3d90bc8b-403a-4c53-ad17-d5f055d18e2c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@IssuedDateFrom">
            <Value>=Parameters!IssuedDateFrom.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@IssuedDateTo">
            <Value>=Parameters!IssuedDateTo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT GP.B1_ALT_ID AS WorkOrder, GP.TRANSACTION_SEQ as IssueNbr, GP.PART_NUMBER as PartNumber, 
GP.TRANSACTION_DATE AS Issued, GP.QUANTITY, 
CONVERT(DECIMAL(16,2), GP.QUANTITY * GP.UNIT_COST) AS TotalCost,
GP.PART_BIN AS IssuedTo,
(SELECT V2.B1_CHECKLIST_COMMENT 
FROM B1PERMIT, BCHCKBOX, BCHCKBOX v2
WHERE B1PERMIT.SERV_PROV_CODE = 'KNOXVILLE'
AND BCHCKBOX.SERV_PROV_CODE = 'KNOXVILLE'
AND v2.SERV_PROV_CODE = 'KNOXVILLE'
AND B1PERMIT.B1_PER_GROUP = 'AMS' AND B1PERMIT.B1_PER_TYPE = 'Miscellaneous' AND B1PERMIT.B1_PER_SUB_TYPE = 'Badge Info'
AND B1PERMIT.B1_PER_ID1 = BCHCKBOX.B1_PER_ID1 AND B1PERMIT.B1_PER_ID2 = BCHCKBOX.B1_PER_ID2 AND B1PERMIT.B1_PER_ID3 = BCHCKBOX.B1_PER_ID3
AND BCHCKBOX.B1_CHECKBOX_DESC = 'TIME_CLOCK_BADGE_NBR'
AND B1PERMIT.B1_PER_ID1 = v2.B1_PER_ID1 AND B1PERMIT.B1_PER_ID2 = v2.B1_PER_ID2 AND B1PERMIT.B1_PER_ID3 = v2.B1_PER_ID3
AND v2.B1_CHECKBOX_DESC = 'EMPL_NAME'
AND SUBSTRING(BCHCKBOX.B1_CHECKLIST_COMMENT, PATINDEX('%[^0]%', BCHCKBOX.B1_CHECKLIST_COMMENT), LEN(BCHCKBOX.B1_CHECKLIST_COMMENT))
= SUBSTRING(GP.PART_BIN, PATINDEX('%[^0]%', GP.PART_BIN), LEN(GP.PART_BIN))
) as EmpName, 
GP.PART_DESCRIPTION, GP.PART_TYPE, CONVERT(DECIMAL(16,2), GP.UNIT_COST) as UnitCost
FROM GPART_TRANSACTION_VIEW_EN_US GP
WHERE GP.SERV_PROV_CODE = 'KNOXVILLE'
AND GP.TRANSACTION_TYPE = 'ISSUE'
AND GP.TRANSACTION_DATE BETWEEN @IssuedDateFrom and DATEADD(DAY, 1, @IssuedDateTo)
ORDER BY GP.B1_ALT_ID, GP.TRANSACTION_SEQ
 </CommandText>
      </Query>
      <Fields>
        <Field Name="WorkOrder">
          <DataField>WorkOrder</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IssueNbr">
          <DataField>IssueNbr</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="PartNumber">
          <DataField>PartNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Issued">
          <DataField>Issued</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="QUANTITY">
          <DataField>QUANTITY</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TotalCost">
          <DataField>TotalCost</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="IssuedTo">
          <DataField>IssuedTo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EmpName">
          <DataField>EmpName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PART_DESCRIPTION">
          <DataField>PART_DESCRIPTION</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PART_TYPE">
          <DataField>PART_TYPE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UnitCost">
          <DataField>UnitCost</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
