          <DataField>WO_NUMBER</DataField>
        </Field>
        <Field Name="WO_STATUS">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>WO_STATUS</DataField>
        </Field>
        <Field Name="CENTER_BUILDING">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CENTER_BUILDING</DataField>
        </Field>
        <Field Name="LOCATION_TYPE">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>LOCATION_TYPE</DataField>
        </Field>
        <Field Name="ADDRESS">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ADDRESS</DataField>
        </Field>
        <Field Name="DETAILED_DESCRIPTION">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DETAILED_DESCRIPTION</DataField>
        </Field>
        <Field Name="DATE_SUBMITTED">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>DATE_SUBMITTED</DataField>
        </Field>
        <Field Name="FIELD_NUMBER">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>FIELD_NUMBER</DataField>
        </Field>
        <Field Name="CONTACT_NAME">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CONTACT_NAME</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
