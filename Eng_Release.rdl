<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=SHERRIE-WORK\SQL2022;Initial Catalog=SANDIMAS_SUPP</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>dcf667c8-dc7f-417f-b326-1d7e8d515a78</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@recordid">
            <Value>=Parameters!recordid.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>Select a.B1_ALT_ID AltID
,a.SERV_PROV_CODE spc
,a.B1_PER_ID1 id1
,a.B1_PER_ID2 id2
,a.B1_PER_ID3 id3
,a.B1_APPL_STATUS CurrStatus
,a.b1_per_group Module

,g.B1_HSE_NBR_START AddrNumStart
,g.B1_STR_DIR StrDir
,g.B1_STR_NAME StrName
,g.B1_UNIT_START AdrUnit
,g.B1_SITUS_CITY AdrCity
,g.B1_SITUS_STATE AdrState
,g.B1_SITUS_ZIP AdrZip

--,g.B1_HSE_NBR_START &amp;' '&amp; g.b1_str_dir &amp;' '&amp; g.b1_str_name &amp;' '&amp; g.b1_situs_city &amp;' '&amp; g.b1_situs_state &amp;' '&amp; g.b1_situs_zip as Address

,i.B1_FULL_NAME ApplName
,i.B1_FNAME ApplFName
,i.B1_LNAME ApplLName
,i.B1_BUSINESS_NAME ApplBusName
,i.B1_ADDRESS1 ApplAddr1
,i.B1_CITY ApplCity
,i.B1_STATE ApplState
,i.B1_ZIP ApplZip
,i.B1_PHONE1 ApplPhone

,i1.B1_FULL_NAME IAName
,i1.B1_FNAME IAFName
,i1.B1_LNAME IALName
,i1.B1_BUSINESS_NAME IABusName
,i1.B1_ADDRESS1 IAAddr1
,i1.B1_CITY IACity
,i1.B1_STATE IAState
,i1.B1_ZIP IAZip
,i1.B1_PHONE1 IAPhone

,lg.LOGO_CONTENT Logo

,dbo.FN_GET_PARCEL_NBR(a.SERV_PROV_CODE,a.B1_PER_ID1,a.B1_PER_ID2,a.B1_PER_ID3) Parcel

,DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Bond Type') as BondType
,DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Issued To') as IssueTo

,DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Bond Name') as BondName
,DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'CC Number') as CCNum
,DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'LOC Number') as LOCNum
,DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Bond Number') as BondNum

,DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Bank') as Bank
,DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Insurance Company') as InsCo

,Convert(Money, DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Bond Amount')) as BondAmt

,cast(convert(char(10), DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'One Year Extension Date'),101) as datetime) as OneYrExt
,cast(convert(char(10), DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Sixty Day Letter Date'),101) as datetime) as SixtyDay
,cast(convert(char(10), DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Ten Day Date'),101) as datetime) as TenDay
,cast(convert(char(10), DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Original Document Date'),101) as datetime) as OrigDocDate
,cast(convert(char(10), DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Original Expiration Date'),101) as datetime) as OrigExpDate
,cast(convert(char(10), DBO.FN_GET_APP_SPEC_INFO(a.serv_prov_code, a.b1_per_id1, a.b1_per_id2, a.b1_per_id3,'Release Date'),101) as datetime) as RelDate

,DBO.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Jurisdiction') as Juris
,DBO.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'EngDevServices_Bond_Div') as EngBondDiv
,DBO.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'EngDevServices_Bond_Name') as EngBondName
,DBO.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'EngDevServices_Bond_Phone') as EngBondPhone
,DBO.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'EngDevServices_Bond_Email') as EngBondEmail
,DBO.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'EngDevServices_PlanningChief') as EngDSChief
,DBO.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'EngDevServices_PlanningChiefTitle') as EngDSChiefTitle

,DBO.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Eng_EncroHeader') as EngHdr

,DBO.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Bond_AttnyName') as AtnyName
,DBO.FN_GET_STDCHOICE_VALUEDESC(a.serv_prov_code,'Report_Details', 'Bond_AttnyTitle') as AtnyTitle

From dbo.B1PERMIT a

Left Outer Join B3ADDRES g on
a.serv_prov_code = g.serv_prov_code
and a.b1_per_id1 = g.b1_per_id1
and a.b1_per_id2 = g.b1_per_id2
and a.b1_per_id3 = g.b1_per_id3
and g.rec_status &lt;&gt; 'I'  
-- and g.B1_PRIMARY_ADDR_FLG = 'Y'

Left Outer Join B3CONTACT i on
a.serv_prov_code = i.serv_prov_code
and a.b1_per_id1 = i.b1_per_id1
and a.b1_per_id2 = i.b1_per_id2
and a.b1_per_id3 = i.b1_per_id3
and i.rec_status &lt;&gt; 'I' 
and i.B1_CONTACT_TYPE = 'Principal'
--and i.B1_FLAG = 'Y'

Left Outer Join B3CONTACT i1 on
a.serv_prov_code = i1.serv_prov_code
and a.b1_per_id1 = i1.b1_per_id1
and a.b1_per_id2 = i1.b1_per_id2
and a.b1_per_id3 = i1.b1_per_id3
and i1.rec_status &lt;&gt; 'I' 
and i1.B1_CONTACT_TYPE = 'Guarantor'
--and i.B1_FLAG = 'Y'

Left Outer Join RSERV_LOGO lg on
a.serv_prov_code = lg.serv_prov_code
and lg.LOGO_TYPE = 'BondLogo'

Where a.serv_prov_code = 'KNOXVILLE'
and a.rec_status &lt;&gt; 'I'
and B1_PER_GROUP ='EngDevServices'
and B1_PER_TYPE = 'Bonds'
and a.b1_alt_id = @recordid</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
