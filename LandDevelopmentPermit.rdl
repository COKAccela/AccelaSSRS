  <DataSets>
    <DataSet Name="LANDPERMIT">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@RECORDID">
            <Value>=Parameters!RECORDID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
VR.[RECORD_ID] AS [RECORD_ID]
,VR.[RECORD_TYPE]	     AS [RECORD_TYPE]
,VR.[DATE_STATUS]	     AS [DATE_STATUS]
,VR.[RECORD_NAME]	     AS [RECORD_NAME]
,VR.[DESCRIPTION]		 AS [DESCRIPTION]
,VR.[SHORT_NOTES]		 AS [SHORT_NOTES]
,VR.[RECORD_STATUS_DATE]	 AS [RECORD_STATUS_DATE]
,VA.[ADDR_PARTIAL]	     AS [ADDR_PARTIAL]
,VA.[CITY]			     AS [CITY]
,VA.[STATE_]			     AS [STATE]
,VA.[ZIP] 			     AS [ZIP]
,VA.[UNIT_TYPE]			 AS [UNIT_TYPE]	
,VA.[UNIT_NBR]			AS [UNIT_NBR]
,ckbx_piv.[Building Inspection Special Conditions] as [BISC]
,ckbx_piv.[Engineering Inspection Special Condition] AS [EISC]
,ckbx_piv.[MEP Inspection Special Conditions] AS [MISP]
,ckbx_piv.[Zoning-Sign Inspection Special Conditions] AS [ZSISC]
,ckbx_piv.[Mechanical] as [Mechanical]
,ckbx_piv.[Electrical] as [Electrical]
,ckbx_piv.[Plumbing] as [Plumbing]
,ckbx_piv.[Expiration Date] as PermitExpirationDate
,ckbx_piv.[Issued Date] as PermitIssuedDate
,ckbx_piv.[Approved Scope of Work] as ApprovedScopeOfWork
,  NULLIF((
    select
      TOP 1 b3p.B1_PARCEL_NBR
    from
      B3PARCEL b3p
    where VR.AGENCY_ID = b3p.serv_prov_code
      and VR.T_ID1 = b3p.b1_per_id1
      and VR.T_ID2 = b3p.b1_per_id2
      and VR.T_ID3 = b3p.b1_per_id3
	  AND b3p.B1_PARCEL_STATUS = 'A'
	  AND b3p.B1_PRIMARY_PAR_FLG = 'Y'
    order by
       b3p.B1_PARCEL_NBR
  ),'') as PARCEL_NBR
FROM [DBO].[V_RECORD] AS VR
inner join [DBO].[V_ADDRESS] VA on vr.RECORD_ID=va.RECORD_ID AND VR.AGENCY_ID=VA.AGENCY_ID
LEFT OUTER JOIN (
		SELECT
			SERV_PROV_CODE SERV_PROV_CODE    ,
			B1_PER_ID1 B1_PER_ID1            ,
			B1_PER_ID2 B1_PER_ID2            ,
			B1_PER_ID3 B1_PER_ID3            ,
			b1_checkbox_desc b1_checkbox_desc,
			b1_checklist_comment b1_checklist_comment
		FROM
			BCHCKBOX)
				  
			bcbox pivot ( max(b1_checklist_comment) for b1_checkbox_desc in ( 
			[Mechanical],
			[Electrical],
			[Plumbing],
			[Expiration Date],
			[Issued Date],
			[Building Inspection Special Conditions],
			[Engineering Inspection Special Condition],
			[MEP Inspection Special Conditions],
			[Zoning-Sign Inspection Special Conditions],
			[Approved Scope of Work]
			) ) ckbx_piv
	on
	VR.AGENCY_ID = ckbx_piv.SERV_PROV_CODE
	AND VR.T_ID1   = ckbx_piv.B1_PER_ID1
	AND VR.T_ID2   = ckbx_piv.B1_PER_ID2
	AND VR.T_ID3   = ckbx_piv.B1_PER_ID3
where 
VR.AGENCY_ID = 'KNOXVILLE'
AND VR.RECORD_MODULE = 'Building'
AND VR.RECORD_ID = @RECORDID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
