    <DataSet Name="LANDPERMITCONTACT">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@RECORDID">
            <Value>=Parameters!RECORDID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select TOP 1 
  NAME_FULL
  ,NAME_FML#  as NAME_FML
 ,BUSINESS_NAME
 ,CONTACT_TYPE

 , TRIM( COALESCE(ADDRESS_LINE1,'')+' '+
    (CASE
        WHEN  ADDRESS_LINE2 IS NOT NULL THEN TRIM(ADDRESS_LINE2)+' '
        ELSE ''
      END)
  +     
  (CASE
        WHEN  ADDRESS_LINE3 IS NOT NULL THEN TRIM(ADDRESS_LINE3) + ' '
        ELSE ''
      END)
   +     (CASE
        WHEN  ADDRESS_PO_BOX IS NOT NULL THEN TRIM(ADDRESS_PO_BOX) + ' '
        ELSE ''
      END)) as ADDRESS_LINE
 , ADDRESS_CITY
 , ADDRESS_STATE
 , ADDRESS_ZIP
 , TRIM( 
	(CASE
		WHEN  PHONE1 IS NOT NULL THEN '(' + SUBSTRING(TRIM(PHONE1),1, 3)  + ')' + SUBSTRING(TRIM(PHONE1),4, 3) + '-' +  SUBSTRING(TRIM(PHONE1),7, 4) 
		ELSE ''
		END)
  + 
	(CASE
		WHEN  PHONE2 IS NOT NULL THEN 
		(CASE WHEN  PHONE1 IS NOT NULL THEN ',  ' ELSE '' END) +
		'(' + SUBSTRING(TRIM(PHONE2),1, 3)  + ')' + SUBSTRING(TRIM(PHONE2),4, 3) + '-' +  SUBSTRING(TRIM(PHONE2),7, 4) 
		ELSE ''
		END)
  +     
	(CASE
	WHEN  PHONE3 IS NOT NULL THEN 
	(CASE WHEN  PHONE1 IS NOT NULL OR PHONE2 IS NOT NULL THEN ',  ' ELSE '' END) +
	'(' + SUBSTRING(TRIM(PHONE3),1, 3)  + ')' + SUBSTRING(TRIM(PHONE3),4, 3) + '-' +  SUBSTRING(TRIM(PHONE3),7, 4) 
	ELSE ''
	END)
) as PHONE_NUMBERS

from V_CONTACT 
where 
AGENCY_ID = 'KNOXVILLE'
AND RECORD_MODULE = 'Building'
AND CONTACT_TYPE = 'Applicant'
and record_id =  @RECORDID</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="NAME_FULL">
          <DataField>NAME_FULL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NAME_FML">
          <DataField>NAME_FML</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BUSINESS_NAME">
          <DataField>BUSINESS_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CONTACT_TYPE">
          <DataField>CONTACT_TYPE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ADDRESS_LINE">
          <DataField>ADDRESS_LINE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ADDRESS_CITY">
          <DataField>ADDRESS_CITY</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ADDRESS_STATE">
          <DataField>ADDRESS_STATE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ADDRESS_ZIP">
          <DataField>ADDRESS_ZIP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PHONE_NUMBERS">
          <DataField>PHONE_NUMBERS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
