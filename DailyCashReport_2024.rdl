  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>Accela</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>2982cc0c-99cc-4620-a5ed-2f3405ad4516</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Module">
            <Value>=Parameters!Module.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PayType">
            <Value>=Parameters!PayType.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT A.SERV_PROV_CODE AS AGENCY_ID
,A.B1_ALT_ID AS RECORD_ID
,A.B1_PER_GROUP AS RECORD_MODULE
,A.B1_SPECIAL_TEXT AS RECORD_NAME
,A.B1_FILE_DD AS RECORD_OPEN_DATE
,A.B1_APPL_STATUS AS RECORD_STATUS
,A.B1_APPL_STATUS_DATE AS RECORD_STATUS_DATE

,ISNULL(NULLIF (A.B1_APP_TYPE_ALIAS, ''), A.B1_PER_GROUP + '/' + A.B1_PER_TYPE + '/' + A.B1_PER_SUB_TYPE + '/' + A.B1_PER_CATEGORY) 
               AS RECORD_TYPE

,B.REC_FUL_NAM AS UPDATED_BY
,B.TRAN_DATE AS UPDATED_DATE
,B.ACTION
,B.TRAN_AMOUNT AS AMOUNT

,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.BANK_NAME END) AS BANK_NAME
,C.BATCH_TRANSACTION_NBR AS BATCH_TRANSACT_ID

,B.TERMINAL_ID AS CASH_DRAWER
,B.CASHIER_ID AS CASHIER_USERID

,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.CHECK_HOLDER_EMAIL END) AS CHECK_HOLDER_EMAIL
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.CHECK_HOLDER_NAME END) AS CHECK_HOLDER_NAME
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.CHECK_NUMBER END) AS CHECK_NUMBER
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.CHECK_TYPE END) AS CHECK_TYPE
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.PAYMENT_DATE END) AS DATE_PAYMENT

,B.TRAN_DATE AS DATE_TRANSACTION
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.DRIVER_LICENSE END) AS DRIVER_LICENSE
,B.GF_L1 AS FEE_ACCT_CODE_1
,B.GF_L2 AS FEE_ACCT_CODE_2
,B.GF_L3 AS FEE_ACCT_CODE_3B
,B.GF_FEE AS FEE_AMOUNT_ASSESSED
,B.GF_COD AS FEE_CODE
,B.GF_DES AS FEE_DESCRIPTION
,B.FEEITEM_SEQ_NBR AS FEE_ID
,B.GF_UNIT AS FEE_QUANTITY
,B.GF_FEE_SCHEDULE AS FEE_SCHEDULE
,B.INVOICE_NBR AS INVOICE_ID

,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.PAYMENT_COMMENT END) AS PAYMENT_COMMENTS
,B.PAYMENT_SEQ_NBR AS PAYMENT_ID

,(CASE when B.ACTION &lt;&gt; 'Refund Applied' and B.CASHIER_ID like 'PUBLICUSER%' and b.payment_method = 'Credit Card' then 'Credit Card - Online'
when B.ACTION &lt;&gt; 'Refund Applied' and B.CASHIER_ID not like 'PUBLICUSER%' and b.payment_method = 'Credit Card' then 'Credit Card - Manual'
when B.ACTION &lt;&gt; 'Refund Applied' and B.CASHIER_ID like 'PUBLICUSER%' and b.payment_method = 'Check' then 'E-Check'
when B.ACTION &lt;&gt; 'Refund Applied' and B.CASHIER_ID not like 'PUBLICUSER%' and b.payment_method = 'Check' then 'Check'
WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN B.PAYMENT_METHOD
else B.PAYMENT_METHOD END) AS PAYMENT_METHOD

,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN B.PAYMENT_REF_NBR END) AS PAYMENT_REFERENCE
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.PAYEE END) AS PAYOR
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.PHONE_NUMBER END) AS PHONE_NUMBER
,C.POS_TRANS_SEQ AS POS_ID

,E.MODULE_NAME AS POS_MODULE
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.RECEIPT_NBR END) AS RECEIPT_ID
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN R.RECEIPT_CUSTOMIZED_NBR END) AS RECEIPT_NUMBER
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN R.RECEIPT_AMOUNT END) AS RECEIPT_TOTAL
,(CASE WHEN B.ACTION &lt;&gt; 'Refund Applied' THEN C.PAYMENT_RECEIVED_CHANNEL END) AS RECEIVED
,(CASE WHEN C.POS_TRANS_SEQ IS NULL THEN A.B1_ALT_ID ELSE NULL END) AS RECORD_ID#
,(CASE WHEN C.POS_TRANS_SEQ IS NULL THEN A.B1_PER_GROUP ELSE NULL END) AS RECORD_MODULE#
,(CASE WHEN C.POS_TRANS_SEQ IS NULL THEN A.B1_FILE_DD ELSE NULL END) AS RECORD_OPEN_DATE#
,(CASE WHEN C.POS_TRANS_SEQ IS NULL THEN A.B1_ALT_ID ELSE 'POS ' + RTRIM(CAST(C.POS_TRANS_SEQ AS CHAR)) END) AS RECORD_OR_POS_ID#
,(CASE WHEN C.POS_TRANS_SEQ IS NULL THEN A.B1_PER_GROUP ELSE E.MODULE_NAME END) AS RECORD_OR_POS_MODU#
,(CASE WHEN C.POS_TRANS_SEQ IS NULL THEN A.B1_APPL_STATUS ELSE NULL END) AS RECORD_STATUS#
,(CASE WHEN C.POS_TRANS_SEQ IS NULL THEN B1_APPL_STATUS_DATE ELSE NULL END) AS RECORD_STATUS_DATE#

,B.SESSION_NBR AS SESSION_ID
,B.SET_ID, B.TRUST_ACCOUNT_ID
,B.WORKSTATION_ID AS WORKSTATION

FROM  B1PERMIT AS A 

INNER JOIN ACCOUNTING_AUDIT_TRAIL AS B ON 
A.SERV_PROV_CODE = B.SERV_PROV_CODE 
AND A.B1_PER_ID1 = B.B1_PER_ID1 
AND A.B1_PER_ID2 = B.B1_PER_ID2 
AND A.B1_PER_ID3 = B.B1_PER_ID3 
and b.rec_status = 'A'

INNER JOIN F4PAYMENT AS C ON 
B.SERV_PROV_CODE = C.SERV_PROV_CODE 
AND B.B1_PER_ID1 = C.B1_PER_ID1 
AND B.B1_PER_ID2 = C.B1_PER_ID2 
AND B.B1_PER_ID3 = C.B1_PER_ID3 
AND B.PAYMENT_SEQ_NBR = C.PAYMENT_SEQ_NBR
and c.rec_status = 'A' 

LEFT OUTER JOIN F4POS_TRANSACTION AS E 
ON C.SERV_PROV_CODE = E.SERV_PROV_CODE 
AND C.POS_TRANS_SEQ = E.POS_TRANS_SEQ 

LEFT OUTER JOIN F4RECEIPT AS R ON 
C.SERV_PROV_CODE = R.SERV_PROV_CODE 
AND C.RECEIPT_NBR = R.RECEIPT_NBR

WHERE A.SERV_PROV_CODE = 'KNOXVILLE'
AND A.REC_STATUS = 'A'
AND B.ACTION IN ('Payment Applied', 'Void Payment Applied', 'Refund Applied')
AND B.TRAN_DATE &gt;= @StartDate
AND B.TRAN_DATE &lt; DATEADD(d,1,@EndDate)
AND A.B1_PER_GROUP = @Module
AND ((@PayType = '--ALL--' AND B.PAYMENT_METHOD LIKE '%') or
	 (@PayType = 'Cash and Check' AND (B.PAYMENT_METHOD IN ('Cash','Money Order') OR (B.PAYMENT_METHOD = 'Check' and B.CASHIER_ID not like 'PUBLICUSER%'))) or
	 (@PayType = 'Credit Card' AND B.PAYMENT_METHOD = 'Credit Card') or
	 (@PayType = 'E-Check' AND ((B.PAYMENT_METHOD = 'Check' AND B.CASHIER_ID like 'PUBLICUSER%') OR (B.PAYMENT_METHOD = 'ECheck'))))</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
