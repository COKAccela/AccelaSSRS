    <DataSet Name="PaymentTypes">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>Select '--ALL--' as PayType
From RSERV_PROV
union
Select 'Cash and Check'
From RSERV_PROV
union
Select 'Credit Card'
From RSERV_PROV
union
Select 'E-Check'
From RSERV_PROV
Where RSERV_PROV.SERV_PROV_CODE = 'KNOXVILLE'</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="PayType">
          <DataField>PayType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
