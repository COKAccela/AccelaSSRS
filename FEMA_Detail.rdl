        </Field>
        <Field Name="R1_COST_DESC">
          <DataField>R1_COST_DESC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="COST_UNIT_COST">
          <DataField>COST_UNIT_COST</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="PSOFT_RATE">
          <DataField>PSOFT_RATE</DataField>
