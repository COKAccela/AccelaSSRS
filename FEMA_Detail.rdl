<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Accela">
      <DataSourceReference>Accela</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>6e33a073-7a1b-40f3-a274-91f8cfccef66</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--declare @StartDate Date          = '01/01/2023',
--  @EndDate         Date          = '12/31/2023';

select
ckbx_piv.[FEMA Eligible] as FEMA_ELIGIBLE,

 TRIM(convert(varchar, ISNULL(AD.B1_HSE_NBR_START,'0')) + ' ' +
 TRIM (ISNULL(AD.B1_STR_DIR,' ')) + ' ' +
 TRIM( ISNULL(AD.B1_STR_NAME,' ')) + ' ' +
 TRIM(ISNULL(AD.B1_STR_SUFFIX,' '))) AS ADDRESS,

rc.R1_COST_TYPE as R1_COST_TYPE, 
rc.R1_Cost_Item as R1_COST_ITEM,
rc.R1_Cost_Desc AS R1_COST_DESC, 
CONVERT(NUMERIC(10,2),goc.COST_UNIT_COST) as COST_UNIT_COST,
CONVERT(NUMERIC(10,2), ISNULL(pivot_ps_badge.[HOURLY_RT], '0.00')) as PSOFT_RATE,



gtyp.R3_SUBGROUP_DESC ASSIGNED_GROUP_DESCR,
BP.B1_ALT_ID WO_NUM,
BP.REC_DATE CREATED_DATE,
BP.B1_APPL_STATUS_DATE as STATUS_DATE,
ckbx_piv.[Work Center] WORK_CENTER,



    CONVERT(NUMERIC(10,2),ISNULL(
  (
    select
      ISNULL(SUM(CONVERT(NUMERIC(10,2),(ISNULL(TD.ATTRIBUTE_VALUE,0)))),0)
    FROM
      BAPPSPECTABLE_VALUE TC
    JOIN
      BAPPSPECTABLE_VALUE TD
    ON
      TD.SERV_PROV_CODE                = TC.SERV_PROV_CODE
    AND TD.B1_PER_ID1                  = TC.B1_PER_ID1
    AND TD.B1_PER_ID2                  = TC.B1_PER_ID2
    AND TD.B1_PER_ID3                  = TC.B1_PER_ID3
    AND TD.GROUP_NAME                  = 'WO_APU'
    AND TD.TABLE_NAME                  = 'ACTUAL PRODUCTION UNITS'
    AND TD.ROW_INDEX                   = TC.ROW_INDEX
    AND TD.COLUMN_NAME                 = 'Quantity'
    AND ISNULL(TD.ATTRIBUTE_VALUE,' ') &lt;&gt; ' '
    WHERE
      TC.SERV_PROV_CODE                = BP.SERV_PROV_CODE
    AND TC.B1_PER_ID1                  = BP.B1_PER_ID1
    AND TC.B1_PER_ID2                  = BP.B1_PER_ID2
    AND TC.B1_PER_ID3                  = BP.B1_PER_ID3
    AND TC.GROUP_NAME                  = 'WO_APU'
    AND TC.TABLE_NAME                  = 'ACTUAL PRODUCTION UNITS'
    AND TC.COLUMN_NAME                 = 'Task'
    AND ISNULL(TC.ATTRIBUTE_VALUE,' ') &lt;&gt; ' '
    AND TC.ATTRIBUTE_VALUE             = got.G1_TASK_CODE ),0)) + (BPD.B1_ACTUAL_PROD_UNITS) AS PROD_UNITS,
	got.G1_TASK_CODE as TASK_CODE,
	CONVERT(NUMERIC(10,2),ISNULL(REG_HR.VALUE, 0)) as REG_HRS,
	CONVERT(NUMERIC(10,2),ISNULL(REG_HR15.VALUE,0)) as REG_HRS15,
	CONVERT(NUMERIC(10,2),ISNULL(REG_HR2.VALUE,0)) as REG_HRS2,
	CONVERT(NUMERIC(10,2),ISNULL(REG_HR.VALUE, 0) * goc.COST_UNIT_COST) as REG_COST,
	CONVERT(NUMERIC(10,2),1.5 * ISNULL(REG_HR15.VALUE,0) * goc.COST_UNIT_COST) as OT15_COST,
	CONVERT(NUMERIC(10,2),2 * ISNULL(REG_HR2.VALUE,0) * goc.COST_UNIT_COST) as OT2_COST,
	CONVERT(NUMERIC(10,2),(ISNULL(REG_HR.VALUE, 0) * goc.COST_UNIT_COST) + (1.5 * ISNULL(REG_HR15.VALUE,0) * goc.COST_UNIT_COST) + (2 * ISNULL(REG_HR2.VALUE,0) * goc.COST_UNIT_COST)) as COST_TOTAL,
BP.SERV_PROV_CODE, 
BP.B1_PER_ID1, 
BP.B1_PER_ID2, 
BP.B1_PER_ID3, 
WD.B1_WORK_DESC,
 TRIM(convert(varchar, ISNULL(AD.B1_HSE_NBR_START,'0'))) AS STREET_NUMBER, 
 TRIM (ISNULL(AD.B1_STR_DIR,' ')) as STREET_NAME_PREFIX, 
 TRIM( ISNULL(AD.B1_STR_NAME,' ')) as STREET_NAME, 
 TRIM(ISNULL(AD.B1_STR_SUFFIX,' ')) AS STREET_NAME_SUFFIX
from B1PERMIT BP
INNER JOIN     
      dbo.BPERMIT_DETAIL BPD
    ON
      BPD.SERV_PROV_CODE   = BP.SERV_PROV_CODE
    AND BPD.B1_PER_ID1     = BP.B1_PER_ID1
    AND BPD.B1_PER_ID2     = BP.B1_PER_ID2
    AND BPD.B1_PER_ID3     = BP.B1_PER_ID3
LEFT OUTER JOIN
      dbo.G3DPTTYP gtyp
    ON
	gtyp.SERV_PROV_CODE = BPD.SERV_PROV_CODE
    and  gtyp.R3_DEPT_KEY      = BPD.B1_ASGN_DEPT
	and gtyp.R3_AGENCY_CODE = BPD.GA_AGENCY_CODE
	AND gtyp.R3_BUREAU_CODE = BPD.GA_BUREAU_CODE
INNER JOIN BWORKDES WD
	ON    WD.SERV_PROV_CODE        = bp.SERV_PROV_CODE
    AND WD.B1_PER_ID1          = bp.B1_PER_ID1
    AND WD.B1_PER_ID2          = bp.B1_PER_ID2
    AND WD.B1_PER_ID3          = bp.B1_PER_ID3
INNER JOIN (
		SELECT
			SERV_PROV_CODE SERV_PROV_CODE    ,
			B1_PER_ID1 B1_PER_ID1            ,
			B1_PER_ID2 B1_PER_ID2            ,
			B1_PER_ID3 B1_PER_ID3            ,
			b1_checkbox_desc b1_checkbox_desc,
			b1_checklist_comment b1_checklist_comment
		FROM
			BCHCKBOX)
				  
			bcbox pivot ( max(b1_checklist_comment) for b1_checkbox_desc in ( 
			[Work Center],
			[Task],
			[FEMA Eligible]) ) ckbx_piv
	on
	BP.SERV_PROV_CODE = ckbx_piv.SERV_PROV_CODE
	AND BP.B1_PER_ID1   = ckbx_piv.B1_PER_ID1
	AND BP.B1_PER_ID2   = ckbx_piv.B1_PER_ID2
	AND BP.B1_PER_ID3   = ckbx_piv.B1_PER_ID3
INNER  JOIN
      dbo.GWORK_ORDER_TASK got
    ON
      got.SERV_PROV_CODE = BP.SERV_PROV_CODE
    AND got.B1_PER_ID1   = BP.B1_PER_ID1
    AND got.B1_PER_ID2   = BP.B1_PER_ID2
    AND got.B1_PER_ID3   = BP.B1_PER_ID3
INNER JOIN 
     dbo.GWORK_ORDER_COSTING goc
    ON
      goc.SERV_PROV_CODE = BP.SERV_PROV_CODE
    AND goc.B1_PER_ID1   = BP.B1_PER_ID1
    AND goc.B1_PER_ID2   = BP.B1_PER_ID2
    AND goc.B1_PER_ID3   = BP.B1_PER_ID3
INNER JOIN
     dbo.RWO_COSTING rc
	 ON
      rc.SERV_PROV_CODE = goc.SERV_PROV_CODE
 AND rc.R1_COST_TYPE = goc.COST_TYPE
 AND rc.R1_COST_ITEM = goc.COST_ITEM

INNER join RCOST_RATE rr
on 
rc.SERV_PROV_CODE = rr.SERV_PROV_CODE
and rc.R1_COST_ITEM = rr.R1_COST_ITEM
and rc.R1_COST_TYPE = rr.R1_COST_TYPE
 and goc.COST_DATE &gt;= rr.R1_ACTIVE_DATE 
and rr.R1_RATE_SEQ = ( select max(R1_RATE_SEQ) 
 FROM RCOST_RATE rcr
 where 
rcr.SERV_PROV_CODE = rr.SERV_PROV_CODE
and rcr.R1_COST_ITEM = rr.R1_COST_ITEM
 and rcr.R1_COST_TYPE = rr.R1_COST_TYPE
 and goc.COST_DATE &gt;= rcr.R1_ACTIVE_DATE
  group by rcr.R1_COST_ITEM) 

LEFT OUTER JOIN
      dbo.B3ADDRES AD
    ON
    AD.SERV_PROV_CODE        = bp.SERV_PROV_CODE
    AND AD.B1_PER_ID1          = bp.B1_PER_ID1
    AND AD.B1_PER_ID2          = bp.B1_PER_ID2
    AND AD.B1_PER_ID3          = bp.B1_PER_ID3
	AND AD.B1_ADDRESS_NBR = 
	(select top 1 B1_ADDRESS_NBR
		from B3ADDRES  ojad
		where ojad.SERV_PROV_CODE = bp.SERV_PROV_CODE
			AND ojad.B1_PER_ID1                  = bp.B1_PER_ID1
			AND ojad.B1_PER_ID2                  = bp.B1_PER_ID2
			AND ojad.B1_PER_ID3                  = bp.B1_PER_ID3
			and ojad.B1_PRIMARY_ADDR_FLG = 'Y'
			AND ojad.B1_STR_NAME IS NOT NULL
			order by ojad.B1_STR_NAME Asc
	)

LEFT OUTER JOIN (
    SELECT GC.SERV_PROV_CODE, 
	GC.B1_PER_ID1, 
	GC.B1_PER_ID2,
	GC.B1_PER_ID3, 
	GOC.Task_code, 
	GOC.COST_ITEM, 
    CONVERT(NUMERIC(10,2),ISNULL(SUM(ISNULL(GC.cost_quantity,0)),0) ) AS VALUE
    FROM GCOSTING_QUANTITY as GC
    inner join GWORK_ORDER_COSTING as GOC
	ON GC.SERV_PROV_CODE        = GOC.SERV_PROV_CODE
    and GC.B1_PER_ID1            = GOC.B1_PER_ID1
    and GC.B1_PER_ID2            = GOC.B1_PER_ID2
    and GC.B1_PER_ID3            = GOC.B1_PER_ID3
    and GC.ENTITY_ID             = GOC.cost_seq_nbr
	and GOC.COST_TYPE    = 'Labor'
    WHERE GC.ENTITY_TYPE           = 'RECORD'
    AND GC.REC_STATUS            = 'A'
	and   GC.COST_FACTOR = 1
	group by GC.SERV_PROV_CODE, 
	GC.B1_PER_ID1, 
	GC.B1_PER_ID2,
	GC.B1_PER_ID3, 
	GOC.Task_code, 
	GOC.COST_ITEM ) AS REG_HR
	on REG_HR.SERV_PROV_CODE        = BP.SERV_PROV_CODE
    and REG_HR.B1_PER_ID1            = BP.B1_PER_ID1
    and REG_HR.B1_PER_ID2            = BP.B1_PER_ID2
    and REG_HR.B1_PER_ID3            = BP.B1_PER_ID3
	and ( ISNULL(REG_HR.Task_code,'-')  = '-' or ISNULL(REG_HR.Task_code,'-') = got.G1_TASK_CODE)
	and  REG_HR.COST_ITEM = rc.R1_COST_ITEM

LEFT OUTER JOIN (
    SELECT GC.SERV_PROV_CODE, 
	GC.B1_PER_ID1, 
	GC.B1_PER_ID2,
	GC.B1_PER_ID3, 
	GOC.Task_code, 
	GOC.COST_ITEM, 
    CONVERT(NUMERIC(10,2),ISNULL(SUM(ISNULL(GC.cost_quantity,0)),0) ) AS VALUE
    FROM GCOSTING_QUANTITY as GC
    inner join GWORK_ORDER_COSTING as GOC
	ON GC.SERV_PROV_CODE        = GOC.SERV_PROV_CODE
    and GC.B1_PER_ID1            = GOC.B1_PER_ID1
    and GC.B1_PER_ID2            = GOC.B1_PER_ID2
    and GC.B1_PER_ID3            = GOC.B1_PER_ID3
    and GC.ENTITY_ID             = GOC.cost_seq_nbr
	and GOC.COST_TYPE    = 'Labor'
    WHERE GC.ENTITY_TYPE           = 'RECORD'
    AND GC.REC_STATUS            = 'A'
	and   GC.COST_FACTOR = 1.5
	group by GC.SERV_PROV_CODE, 
	GC.B1_PER_ID1, 
	GC.B1_PER_ID2,
	GC.B1_PER_ID3, 
	GOC.Task_code, 
	GOC.COST_ITEM ) AS REG_HR15
	on REG_HR15.SERV_PROV_CODE        = BP.SERV_PROV_CODE
    and REG_HR15.B1_PER_ID1            = BP.B1_PER_ID1
    and REG_HR15.B1_PER_ID2            = BP.B1_PER_ID2
    and REG_HR15.B1_PER_ID3            = BP.B1_PER_ID3
	and ( ISNULL(REG_HR15.Task_code,'-')  = '-' or ISNULL(REG_HR15.Task_code,'-') = got.G1_TASK_CODE)
	and  REG_HR15.COST_ITEM = rc.R1_COST_ITEM

LEFT OUTER JOIN (
    SELECT GC.SERV_PROV_CODE, 
	GC.B1_PER_ID1, 
	GC.B1_PER_ID2,
	GC.B1_PER_ID3, 
	GOC.Task_code, 
	GOC.COST_ITEM, 
    CONVERT(NUMERIC(10,2),ISNULL(SUM(ISNULL(GC.cost_quantity,0)),0) ) AS VALUE
    FROM GCOSTING_QUANTITY as GC
    inner join GWORK_ORDER_COSTING as GOC
	ON GC.SERV_PROV_CODE        = GOC.SERV_PROV_CODE
    and GC.B1_PER_ID1            = GOC.B1_PER_ID1
    and GC.B1_PER_ID2            = GOC.B1_PER_ID2
    and GC.B1_PER_ID3            = GOC.B1_PER_ID3
    and GC.ENTITY_ID             = GOC.cost_seq_nbr
	and GOC.COST_TYPE    = 'Labor'
    WHERE GC.ENTITY_TYPE           = 'RECORD'
    AND GC.REC_STATUS            = 'A'
	and   GC.COST_FACTOR = 2
	group by GC.SERV_PROV_CODE, 
	GC.B1_PER_ID1, 
	GC.B1_PER_ID2,
	GC.B1_PER_ID3, 
	GOC.Task_code, 
	GOC.COST_ITEM ) AS REG_HR2
	on REG_HR2.SERV_PROV_CODE        = BP.SERV_PROV_CODE
    and REG_HR2.B1_PER_ID1            = BP.B1_PER_ID1
    and REG_HR2.B1_PER_ID2            = BP.B1_PER_ID2
    and REG_HR2.B1_PER_ID3            = BP.B1_PER_ID3
	and ( ISNULL(REG_HR2.Task_code,'-')  = '-' or ISNULL(REG_HR2.Task_code,'-') = got.G1_TASK_CODE)
	and  REG_HR2.COST_ITEM = rc.R1_COST_ITEM


LEFT OUTER JOIN (
	SELECT b1.SERV_PROV_CODE, b1.B1_PER_ID1, b1.B1_PER_ID2, b1.B1_PER_ID3, bb.b1_checkbox_desc, bb.b1_checklist_comment
	FROM B1PERMIT b1
	inner join BCHCKBOX bb 
	on b1.SERV_PROV_CODE = bb.SERV_PROV_CODE
	and b1.B1_PER_ID1  = bb.B1_PER_ID1
	and b1.B1_PER_ID2 = bb.B1_PER_ID2
	and b1.B1_PER_ID3 = bb.B1_PER_ID3
	and b1.B1_PER_TYPE = bb.B1_PER_TYPE
	and b1.B1_PER_SUB_TYPE = bb.B1_PER_SUB_TYPE
	WHERE b1.SERV_PROV_CODE = 'KNOXVILLE'
	AND b1.B1_PER_GROUP = 'AMS' 
	AND b1.B1_PER_TYPE = 'Miscellaneous' 
	AND b1.B1_PER_SUB_TYPE = 'Badge Info' 
	AND B1_PER_CATEGORY = 'NA' 
	AND b1.REC_STATUS = 'A' ) as bcbox 
pivot ( max(b1_checklist_comment) for b1_checkbox_desc in ( 
			[HOURLY_RT],
			[EMPLID],
			[EMPL_NAME]) ) as pivot_ps_badge
on bp.SERV_PROV_CODE = pivot_ps_badge.SERV_PROV_CODE
and FORMAT(cast(pivot_ps_badge.[EMPLID] as int) , '000000') = substring(rc.R1_Cost_Item, CHARINDEX('-',rc.R1_Cost_Item) + 1, len(rc.R1_Cost_Item) - CHARINDEX('-',rc.R1_Cost_Item)) 

WHERE BP.SERV_PROV_CODE = 'KNOXVILLE' 
 AND BP.B1_PER_TYPE                      = 'Work Order'
  AND BP.B1_PER_SUB_TYPE                    = 'Public Service'
  
and BP.b1_appl_status = 'Completed'
 AND isnull(goc.COST_TYPE, '') = 'Labor'

and ckbx_piv.[Work Center] is not null
and ISNULL(ckbx_piv.[FEMA Eligible],'')  = 'CHECKED'
and ( 
	(@EndDate is not null and @StartDate is not null 
		and CONVERT(DATE, BP.B1_APPL_STATUS_DATE, 101) between
		CONVERT(DATE, @StartDate, 101) AND CONVERT(DATE, @EndDate, 101)
	)
		
    OR (
        @EndDate is null
    and @StartDate is not null
    and CONVERT(DATE, BP.B1_APPL_STATUS_DATE, 101) &gt;= CONVERT(DATE, @StartDate, 101))
    OR (
        @StartDate is null
    and @EndDate is not null
    and CONVERT(DATE, BP.B1_APPL_STATUS_DATE, 101) &lt;= CONVERT(DATE, @EndDate, 101)) )
order by BP.B1_ALT_ID, goc.COST_ITEM</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
