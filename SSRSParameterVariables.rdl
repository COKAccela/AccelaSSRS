  <DataSources>
    <DataSource Name="Accela">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=citysql2019;Initial Catalog=AccelaSaaSSQL</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>5209efd1-42d4-425f-8c05-aec4c38201b5</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <CommandText>SELECT RD.SERV_PROV_CODE, RD.REPORT_NAME, RD.REPORT_LINK,
  RC.CATEGORY_NAME, RP.PARAMETER_NAME, XP.DATA1
  FROM RPT_DETAIL RD
  INNER JOIN [RPT_CATEGORY] RC
  ON RD.SERV_PROV_CODE = RC.SERV_PROV_CODE
    AND RD.CATEGORY_ID = RC.RPT_CATEGORY_ID
  LEFT OUTER JOIN RPT_PARAMETER RP
  ON RD.SERV_PROV_CODE = Rp.SERV_PROV_CODE
    AND RD.REPORT_ID = RP.REPORT_ID
    AND UPPER(parameter_type) = 'DROPDOWN'
  inner JOIN XPOLICY XP
  ON XP.SERV_PROV_CODE = RD.SERV_PROV_CODE
    AND CONVERT(VARCHAR,XP.POLICY_SEQ) = rp.DEFAULT_VALUE
    AND XP.POLICY_NAME = 'ReportVariableSec'
  WHERE RD.SERV_PROV_CODE = 'KNOXVILLE' 
    AND RD.REPORT_TYPE = '65'
order by RP.PARAMETER_NAME</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SERV_PROV_CODE">
          <DataField>SERV_PROV_CODE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REPORT_NAME">
          <DataField>REPORT_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="REPORT_LINK">
          <DataField>REPORT_LINK</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CATEGORY_NAME">
          <DataField>CATEGORY_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PARAMETER_NAME">
          <DataField>PARAMETER_NAME</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA1">
          <DataField>DATA1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
