<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Accela">
      <DataSourceReference>Accela</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>4df22cd3-fdd9-4e1f-8a2a-1a27164d2a73</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@RECORD_ID">
            <Value>=Parameters!RECORD_ID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT   g6a.G6_ACT_TYP
      ,g6a.G6_ACT_DES
	  ,g6a.G6_STATUS
  FROM B1PERMIT AS b1p 
  INNER JOIN G6ACTION as g6a
  ON  g6a.SERV_PROV_CODE = b1p.SERV_PROV_CODE AND
 g6a.B1_PER_ID1 = b1p.B1_PER_ID1 AND
 g6a.B1_PER_ID2 = b1p.B1_PER_ID2 AND
 g6a.B1_PER_ID3 = b1p.B1_PER_ID3
  where 
  b1p.SERV_PROV_CODE = 'KNOXVILLE'
  AND b1p.B1_ALT_ID =  @RECORD_ID -- 'IRC-NEW-24-0610'
  and g6a.G6_STATUS = 'Pending'
  and g6a.REC_STATUS = 'A'</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="G6_ACT_TYP">
          <DataField>G6_ACT_TYP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="G6_ACT_DES">
          <DataField>G6_ACT_DES</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="G6_STATUS">
          <DataField>G6_STATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
