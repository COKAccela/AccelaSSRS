          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TotFee">
          <DataField>TotFee</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CityStateZip">
          <DataField>CityStateZip</DataField>
          <rd:TypeName>System.String</rd:TypeName>
