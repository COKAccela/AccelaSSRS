          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FaxLabel">
          <Value>=iif(Fields!b1_per_group.Value &lt;&gt; "Utilities", "Fax", "")</Value>
        </Field>
        <Field Name="Grouping">
          <Value>=iif((IsNothing(Fields!FEE_NOTE.Value) or Fields!FEE_NOTE.Value = ""), Fields!FEE_DESCRIPTION.Value, Fields!FEE_DESCRIPTION.Value &amp; " (" &amp; Fields!FEE_NOTE.Value &amp; ")")</Value>
        </Field>
        <Field Name="CashierACAName">
          <DataField>CashierACAName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CashierAAName">
          <DataField>CashierAAName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
