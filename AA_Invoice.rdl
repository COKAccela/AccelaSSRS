        <Field Name="ApplName">
          <DataField>ApplName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ApplAddr1">
          <DataField>ApplAddr1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_per_group">
          <DataField>b1_per_group</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Jurisdiction">
          <DataField>Jurisdiction</DataField>
