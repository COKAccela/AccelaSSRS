  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>Accela</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>5c62892c-a797-4c7f-be9b-9f2eea90c33c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@BegDate">
            <Value>=Parameters!BegDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
			TRIM(e.b1_parcel_nbr) AS PARCEL_NUMBER,
			FORMAT(b.BALANCE, 'N2') AS BALANCE,
			CONVERT(VARCHAR, CAST(d.B1_CHECKLIST_COMMENT AS DATE), 112) AS DATE_LIEN_FILED,
			YEAR(CAST(d.B1_CHECKLIST_COMMENT AS DATE)) AS YEAR,
			TRIM(a.B1_ALT_ID) AS ALTERNATE_ID,
			--a.B1_APP_TYPE_ALIAS,
			--b.TOTAL_FEE, 
			--b.TOTAL_PAY,
			--c.SD_PRO_DES, 
			--c.SD_APP_DES, 
			--d.B1_CHECKLIST_COMMENT as DATE_LIEN_FILED,
			--FORMAT(c.G6_STAT_DD, 'MM/dd/yyyy') as LIEN_FILED_STATUS_DATE, 
			--a.B1_APPL_STATUS,
			a.B1_PER_ID1,
			a.B1_PER_ID2,
			a.B1_PER_ID3
				
	FROM	B1PERMIT a
			LEFT JOIN BPERMIT_DETAIL b
				ON a.SERV_PROV_CODE = b.SERV_PROV_CODE
				and a.B1_PER_ID1 = b.B1_PER_ID1
				and a.B1_PER_ID2 = b.B1_PER_ID2
				and a.B1_PER_ID3 = b.B1_PER_ID3
			LEFT JOIN GPROCESS c
				ON a.SERV_PROV_CODE = c.SERV_PROV_CODE
				and a.B1_PER_ID1 = c.B1_PER_ID1
				and a.B1_PER_ID2 = c.B1_PER_ID2
				and a.B1_PER_ID3 = c.B1_PER_ID3
			LEFT JOIN GPROCESS_SPEC_INFO d
				ON a.SERV_PROV_CODE = d.SERV_PROV_CODE
				and a.B1_PER_ID1 = d.B1_PER_ID1
				and a.B1_PER_ID2 = d.B1_PER_ID2
				and a.B1_PER_ID3 = d.B1_PER_ID3
			LEFT JOIN B3PARCEL e
				ON a.SERV_PROV_CODE = e.SERV_PROV_CODE
				and a.B1_PER_ID1 = e.B1_PER_ID1
				and a.B1_PER_ID2 = e.B1_PER_ID2
				and a.B1_PER_ID3 = e.B1_PER_ID3
			
	WHERE 	a.SERV_PROV_CODE = 'KNOXVILLE' 
	AND a.B1_APP_TYPE_ALIAS in ('CE Structure Complaint')
	AND b.BALANCE &gt; 0
	AND c.SD_APP_DES in ('Lien Owed - Work Completed', 'Open-lien', 'Closed-lien')
--'Bill Owed' removed 7/31/2024 - Not needed per Cheri Burke
	AND d.B1_CHECKBOX_TYPE = 'STR LIEN INFORMATION'
	AND d.B1_CHECKBOX_DESC = 'Date Lien Filed'
	AND CAST(d.b1_checklist_comment AS date) between @BegDate AND @EndDate
	AND a.B1_APPL_STATUS in ('Lien Owed', 'Lien Owed - Open', 'Lien Owed - Closed')
-- 'Bill Owed' removed 7/31/2024 - Not needed per Cheri Burke
	ORDER BY e.B1_PARCEL_NBR, a.B1_ALT_ID, CAST(d.b1_checklist_comment AS date)</CommandText>
      </Query>
      <Fields>
        <Field Name="PARCEL_NUMBER">
          <DataField>PARCEL_NUMBER</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BALANCE">
          <DataField>BALANCE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATE_LIEN_FILED">
          <DataField>DATE_LIEN_FILED</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="YEAR">
          <DataField>YEAR</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ALTERNATE_ID">
          <DataField>ALTERNATE_ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_ID1">
          <DataField>B1_PER_ID1</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_ID2">
          <DataField>B1_PER_ID2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_PER_ID3">
          <DataField>B1_PER_ID3</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
