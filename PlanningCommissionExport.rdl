<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="ACCELA">
      <DataSourceReference>Accela</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>ccfbd176-d70f-43cc-a75c-508e84edcc90</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="PlanningCommission_Permit_DataSet">
      <Query>
        <DataSourceName>ACCELA</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--DECLARE @ToDate date;
--DECLARE @FromDate date;

--set @FromDate = '10/01/2022';
--SET @ToDate = '07/31/2024';
-- Divided into two queries in order to improve performance
-- First query only returns results that have parents, and returns its parents recursively, it must have an inner join on the cte_connect_by clause, otherwise performance will cause a timeout
-- After the UNION, Second query returns all results with no recursion
with cte_connect_by as (
			select 0 as level, s.* 
			from xapp2ref s
			inner join  B1PERMIT PR 
				ON  PR.SERV_PROV_CODE=s.SERV_PROV_CODE
				AND PR.B1_PER_ID1=s.B1_PER_ID1
				AND PR.B1_PER_ID2=s.B1_PER_ID2
				AND PR.B1_PER_ID3=s.B1_PER_ID3
			left outer join bpermit_detail bdd 
				ON  PR.SERV_PROV_CODE=BDD.SERV_PROV_CODE
				AND PR.B1_PER_ID1=BDD.B1_PER_ID1
				AND PR.B1_PER_ID2=BDD.B1_PER_ID2
				AND PR.B1_PER_ID3=BDD.B1_PER_ID3
			left outer join (
				select
				  SERV_PROV_CODE,
				  B1_PER_ID1,
				  B1_PER_ID2,
				  B1_PER_ID3,
				  AUDIT_MOD_DATE
				  FROM BVALUATN
				  where SERV_PROV_CODE = 'KNOXVILLE'
				)  VALD
				ON  PR.SERV_PROV_CODE = VALD.SERV_PROV_CODE
				AND PR.B1_PER_ID1 = VALD.B1_PER_ID1
				AND PR.B1_PER_ID2 = VALD.B1_PER_ID2
				AND PR.B1_PER_ID3 = VALD.B1_PER_ID3
			left outer join BCHCKBOX as bcb
			ON PR.SERV_PROV_CODE=bcb.SERV_PROV_CODE
				AND PR.B1_PER_ID1=bcb.B1_PER_ID1
				AND PR.B1_PER_ID2=bcb.B1_PER_ID2
				AND PR.B1_PER_ID3=bcb.B1_PER_ID3
				AND bcb.b1_checkbox_desc = '[Estimated Cost (Job Value)]'
			where  PR.SERV_PROV_CODE = 'KNOXVILLE'
			AND PR.B1_PER_GROUP = 'Building'
			and ( 
				(  @ToDate is not null and @FromDate is not null and 
					( (PR.B1_FILE_DD is not null and PR.B1_FILE_DD between @FromDate and @ToDate) or
						(PR.rec_date is not null and PR.rec_date between @FromDate and @ToDate) or 
						(PR.b1_appl_status_date  is not null and PR.b1_appl_status_date between @FromDate and @ToDate) or
								(bdd.rec_date is not null and Cast(bdd.rec_date as Date) between @FromDate and @ToDate) or 
								(bdd.b1_complete_date is not null and Cast(bdd.b1_complete_date as Date) between @FromDate and @ToDate) or
								(bdd.disposition_date is not null and Cast(bdd.disposition_date  as Date) between @FromDate and @ToDate) or
								(VALD.AUDIT_MOD_DATE is not null and Cast(VALD.AUDIT_MOD_DATE as Date) between @FromDate and @ToDate) or
						(bcb.AUDIT_MOD_DATE is not null and Cast(bcb.AUDIT_MOD_DATE as Date) between @FromDate and @ToDate)
					)
				)
		
				and PR.B1_APPL_STATUS not in (
					'Plan Review', 
					'Revisions Required', 
					'Ready to Issue', 
					'Additional Info Required', 
					'In Review',
					'Waiting on Customer',
					'Pending CO',
					'Pending',
					'HOLD'
					)
				and PR.B1_APP_TYPE_ALIAS in (
					'Building Permit Commercial',
					'Building Permit Residential',
					'Electrical Permit Commercial',
					'Electrical Permit Residential',
					'Gas Permit Commercial',
					'Gas Permit Residential',
					'IBC Addition Permit',
					'IBC Alteration Permit',
					'IBC Compliance Certification',
					'IBC Demolition Permit',
					'IBC Electrical Permit',
					'IBC Mechanical Permit',
					'IBC New Construction Permit',
					'IBC Plumbing Permit',
					'IRC Addition Permit',
					'IRC Alteration Permit',
					'IRC Compliance Certification',
					'IRC Demolition Permit',
					'IRC Electrical Permit',
					'IRC Mechanical Permit',
					'IRC New Construction Permit',
					'IRC Plumbing Permit',
					'Mechanical Permit Commercial',
					'Mechanical Permit Residential',
					'Plans Review Commercial',
					'Plans Review Residential',
					'Plumbing Permit Commercial',
					'Plumbing Permit Residential',
					'Sign Permit Sign')
						and pR.b1_per_id2 &lt;&gt; 'CONV'
						)
			union all
			select level + 1 as level, s.* 
			from cte_connect_by r 
			inner join xapp2ref s    
			ON  r.MASTER_SERV_PROV_CODE = s.SERV_PROV_CODE
			AND r.B1_MASTER_ID1 = s.B1_PER_ID1
			AND r.B1_MASTER_ID2 = s.B1_PER_ID2 
			AND r.B1_MASTER_ID3 = s.B1_PER_ID3
			and  r.B1_RELATIONSHIP &lt;&gt; 'EST'
			)
select 
P.B1_ALT_ID                      AS PERMIT,
P.B1_APP_TYPE_ALIAS              AS RECORD_TYPE,
P.B1_APPL_STATUS                 AS RECORD_STATUS,
P.B1_FILE_DD                     AS DATE_OPENED,
P.B1_PER_GROUP + ',' + P.B1_PER_TYPE + ',' + P.B1_PER_SUB_TYPE + ',' + P.B1_PER_CATEGORY AS DESCR_RECORD_TYPE,
BA.B1_HSE_NBR_START              AS STREET_NBR,
BA.B1_STR_DIR                   AS STREET_DIRECTION,
BA.B1_STR_NAME                  AS STREET_NAME,
BA.B1_STR_SUFFIX          AS STREET_TYPE,
BA.B1_UNIT_START          AS UNIT_NBR,
BA.B1_UNIT_TYPE           AS UNIT_TYPE,
BP.B1_PARCEL_NBR          AS PARCEL_NBR,
BP.B1_SUBDIVISION		  AS SUBDIVISION,
BP.B1_BLOCK				  AS "BLOCK",
BO.B1_OWNER_FULL_NAME             AS "OWNER",
BD.B1_SHORT_NOTES         AS SHORT_NOTES,
CO.B1_BUS_NAME       AS CONTRACTOR,
CO.B1_LICENSE_NBR   AS LICENSE_NBR,
P.SERV_PROV_CODE,
P.B1_PER_ID1,
P.B1_PER_ID2,
P.B1_PER_ID3,
AACF.Zoning,
AACF.Service_Area, 
AACF.General_Project_Type, 
AACF.Building_Construction_Type, 
AACF.Approved_Scope_of_Work,
AACF.Customer_Description_of_Work,
AACF.Tenant_Name,
AACF.Principal_Use, 
AACF.Portion_of_Structure_for_Cert,
AACF.Special_Stipulations,
AACF.Date_CO_Issued,
AACF.Date_Fire_CO_Issued,
AACF.Use_and_Occupancy_Existing,
AACF.Use_and_Occupancy_Proposed,
AACF.Permit_for_Occupancy,
AACF.Customer_Title,
AACF.Permit_Issued_Date,
AACF.Permit_Expiration_Date,
AACF.Proposed_Use_of_New_Shell,
AACF.Current_tenant_name,
AACF.New_tenant_name,
AACF.Previous_tenant_name, 
AACF.Principal_Zoning_Use_Existing,
AACF.Principal_Zoning_Use_Proposed,
AACF.Associated_Zoning_Use,
AACF.Total_Floor_Area,
AACF.Permit_Transfer,
---- For Valuation- First use Estimated Cost if given, otherwise use Bvaluation 
CASE WHEN AACF.Estimated_Cost  IS NULL OR CAST(AACF.Estimated_Cost as float) = 0 THEN VAL.BVALUATION  ELSE AACF.Estimated_Cost END as VALUATION,
PX.B1_ALT_ID                   AS PARENT_PERMIT
FROM
  B1PERMIT P
  -- B3 Address Grouping (BAG)
  -- choose address by finding the minimum address based on:
  -- Str Number + Direction + Name + Suffix + Unit # + Unit Type
  -- using default lexicographic sort order
  left outer join (
    select
        SERV_PROV_CODE,
        B1_PER_ID1,
        B1_PER_ID2,
        B1_PER_ID3,
        min(CONCAT(CAST(B1_HSE_NBR_START AS varchar), B1_STR_DIR, B1_STR_NAME, B1_STR_SUFFIX,B1_UNIT_START,B1_UNIT_TYPE )) as full_address
        from B3ADDRES
		where SERV_PROV_CODE = 'KNOXVILLE' and
		B1_PRIMARY_ADDR_FLG = 'Y'
        group by SERV_PROV_CODE,
        B1_PER_ID1,
        B1_PER_ID2,
        B1_PER_ID3
    )  BAG
    ON  P.SERV_PROV_CODE=BAG.SERV_PROV_CODE
    AND P.B1_PER_ID1=BAG.B1_PER_ID1
    AND P.B1_PER_ID2=BAG.B1_PER_ID2
    AND P.B1_PER_ID3=BAG.B1_PER_ID3
	-- A Permit with Multiple Addresses is reduced to one address based on the lowest numbered address.
    inner join B3ADDRES BA
    ON  BAG.SERV_PROV_CODE=BA.SERV_PROV_CODE
    AND BAG.B1_PER_ID1=BA.B1_PER_ID1
    AND BAG.B1_PER_ID2=BA.B1_PER_ID2
    AND BAG.B1_PER_ID3=BA.B1_PER_ID3
	and BAG.full_address = CONCAT(CAST(BA.B1_HSE_NBR_START AS varchar), BA.B1_STR_DIR, BA.B1_STR_NAME, BA.B1_STR_SUFFIX,BA.B1_UNIT_START,BA.B1_UNIT_TYPE )
-- B1 Parcel Grouping (BPG)
-- choose the parcel by finding the minimum parcel number based on:
-- Parcel Number + Subdivision + Block
-- using  default lexicographic sort order
left outer join (
  select SERV_PROV_CODE
    ,B1_PER_ID1
    ,B1_PER_ID2
    ,B1_PER_ID3
    , min (CONCAT(B1_PARCEL_NBR, B1_SUBDIVISION, B1_BLOCK))	as Parcel_Sub_Block
    from  B3PARCEL
	where SERV_PROV_CODE = 'KNOXVILLE'
	AND B1_PRIMARY_PAR_FLG = 'Y'
        group by SERV_PROV_CODE,
        B1_PER_ID1,
        B1_PER_ID2,
        B1_PER_ID3) BPG
    ON  P.SERV_PROV_CODE=BPG.SERV_PROV_CODE
    AND P.B1_PER_ID1=BPG.B1_PER_ID1
    AND P.B1_PER_ID2=BPG.B1_PER_ID2
    AND P.B1_PER_ID3=BPG.B1_PER_ID3
  --A Permit with Multiple Parcels is reduced to one parcel based on the lowest Parcel Number,Subdivision and Block.
  inner join B3PARCEL BP
    ON  BPG.SERV_PROV_CODE=BP.SERV_PROV_CODE
    AND BPG.B1_PER_ID1=BP.B1_PER_ID1
    AND BPG.B1_PER_ID2=BP.B1_PER_ID2
    AND BPG.B1_PER_ID3=BP.B1_PER_ID3
	and BPG.Parcel_Sub_Block =  CONCAT(BP.B1_PARCEL_NBR, BP.B1_SUBDIVISION, BP.B1_BLOCK)
--  Valuation
--  based on the value of G3_FEE_FACTOR_FLG, if CONT then return the g3 value TTL (?)
--  otherwise return the G3 Calculated Value
left outer join (
	select
	  SERV_PROV_CODE,
	  B1_PER_ID1,
	  B1_PER_ID2,
	  B1_PER_ID3,
	  CASE COALESCE(G3_FEE_FACTOR_FLG,'CONT') WHEN 'CONT' THEN G3_VALUE_TTL  ELSE G3_CALC_VALUE END   BVALUATION,
	  AUDIT_MOD_DATE
	  FROM BVALUATN
	  where SERV_PROV_CODE = 'KNOXVILLE'
)  VAL
    ON  P.SERV_PROV_CODE = VAL.SERV_PROV_CODE
    AND P.B1_PER_ID1 = VAL.B1_PER_ID1
    AND P.B1_PER_ID2 = VAL.B1_PER_ID2
    AND P.B1_PER_ID3 = VAL.B1_PER_ID3
-- B3 Owners Grouping (BOG)
-- choose the owner by finding the maximum owners full name based on default lexicographic sort order

left outer join (
  select SERV_PROV_CODE
    ,B1_PER_ID1
    ,B1_PER_ID2
    ,B1_PER_ID3
    ,max(B1_OWNER_FULL_NAME) as max_owner_name
   from B3OWNERS
   where SERV_PROV_CODE = 'KNOXVILLE'
   and B1_PRIMARY_OWNER = 'Y'
   group by
   SERV_PROV_CODE
    ,B1_PER_ID1
    ,B1_PER_ID2
    ,B1_PER_ID3
   
  ) bog on
    P.SERV_PROV_CODE = BOG.SERV_PROV_CODE
    AND P.B1_PER_ID1 = BOG.B1_PER_ID1
    AND P.B1_PER_ID2 = BOG.B1_PER_ID2
    AND P.B1_PER_ID3 = BOG.B1_PER_ID3
	--A Permit with Mulitple Owner names is reduced to one name based on the full owner name ordered A-Z (A being the lowest)
  left outer join  B3OWNERS BO
    ON  BO.SERV_PROV_CODE = BOG.SERV_PROV_CODE
    AND BO.B1_PER_ID1 = BOG.B1_PER_ID1
    AND BO.B1_PER_ID2 = BOG.B1_PER_ID2
    AND BO.B1_PER_ID3 = BOG.B1_PER_ID3
	and BO.B1_OWNER_FULL_NAME = bog.max_owner_name
-- B3 Contractor Grouping (COG)
-- choose the contractor by finding the maximum license number 
-- based on  default lexicographic sort order
  inner join (
  select SERV_PROV_CODE
    ,B1_PER_ID1
    ,B1_PER_ID2
    ,B1_PER_ID3
    , MAX(LIC_SEQ_NBR) AS MAX_LIC_SEQ_NBR
    from  B3CONTRA
	where SERV_PROV_CODE = 'KNOXVILLE'
        group by SERV_PROV_CODE,
        B1_PER_ID1,
        B1_PER_ID2,
        B1_PER_ID3) COG
    ON  P.SERV_PROV_CODE=COG.SERV_PROV_CODE
    AND P.B1_PER_ID1=COG.B1_PER_ID1
    AND P.B1_PER_ID2=COG.B1_PER_ID2
    AND P.B1_PER_ID3=COG.B1_PER_ID3
	--A Permit with Multiple Contractors is reduced to one contractor based on the order of the contractor id
  LEFT OUTER JOIN B3CONTRA CO
    ON  CO.SERV_PROV_CODE=COG.SERV_PROV_CODE
    AND CO.B1_PER_ID1=COG.B1_PER_ID1
    AND CO.B1_PER_ID2=COG.B1_PER_ID2
    AND CO.B1_PER_ID3=COG.B1_PER_ID3
	AND CO.LIC_SEQ_NBR=COG.MAX_LIC_SEQ_NBR
  left outer join bpermit_detail bd 
    ON  P.SERV_PROV_CODE=BD.SERV_PROV_CODE
    AND P.B1_PER_ID1=BD.B1_PER_ID1
    AND P.B1_PER_ID2=BD.B1_PER_ID2
    AND P.B1_PER_ID3=BD.B1_PER_ID3
-- get the Work Description if there is one
  LEFT JOIN BWORKDES BW
    ON  P.SERV_PROV_CODE = BW.SERV_PROV_CODE
    AND P.B1_PER_ID1 = BW.B1_PER_ID1
    AND P.B1_PER_ID2 = BW.B1_PER_ID2
    AND P.B1_PER_ID3 = BW.B1_PER_ID3
-- the query results are joined to the parent permit of the current permit to get the parent permit id, and ancestors
INNER JOIN cte_connect_by cte 
ON P.SERV_PROV_CODE = cte.SERV_PROV_CODE
and P.B1_PER_ID1 = cte.B1_PER_ID1
and p.B1_PER_ID2 = cte.B1_PER_ID2
and p.B1_PER_ID3 = cte.B1_PER_ID3
and cte.B1_RELATIONSHIP &lt;&gt; 'EST'
left outer join b1permit PX -- subquery for your parent id
ON  PX.SERV_PROV_CODE = cte.MASTER_SERV_PROV_CODE
AND PX.B1_PER_ID1 = cte.B1_MASTER_ID1 
AND PX.B1_PER_ID2 = cte.B1_MASTER_ID2 
AND PX.B1_PER_ID3 = cte.B1_MASTER_ID3
-- the below is a cross join query to return the keys and values of a table as columns and rows of the current query results
LEFT JOIN (select
AACF.SERV_PROV_CODE,
AACF.B1_PER_ID1,
AACF.B1_PER_ID2,  
AACF.B1_PER_ID3,
AACF.Zoning as Zoning,
AACF.[Service Area] as Service_Area,
AACF.[General Project Type] as General_Project_Type,
AACF.[Building Construction Type] as Building_Construction_Type,
AACF.[Approved Scope of Work] as Approved_Scope_of_Work,
AACF.[Customer Description of Work] as Customer_Description_of_Work,
AACF.[Tenant Name] as Tenant_Name,
AACF.[Principal Use] as Principal_Use,
AACF.[Portion of Structure for Certificate] as Portion_of_Structure_for_Cert,
AACF.[Special Stipulations] as Special_Stipulations,
AACF.[Date CO Issued] as Date_CO_Issued,
AACF.[Date Fire CO Issued] as Date_Fire_CO_Issued,
AACF.[Use and Occupancy Existing] as Use_and_Occupancy_Existing,
AACF.[Use and Occupancy Proposed] as Use_and_Occupancy_Proposed,
AACF.[Permit for Occupancy] as Permit_for_Occupancy,
AACF.[Customer Title] as Customer_Title,
AACF.[Permit Issued Date] as Permit_Issued_Date,
AACF.[Permit Expiration Date] as Permit_Expiration_Date,
AACF.[Proposed Use of New Shell] as Proposed_Use_of_New_Shell,
AACF.[Current tenant name] as Current_tenant_name,
AACF.[New tenant name] as New_tenant_name, 
AACF.[Previous tenant name] as Previous_tenant_name,
AACF.[Principal Zoning Use Existing] as Principal_Zoning_Use_Existing,
AACF.[Principal Zoning Use Proposed] as Principal_Zoning_Use_Proposed,
AACF.[Associated Zoning Use] as Associated_Zoning_Use,
AACF.[Total Floor Area] as Total_Floor_Area,
AACF.[Estimated Cost (Job Value)] as Estimated_Cost,
AACF.[Permit Transfer] as Permit_Transfer
from (
	SELECT bcb.b1_checkbox_desc, bcb.b1_checklist_comment, 
	PR.SERV_PROV_CODE SERV_PROV_CODE , PR.B1_PER_ID1 B1_PER_ID1,PR.B1_PER_ID2 B1_PER_ID2,  PR.B1_PER_ID3 B1_PER_ID3
	FROM BCHCKBOX  bcb
	inner join  B1PERMIT PR 
		ON  PR.SERV_PROV_CODE=bcb.SERV_PROV_CODE
		AND PR.B1_PER_ID1=bcb.B1_PER_ID1
		AND PR.B1_PER_ID2=bcb.B1_PER_ID2
		AND PR.B1_PER_ID3=bcb.B1_PER_ID3
	  left outer join bpermit_detail bdd 
    ON  PR.SERV_PROV_CODE=BDD.SERV_PROV_CODE
    AND PR.B1_PER_ID1=BDD.B1_PER_ID1
    AND PR.B1_PER_ID2=BDD.B1_PER_ID2
    AND PR.B1_PER_ID3=BDD.B1_PER_ID3
left outer join (
	select
	  SERV_PROV_CODE,
	  B1_PER_ID1,
	  B1_PER_ID2,
	  B1_PER_ID3,
	  AUDIT_MOD_DATE
	  FROM BVALUATN
	  where SERV_PROV_CODE = 'KNOXVILLE'
	)  VALD
    ON  PR.SERV_PROV_CODE = VALD.SERV_PROV_CODE
    AND PR.B1_PER_ID1 = VALD.B1_PER_ID1
    AND PR.B1_PER_ID2 = VALD.B1_PER_ID2
    AND PR.B1_PER_ID3 = VALD.B1_PER_ID3

		where  PR.SERV_PROV_CODE = 'KNOXVILLE'
		AND PR.B1_PER_GROUP = 'Building'
		and ( 
    (  @ToDate is not null and @FromDate is not null and 
        ( (PR.B1_FILE_DD is not null and PR.B1_FILE_DD between @FromDate and @ToDate) or
          (PR.rec_date is not null and PR.rec_date between @FromDate and @ToDate) or 
          (PR.b1_appl_status_date  is not null and PR.b1_appl_status_date between @FromDate and @ToDate) or
					(bdd.rec_date is not null and Cast(bdd.rec_date as Date) between @FromDate and @ToDate) or 
					(bdd.b1_complete_date is not null and Cast(bdd.b1_complete_date as Date) between @FromDate and @ToDate) or
					(bdd.disposition_date is not null and Cast(bdd.disposition_date  as Date) between @FromDate and @ToDate) or
					(VALD.AUDIT_MOD_DATE is not null and Cast(VALD.AUDIT_MOD_DATE as Date) between @FromDate and @ToDate) or
		  (bcb.AUDIT_MOD_DATE is not null and Cast(bcb.AUDIT_MOD_DATE as Date) between @FromDate and @ToDate)
        )
    )
)
) BCBOX
pivot (
MAX(b1_checklist_comment) 				 
	for b1_checkbox_desc in 
		(
		[Zoning],
		[Service Area], 
		[General Project Type], 
		[Building Construction Type], 
		[Approved Scope of Work],
		[Customer Description of Work],
		[Tenant Name],
		[Principal Use], 
		[Portion of Structure for Certificate],
		[Special Stipulations],
		[Date CO Issued],
		[Date Fire CO Issued],
		[Use and Occupancy Existing],
		[Use and Occupancy Proposed],
		[Permit for Occupancy],
		[Customer Title],
		[Permit Issued Date],
		[Permit Expiration Date],
		[Proposed Use of New Shell],
		[Current tenant name],
		[New tenant name],
		[Previous tenant name], 
		[Principal Zoning Use Existing],
		[Principal Zoning Use Proposed],
		[Associated Zoning Use],
		[Total Floor Area],
		[Estimated Cost (Job Value)],
		[Permit Transfer]
		)) AACF) AACF ON P.SERV_PROV_CODE=AACF.SERV_PROV_CODE
    AND P.B1_PER_ID1=AACF.B1_PER_ID1
    AND P.B1_PER_ID2=AACF.B1_PER_ID2
    AND P.B1_PER_ID3=AACF.B1_PER_ID3
left outer join BCHCKBOX as JOB_VALUE_MOD
ON P.SERV_PROV_CODE=JOB_VALUE_MOD.SERV_PROV_CODE
    AND P.B1_PER_ID1=JOB_VALUE_MOD.B1_PER_ID1
    AND P.B1_PER_ID2=JOB_VALUE_MOD.B1_PER_ID2
    AND P.B1_PER_ID3=JOB_VALUE_MOD.B1_PER_ID3
	AND JOB_VALUE_MOD.b1_checkbox_desc = '[Estimated Cost (Job Value)]'
WHERE
	P.SERV_PROV_CODE = 'KNOXVILLE'
	AND P.B1_PER_GROUP = 'Building'
	-- Ignore date logic if a parent
	AND 
	( cte.level &gt; 0 or 
		( 
			(@ToDate is not null and @FromDate is not null and 
				( (P.B1_FILE_DD is not null and Cast(P.B1_FILE_DD as Date) between @FromDate and @ToDate) or
					(P.rec_date is not null and Cast(P.rec_date as Date) between @FromDate and @ToDate) or 
					(P.b1_appl_status_date  is not null and Cast(P.b1_appl_status_date as Date) between @FromDate and @ToDate) or 
					(bd.rec_date is not null and Cast(bd.rec_date as Date) between @FromDate and @ToDate) or 
					(bd.b1_complete_date is not null and Cast(bd.b1_complete_date as Date) between @FromDate and @ToDate) or
					(bd.disposition_date is not null and Cast(bd.disposition_date  as Date) between @FromDate and @ToDate) or
					(VAL.AUDIT_MOD_DATE is not null and Cast(VAL.AUDIT_MOD_DATE as Date) between @FromDate and @ToDate) or
					(JOB_VALUE_MOD.AUDIT_MOD_DATE is not null and Cast(JOB_VALUE_MOD.AUDIT_MOD_DATE as Date) between @FromDate and @ToDate)
				)
			)
		)
	)
and P.B1_APPL_STATUS not in (
'Plan Review', 
'Revisions Required', 
'Ready to Issue', 
'Additional Info Required', 
'In Review',
'Waiting on Customer',
'Pending CO',
'Pending',
'HOLD'
)
and P.B1_APP_TYPE_ALIAS in (
'Building Permit Commercial',
'Building Permit Residential',
'Electrical Permit Commercial',
'Electrical Permit Residential',
'Gas Permit Commercial',
'Gas Permit Residential',
'IBC Addition Permit',
'IBC Alteration Permit',
'IBC Compliance Certification',
'IBC Demolition Permit',
'IBC Electrical Permit',
'IBC Mechanical Permit',
'IBC New Construction Permit',
'IBC Plumbing Permit',
'IRC Addition Permit',
'IRC Alteration Permit',
'IRC Compliance Certification',
'IRC Demolition Permit',
'IRC Electrical Permit',
'IRC Mechanical Permit',
'IRC New Construction Permit',
'IRC Plumbing Permit',
'Mechanical Permit Commercial',
'Mechanical Permit Residential',
'Plans Review Commercial',
'Plans Review Residential',
'Plumbing Permit Commercial',
'Plumbing Permit Residential',
'Sign Permit Sign')
 and p.b1_per_id2 &lt;&gt; 'CONV'
GROUP BY cte.level,
P.B1_ALT_ID,
P.B1_APP_TYPE_ALIAS,
P.B1_APPL_STATUS,
P.B1_FILE_DD,
P.B1_PER_GROUP + ',' + P.B1_PER_TYPE + ',' + P.B1_PER_SUB_TYPE + ',' + P.B1_PER_CATEGORY,
BA.B1_HSE_NBR_START ,
BA.B1_STR_DIR ,
BA.B1_STR_NAME ,
BA.B1_STR_SUFFIX ,
BA.B1_UNIT_START,
BA.B1_UNIT_TYPE,
BP.B1_PARCEL_NBR ,
BP.B1_SUBDIVISION,
BP.B1_BLOCK,
BO.B1_OWNER_FULL_NAME ,
BD.B1_SHORT_NOTES,
CO.B1_BUS_NAME,
CO.B1_LICENSE_NBR,
P.SERV_PROV_CODE,
P.B1_PER_ID1,
P.B1_PER_ID2,
P.B1_PER_ID3,
AACF.Zoning,
AACF.Service_Area, 
AACF.General_Project_Type, 
AACF.Building_Construction_Type, 
AACF.Approved_Scope_of_Work,
AACF.Customer_Description_of_Work,
AACF.Tenant_Name,
AACF.Principal_Use, 
AACF.Portion_of_Structure_for_Cert,
AACF.Special_Stipulations,
AACF.Date_CO_Issued,
AACF.Date_Fire_CO_Issued,
AACF.Use_and_Occupancy_Existing,
AACF.Use_and_Occupancy_Proposed,
AACF.Permit_for_Occupancy,
AACF.Customer_Title,
AACF.Permit_Issued_Date,
AACF.Permit_Expiration_Date,
AACF.Proposed_Use_of_New_Shell,
AACF.Current_tenant_name,
AACF.New_tenant_name,
AACF.Previous_tenant_name, 
AACF.Principal_Zoning_Use_Existing,
AACF.Principal_Zoning_Use_Proposed,
AACF.Associated_Zoning_Use,
AACF.Total_Floor_Area,
AACF.Permit_Transfer,
---- For Valuation- First use Estimated Cost if given, otherwise use Bvaluation 
CASE WHEN AACF.Estimated_Cost  IS NULL OR CAST(AACF.Estimated_Cost as float) = 0 THEN VAL.BVALUATION  ELSE AACF.Estimated_Cost END,
PX.B1_ALT_ID
-- Here starts the second query
UNION
select 
P.B1_ALT_ID                      AS PERMIT,
P.B1_APP_TYPE_ALIAS              AS RECORD_TYPE,
P.B1_APPL_STATUS                 AS RECORD_STATUS,
P.B1_FILE_DD                     AS DATE_OPENED,
P.B1_PER_GROUP + ',' + P.B1_PER_TYPE + ',' + P.B1_PER_SUB_TYPE + ',' + P.B1_PER_CATEGORY AS DESCR_RECORD_TYPE,
BA.B1_HSE_NBR_START              AS STREET_NBR,
BA.B1_STR_DIR                   AS STREET_DIRECTION,
BA.B1_STR_NAME                  AS STREET_NAME,
BA.B1_STR_SUFFIX          AS STREET_TYPE,
BA.B1_UNIT_START          AS UNIT_NBR,
BA.B1_UNIT_TYPE           AS UNIT_TYPE,
BP.B1_PARCEL_NBR          AS PARCEL_NBR,
BP.B1_SUBDIVISION		  AS SUBDIVISION,
BP.B1_BLOCK				  AS "BLOCK",
BO.B1_OWNER_FULL_NAME             AS "OWNER",
BD.B1_SHORT_NOTES         AS SHORT_NOTES,
CO.B1_BUS_NAME       AS CONTRACTOR,
CO.B1_LICENSE_NBR   AS LICENSE_NBR,
P.SERV_PROV_CODE,
P.B1_PER_ID1,
P.B1_PER_ID2,
P.B1_PER_ID3,
AACF.Zoning,
AACF.Service_Area, 
AACF.General_Project_Type, 
AACF.Building_Construction_Type, 
AACF.Approved_Scope_of_Work,
AACF.Customer_Description_of_Work,
AACF.Tenant_Name,
AACF.Principal_Use, 
AACF.Portion_of_Structure_for_Cert,
AACF.Special_Stipulations,
AACF.Date_CO_Issued,
AACF.Date_Fire_CO_Issued,
AACF.Use_and_Occupancy_Existing,
AACF.Use_and_Occupancy_Proposed,
AACF.Permit_for_Occupancy,
AACF.Customer_Title,
AACF.Permit_Issued_Date,
AACF.Permit_Expiration_Date,
AACF.Proposed_Use_of_New_Shell,
AACF.Current_tenant_name,
AACF.New_tenant_name,
AACF.Previous_tenant_name, 
AACF.Principal_Zoning_Use_Existing,
AACF.Principal_Zoning_Use_Proposed,
AACF.Associated_Zoning_Use,
AACF.Total_Floor_Area,
AACF.Permit_Transfer,
---- For Valuation- First use Estimated Cost if given, otherwise use Bvaluation 
CASE WHEN AACF.Estimated_Cost  IS NULL OR CAST(AACF.Estimated_Cost as float) = 0 THEN VAL.BVALUATION  ELSE AACF.Estimated_Cost END as VALUATION,
NULL                   AS PARENT_PERMIT
FROM
  B1PERMIT P
  -- B3 Address Grouping (BAG)
  -- choose address by finding the minimum address based on:
  -- Str Number + Direction + Name + Suffix + Unit # + Unit Type
  -- using default lexicographic sort order
  left outer join (
    select
        SERV_PROV_CODE,
        B1_PER_ID1,
        B1_PER_ID2,
        B1_PER_ID3,
        min(CONCAT(CAST(B1_HSE_NBR_START AS varchar), B1_STR_DIR, B1_STR_NAME, B1_STR_SUFFIX,B1_UNIT_START,B1_UNIT_TYPE )) as full_address
        from B3ADDRES
		where SERV_PROV_CODE = 'KNOXVILLE' and
		B1_PRIMARY_ADDR_FLG = 'Y'
        group by SERV_PROV_CODE,
        B1_PER_ID1,
        B1_PER_ID2,
        B1_PER_ID3
    )  BAG
    ON  P.SERV_PROV_CODE=BAG.SERV_PROV_CODE
    AND P.B1_PER_ID1=BAG.B1_PER_ID1
    AND P.B1_PER_ID2=BAG.B1_PER_ID2
    AND P.B1_PER_ID3=BAG.B1_PER_ID3
	-- A Permit with Multiple Addresses is reduced to one address based on the lowest numbered address.
    inner join B3ADDRES BA
    ON  BAG.SERV_PROV_CODE=BA.SERV_PROV_CODE
    AND BAG.B1_PER_ID1=BA.B1_PER_ID1
    AND BAG.B1_PER_ID2=BA.B1_PER_ID2
    AND BAG.B1_PER_ID3=BA.B1_PER_ID3
	and BAG.full_address = CONCAT(CAST(BA.B1_HSE_NBR_START AS varchar), BA.B1_STR_DIR, BA.B1_STR_NAME, BA.B1_STR_SUFFIX,BA.B1_UNIT_START,BA.B1_UNIT_TYPE )
-- B1 Parcel Grouping (BPG)
-- choose the parcel by finding the minimum parcel number based on:
-- Parcel Number + Subdivision + Block
-- using  default lexicographic sort order
left outer join (
  select SERV_PROV_CODE
    ,B1_PER_ID1
    ,B1_PER_ID2
    ,B1_PER_ID3
    , min (CONCAT(B1_PARCEL_NBR, B1_SUBDIVISION, B1_BLOCK))	as Parcel_Sub_Block
    from  B3PARCEL
	where SERV_PROV_CODE = 'KNOXVILLE'
	AND B1_PRIMARY_PAR_FLG = 'Y'
        group by SERV_PROV_CODE,
        B1_PER_ID1,
        B1_PER_ID2,
        B1_PER_ID3) BPG
    ON  P.SERV_PROV_CODE=BPG.SERV_PROV_CODE
    AND P.B1_PER_ID1=BPG.B1_PER_ID1
    AND P.B1_PER_ID2=BPG.B1_PER_ID2
    AND P.B1_PER_ID3=BPG.B1_PER_ID3
  --A Permit with Multiple Parcels is reduced to one parcel based on the lowest Parcel Number,Subdivision and Block.
  inner join B3PARCEL BP
    ON  BPG.SERV_PROV_CODE=BP.SERV_PROV_CODE
    AND BPG.B1_PER_ID1=BP.B1_PER_ID1
    AND BPG.B1_PER_ID2=BP.B1_PER_ID2
    AND BPG.B1_PER_ID3=BP.B1_PER_ID3
	and BPG.Parcel_Sub_Block =  CONCAT(BP.B1_PARCEL_NBR, BP.B1_SUBDIVISION, BP.B1_BLOCK)
--  Valuation
--  based on the value of G3_FEE_FACTOR_FLG, if CONT then return the g3 value TTL (?)
--  otherwise return the G3 Calculated Value
left outer join (
	select
	  SERV_PROV_CODE,
	  B1_PER_ID1,
	  B1_PER_ID2,
	  B1_PER_ID3,
	  CASE COALESCE(G3_FEE_FACTOR_FLG,'CONT') WHEN 'CONT' THEN G3_VALUE_TTL  ELSE G3_CALC_VALUE END   BVALUATION,
	  AUDIT_MOD_DATE
	  FROM BVALUATN
	  where SERV_PROV_CODE = 'KNOXVILLE'
)  VAL
    ON  P.SERV_PROV_CODE = VAL.SERV_PROV_CODE
    AND P.B1_PER_ID1 = VAL.B1_PER_ID1
    AND P.B1_PER_ID2 = VAL.B1_PER_ID2
    AND P.B1_PER_ID3 = VAL.B1_PER_ID3
-- B3 Owners Grouping (BOG)
-- choose the owner by finding the maximum owners full name based on default lexicographic sort order

left outer join (
  select SERV_PROV_CODE
    ,B1_PER_ID1
    ,B1_PER_ID2
    ,B1_PER_ID3
    ,max(B1_OWNER_FULL_NAME) as max_owner_name
   from B3OWNERS
   where SERV_PROV_CODE = 'KNOXVILLE'
   and B1_PRIMARY_OWNER = 'Y'
   group by
   SERV_PROV_CODE
    ,B1_PER_ID1
    ,B1_PER_ID2
    ,B1_PER_ID3
   
  ) bog on
    P.SERV_PROV_CODE = BOG.SERV_PROV_CODE
    AND P.B1_PER_ID1 = BOG.B1_PER_ID1
    AND P.B1_PER_ID2 = BOG.B1_PER_ID2
    AND P.B1_PER_ID3 = BOG.B1_PER_ID3
	--A Permit with Mulitple Owner names is reduced to one name based on the full owner name ordered A-Z (A being the lowest)
  left outer join  B3OWNERS BO
    ON  BO.SERV_PROV_CODE = BOG.SERV_PROV_CODE
    AND BO.B1_PER_ID1 = BOG.B1_PER_ID1
    AND BO.B1_PER_ID2 = BOG.B1_PER_ID2
    AND BO.B1_PER_ID3 = BOG.B1_PER_ID3
	and BO.B1_OWNER_FULL_NAME = bog.max_owner_name
-- B3 Contractor Grouping (COG)
-- choose the contractor by finding the maximum license number 
-- based on  default lexicographic sort order
  inner join (
  select SERV_PROV_CODE
    ,B1_PER_ID1
    ,B1_PER_ID2
    ,B1_PER_ID3
    , MAX(LIC_SEQ_NBR) AS MAX_LIC_SEQ_NBR
    from  B3CONTRA
	where SERV_PROV_CODE = 'KNOXVILLE'
        group by SERV_PROV_CODE,
        B1_PER_ID1,
        B1_PER_ID2,
        B1_PER_ID3) COG
    ON  P.SERV_PROV_CODE=COG.SERV_PROV_CODE
    AND P.B1_PER_ID1=COG.B1_PER_ID1
    AND P.B1_PER_ID2=COG.B1_PER_ID2
    AND P.B1_PER_ID3=COG.B1_PER_ID3
	--A Permit with Multiple Contractors is reduced to one contractor based on the order of the contractor id
  LEFT OUTER JOIN B3CONTRA CO
    ON  CO.SERV_PROV_CODE=COG.SERV_PROV_CODE
    AND CO.B1_PER_ID1=COG.B1_PER_ID1
    AND CO.B1_PER_ID2=COG.B1_PER_ID2
    AND CO.B1_PER_ID3=COG.B1_PER_ID3
	AND CO.LIC_SEQ_NBR=COG.MAX_LIC_SEQ_NBR
  left outer join bpermit_detail bd 
    ON  P.SERV_PROV_CODE=BD.SERV_PROV_CODE
    AND P.B1_PER_ID1=BD.B1_PER_ID1
    AND P.B1_PER_ID2=BD.B1_PER_ID2
    AND P.B1_PER_ID3=BD.B1_PER_ID3
-- get the Work Description if there is one
  LEFT JOIN BWORKDES BW
    ON  P.SERV_PROV_CODE = BW.SERV_PROV_CODE
    AND P.B1_PER_ID1 = BW.B1_PER_ID1
    AND P.B1_PER_ID2 = BW.B1_PER_ID2
    AND P.B1_PER_ID3 = BW.B1_PER_ID3
-- the query results are joined to the parent permit of the current permit to get the parent permit id, and ancestors


-- the below is a cross join query to return the keys and values of a table as columns and rows of the current query results
LEFT JOIN (select
AACF.SERV_PROV_CODE,
AACF.B1_PER_ID1,
AACF.B1_PER_ID2,  
AACF.B1_PER_ID3,
AACF.Zoning as Zoning,
AACF.[Service Area] as Service_Area,
AACF.[General Project Type] as General_Project_Type,
AACF.[Building Construction Type] as Building_Construction_Type,
AACF.[Approved Scope of Work] as Approved_Scope_of_Work,
AACF.[Customer Description of Work] as Customer_Description_of_Work,
AACF.[Tenant Name] as Tenant_Name,
AACF.[Principal Use] as Principal_Use,
AACF.[Portion of Structure for Certificate] as Portion_of_Structure_for_Cert,
AACF.[Special Stipulations] as Special_Stipulations,
AACF.[Date CO Issued] as Date_CO_Issued,
AACF.[Date Fire CO Issued] as Date_Fire_CO_Issued,
AACF.[Use and Occupancy Existing] as Use_and_Occupancy_Existing,
AACF.[Use and Occupancy Proposed] as Use_and_Occupancy_Proposed,
AACF.[Permit for Occupancy] as Permit_for_Occupancy,
AACF.[Customer Title] as Customer_Title,
AACF.[Permit Issued Date] as Permit_Issued_Date,
AACF.[Permit Expiration Date] as Permit_Expiration_Date,
AACF.[Proposed Use of New Shell] as Proposed_Use_of_New_Shell,
AACF.[Current tenant name] as Current_tenant_name,
AACF.[New tenant name] as New_tenant_name, 
AACF.[Previous tenant name] as Previous_tenant_name,
AACF.[Principal Zoning Use Existing] as Principal_Zoning_Use_Existing,
AACF.[Principal Zoning Use Proposed] as Principal_Zoning_Use_Proposed,
AACF.[Associated Zoning Use] as Associated_Zoning_Use,
AACF.[Total Floor Area] as Total_Floor_Area,
AACF.[Estimated Cost (Job Value)] as Estimated_Cost,
AACF.[Permit Transfer] as Permit_Transfer
from (
	SELECT bcb.b1_checkbox_desc, bcb.b1_checklist_comment, 
	PR.SERV_PROV_CODE SERV_PROV_CODE , PR.B1_PER_ID1 B1_PER_ID1,PR.B1_PER_ID2 B1_PER_ID2,  PR.B1_PER_ID3 B1_PER_ID3
	FROM BCHCKBOX  bcb
	inner join  B1PERMIT PR 
		ON  PR.SERV_PROV_CODE=bcb.SERV_PROV_CODE
		AND PR.B1_PER_ID1=bcb.B1_PER_ID1
		AND PR.B1_PER_ID2=bcb.B1_PER_ID2
		AND PR.B1_PER_ID3=bcb.B1_PER_ID3
	  left outer join bpermit_detail bdd 
    ON  PR.SERV_PROV_CODE=BDD.SERV_PROV_CODE
    AND PR.B1_PER_ID1=BDD.B1_PER_ID1
    AND PR.B1_PER_ID2=BDD.B1_PER_ID2
    AND PR.B1_PER_ID3=BDD.B1_PER_ID3
left outer join (
	select
	  SERV_PROV_CODE,
	  B1_PER_ID1,
	  B1_PER_ID2,
	  B1_PER_ID3,
	  AUDIT_MOD_DATE
	  FROM BVALUATN
	  where SERV_PROV_CODE = 'KNOXVILLE'
	)  VALD
    ON  PR.SERV_PROV_CODE = VALD.SERV_PROV_CODE
    AND PR.B1_PER_ID1 = VALD.B1_PER_ID1
    AND PR.B1_PER_ID2 = VALD.B1_PER_ID2
    AND PR.B1_PER_ID3 = VALD.B1_PER_ID3

		where  PR.SERV_PROV_CODE = 'KNOXVILLE'
		AND PR.B1_PER_GROUP = 'Building'
		and ( 
    (  @ToDate is not null and @FromDate is not null and 
        ( (PR.B1_FILE_DD is not null and PR.B1_FILE_DD between @FromDate and @ToDate) or
          (PR.rec_date is not null and PR.rec_date between @FromDate and @ToDate) or 
          (PR.b1_appl_status_date  is not null and PR.b1_appl_status_date between @FromDate and @ToDate) or
					(bdd.rec_date is not null and Cast(bdd.rec_date as Date) between @FromDate and @ToDate) or 
					(bdd.b1_complete_date is not null and Cast(bdd.b1_complete_date as Date) between @FromDate and @ToDate) or
					(bdd.disposition_date is not null and Cast(bdd.disposition_date  as Date) between @FromDate and @ToDate) or
					(VALD.AUDIT_MOD_DATE is not null and Cast(VALD.AUDIT_MOD_DATE as Date) between @FromDate and @ToDate) or
		  (bcb.AUDIT_MOD_DATE is not null and Cast(bcb.AUDIT_MOD_DATE as Date) between @FromDate and @ToDate)
        )
    )
)
) BCBOX
pivot (
MAX(b1_checklist_comment) 				 
	for b1_checkbox_desc in 
		(
		[Zoning],
		[Service Area], 
		[General Project Type], 
		[Building Construction Type], 
		[Approved Scope of Work],
		[Customer Description of Work],
		[Tenant Name],
		[Principal Use], 
		[Portion of Structure for Certificate],
		[Special Stipulations],
		[Date CO Issued],
		[Date Fire CO Issued],
		[Use and Occupancy Existing],
		[Use and Occupancy Proposed],
		[Permit for Occupancy],
		[Customer Title],
		[Permit Issued Date],
		[Permit Expiration Date],
		[Proposed Use of New Shell],
		[Current tenant name],
		[New tenant name],
		[Previous tenant name], 
		[Principal Zoning Use Existing],
		[Principal Zoning Use Proposed],
		[Associated Zoning Use],
		[Total Floor Area],
		[Estimated Cost (Job Value)],
		[Permit Transfer]
		)) AACF) AACF ON P.SERV_PROV_CODE=AACF.SERV_PROV_CODE
    AND P.B1_PER_ID1=AACF.B1_PER_ID1
    AND P.B1_PER_ID2=AACF.B1_PER_ID2
    AND P.B1_PER_ID3=AACF.B1_PER_ID3
left outer join BCHCKBOX as JOB_VALUE_MOD
ON P.SERV_PROV_CODE=JOB_VALUE_MOD.SERV_PROV_CODE
    AND P.B1_PER_ID1=JOB_VALUE_MOD.B1_PER_ID1
    AND P.B1_PER_ID2=JOB_VALUE_MOD.B1_PER_ID2
    AND P.B1_PER_ID3=JOB_VALUE_MOD.B1_PER_ID3
	AND JOB_VALUE_MOD.b1_checkbox_desc = '[Estimated Cost (Job Value)]'
WHERE
	P.SERV_PROV_CODE = 'KNOXVILLE'
	AND P.B1_PER_GROUP = 'Building'
	-- Ignore date logic if a parent
	AND 
	( 
		( 
			(@ToDate is not null and @FromDate is not null and 
				( (P.B1_FILE_DD is not null and Cast(P.B1_FILE_DD as Date) between @FromDate and @ToDate) or
					(P.rec_date is not null and Cast(P.rec_date as Date) between @FromDate and @ToDate) or 
					(P.b1_appl_status_date  is not null and Cast(P.b1_appl_status_date as Date) between @FromDate and @ToDate) or 
					(bd.rec_date is not null and Cast(bd.rec_date as Date) between @FromDate and @ToDate) or 
					(bd.b1_complete_date is not null and Cast(bd.b1_complete_date as Date) between @FromDate and @ToDate) or
					(bd.disposition_date is not null and Cast(bd.disposition_date  as Date) between @FromDate and @ToDate) or
					(VAL.AUDIT_MOD_DATE is not null and Cast(VAL.AUDIT_MOD_DATE as Date) between @FromDate and @ToDate) or
					(JOB_VALUE_MOD.AUDIT_MOD_DATE is not null and Cast(JOB_VALUE_MOD.AUDIT_MOD_DATE as Date) between @FromDate and @ToDate)
				)
			)
		)
	)
and P.B1_APPL_STATUS not in (
'Plan Review', 
'Revisions Required', 
'Ready to Issue', 
'Additional Info Required', 
'In Review',
'Waiting on Customer',
'Pending CO',
'Pending',
'HOLD'
)
and P.B1_APP_TYPE_ALIAS in (
'Building Permit Commercial',
'Building Permit Residential',
'Electrical Permit Commercial',
'Electrical Permit Residential',
'Gas Permit Commercial',
'Gas Permit Residential',
'IBC Addition Permit',
'IBC Alteration Permit',
'IBC Compliance Certification',
'IBC Demolition Permit',
'IBC Electrical Permit',
'IBC Mechanical Permit',
'IBC New Construction Permit',
'IBC Plumbing Permit',
'IRC Addition Permit',
'IRC Alteration Permit',
'IRC Compliance Certification',
'IRC Demolition Permit',
'IRC Electrical Permit',
'IRC Mechanical Permit',
'IRC New Construction Permit',
'IRC Plumbing Permit',
'Mechanical Permit Commercial',
'Mechanical Permit Residential',
'Plans Review Commercial',
'Plans Review Residential',
'Plumbing Permit Commercial',
'Plumbing Permit Residential',
'Sign Permit Sign')
 and p.b1_per_id2 &lt;&gt; 'CONV'
 AND NOT EXISTS
 (
 SELECT * FROM xapp2ref XAP
WHERE  p.SERV_PROV_CODE=XAP.SERV_PROV_CODE
AND p.B1_PER_ID1=XAP.B1_PER_ID1
AND p.B1_PER_ID2=XAP.B1_PER_ID2
AND p.B1_PER_ID3=XAP.B1_PER_ID3
and  XAP.B1_RELATIONSHIP &lt;&gt; 'EST')
GROUP BY 
P.B1_ALT_ID,
P.B1_APP_TYPE_ALIAS,
P.B1_APPL_STATUS,
P.B1_FILE_DD,
P.B1_PER_GROUP + ',' + P.B1_PER_TYPE + ',' + P.B1_PER_SUB_TYPE + ',' + P.B1_PER_CATEGORY,
BA.B1_HSE_NBR_START ,
BA.B1_STR_DIR ,
BA.B1_STR_NAME ,
BA.B1_STR_SUFFIX ,
BA.B1_UNIT_START,
BA.B1_UNIT_TYPE,
BP.B1_PARCEL_NBR ,
BP.B1_SUBDIVISION,
BP.B1_BLOCK,
BO.B1_OWNER_FULL_NAME ,
BD.B1_SHORT_NOTES,
CO.B1_BUS_NAME,
CO.B1_LICENSE_NBR,
P.SERV_PROV_CODE,
P.B1_PER_ID1,
P.B1_PER_ID2,
P.B1_PER_ID3,
AACF.Zoning,
AACF.Service_Area, 
AACF.General_Project_Type, 
