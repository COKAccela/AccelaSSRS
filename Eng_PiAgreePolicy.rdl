dbo.fn_get_stdchoice_valuedesc ('KNOXVILLE', 'Report_Details', 'Building_Addr1') buildingAddr1,
dbo.fn_get_stdchoice_valuedesc ('KNOXVILLE', 'Report_Details', 'Building_CSZ') buildingCSZ,
