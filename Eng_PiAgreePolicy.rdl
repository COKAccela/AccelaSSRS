    <DataSet Name="DataSet5">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@altID">
            <Value>=Parameters!altID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 'Letter of Credit' LOC, 'Surety Bond' SB, 'Cashiers Check' CCheck,
b1_alt_id
from b1permit
where serv_prov_code = 'KNOXVILLE'
and b1_alt_id = @altID</CommandText>
      </Query>
      <Fields>
        <Field Name="LOC">
          <DataField>LOC</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SB">
          <DataField>SB</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CCheck">
          <DataField>CCheck</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="b1_alt_id">
          <DataField>b1_alt_id</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet4">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select dbo.fn_get_stdchoice_valuedesc ('KNOXVILLE', 'Report_Details', 'EngDevServices_Bond_Email') bondEmail</CommandText>
      </Query>
