  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@altID">
            <Value>=Parameters!altID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 
a.b1_alt_id,
dbo.FN_GET_ADDRESS_INFO(a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3, '', '') firstAddress,
dbo.FN_GET_PARCEL_INFO(a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3, '') firstParcel,
dbo.fn_get_app_spec_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3, 'Issued Date') issuedDate,
dbo.fn_get_app_spec_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3, 'Permit Expiration Date') permitExpirationDate,
dbo.fn_get_app_spec_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3, 'Permit Number') projectNumber,
dbo.fn_get_app_spec_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3, 'Block Number') blockNumber,
dbo.fn_get_app_spec_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3, 'Engineering Scope of Work') engScope,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'Full Name', '', '') as contactFullName,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'OrgName', '', '') as contactBusName,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'ContactType', '', '') as contactType, 
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'Phone1', '', '') as contactPhone1,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'Phone2', '', '') as contactPhone2,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'Address1', '', '') as contactAddr1,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'Address2', '', '') as contactAddr2,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'Address3', '', '') as contactAddr3,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'City', '', '') as contactCity,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'State', '', '') as contactState,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'Zip', '', '') as contactZip,
dbo.fn_get_contact_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Applicant', '', '', 'FullAddr_Block', '', '') as contactAddrBlock,
dbo.fn_get_licprof_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'FullName', '', '', '') as licProfName,
dbo.fn_get_licprof_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'BusinessName', '', '', '') as licProfBusName,
dbo.fn_get_licprof_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'LicenseType', '', '', '') as licProfLicType,
dbo.fn_get_licprof_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'LicenseNumber', '', '', '') as licProfLicNbr,
dbo.fn_get_licprof_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'FullAddr_Block', '', '', '') as licProfAddr,
dbo.fn_get_licprof_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Trunaddr_block_2', '', '', '') as licProfTrunAddr,
dbo.fn_get_licprof_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Phone1', '', '', '') as licProfPhone1,
dbo.fn_get_licprof_info (a.SERV_PROV_CODE, a.B1_PER_ID1, a.B1_PER_ID2, a.B1_PER_ID3,'Phone2', '', '', '') as licProfPhone2
from B1PERMIT a, BPERMIT_DETAIL b
where a.serv_prov_code = 'KNOXVILLE'
and a.serv_prov_code = b.serv_prov_code
and a.B1_ALT_ID = @altID
and a.b1_per_id1 = b.b1_per_id1
and a.b1_per_id2 = b.b1_per_id2
and a.b1_per_id3 = b.b1_per_id3
and a.rec_status = 'A'
and b.rec_status = 'A'</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="b1_alt_id">
          <DataField>b1_alt_id</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
