  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Accela">
      <DataSourceReference>Accela</DataSourceReference>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>762e8bfe-da02-40cc-b2bb-ba10ec1bb2e0</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Accela</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
SELECT G.R3_SUBGROUP_DESC Organ,
CONVERT(DATETIME, bvd.ATTRIBUTE_VALUE) prod_date,
b.B1_CHECKLIST_COMMENT work_center,
bvt.ATTRIBUTE_VALUE Task,
SUM(CAST(bvq.ATTRIBUTE_VALUE AS FLOAT)) Loads,
SUM(case when bvu.attribute_value = 'Tons' then (CONVERT(float, bvw.attribute_value) * 2000) else (CONVERT(float, bvw.attribute_value) * 1) end ) Pounds,
P.b1_appl_status FROM B1PERMIT P
JOIN bpermit_detail D ON 
D.SERV_PROV_CODE = P.SERV_PROV_CODE
AND D.B1_PER_ID1 = p.B1_PER_ID1 
AND D.B1_PER_ID2 = P.B1_PER_ID2
AND D.B1_PER_ID3 = p.B1_PER_ID3
left outer join BCHCKBOX b on
b.SERV_PROV_CODE = d.SERV_PROV_CODE
AND b.B1_PER_ID1 = d.B1_PER_ID1 
AND b.B1_PER_ID2 = d.B1_PER_ID2
AND b.B1_PER_ID3 = d.B1_PER_ID3
AND b.B1_CHECKBOX_TYPE = 'PS WORK ORDER INFORMATION'
AND b.B1_CHECKBOX_DESC = 'Work Center'
left outer join G3DPTTYP g on
g.R3_DEPT_KEY = D.B1_ASGN_DEPT 
and g.SERV_PROV_CODE = D.SERV_PROV_CODE
join BAPPSPECTABLE_VALUE bvt on
bvt.SERV_PROV_CODE = p.SERV_PROV_CODE
AND bvt.B1_PER_ID1 = p.B1_PER_ID1 
AND bvt.B1_PER_ID2 = p.B1_PER_ID2
AND bvt.B1_PER_ID3 = p.B1_PER_ID3
AND bvt.GROUP_NAME = 'WO_APU'
AND bvt.TABLE_NAME = 'ACTUAL PRODUCTION UNITS'
AND bvt.COLUMN_NAME = 'Task' 
AND ISNULL(bvt.ATTRIBUTE_VALUE,' ') &lt;&gt; ' ' 
AND bvt.ATTRIBUTE_VALUE IN ('103 - EXTRA TRASH-SHUTTLE', '104 - EXTRA TRASH-REGULAR', '114 - Litter Pickup Hand')
join BAPPSPECTABLE_VALUE bvw on
bvw.SERV_PROV_CODE = bvt.SERV_PROV_CODE
AND bvw.B1_PER_ID1 = bvt.B1_PER_ID1 
AND bvw.B1_PER_ID2 = bvt.B1_PER_ID2
AND bvw.B1_PER_ID3 = bvt.B1_PER_ID3
AND bvw.GROUP_NAME = 'WO_APU'
AND bvw.TABLE_NAME = 'ACTUAL PRODUCTION UNITS'
AND bvw.COLUMN_NAME = 'Weight' 
AND bvw.ROW_INDEX = bvt.ROW_INDEX 
AND ISNULL(bvw.ATTRIBUTE_VALUE,' ') &lt;&gt; ' '
AND bvw.ATTRIBUTE_VALUE &lt;&gt; '0.0'
join BAPPSPECTABLE_VALUE bvd on
bvd.SERV_PROV_CODE = bvw.SERV_PROV_CODE
AND bvd.B1_PER_ID1 = bvw.B1_PER_ID1 
AND bvd.B1_PER_ID2 = bvw.B1_PER_ID2
AND bvd.B1_PER_ID3 = bvw.B1_PER_ID3
AND bvd.GROUP_NAME = 'WO_APU'
AND bvd.TABLE_NAME = 'ACTUAL PRODUCTION UNITS'
AND bvd.COLUMN_NAME = 'Date' 
AND bvd.ROW_INDEX = bvt.ROW_INDEX 
AND ISNULL(bvd.ATTRIBUTE_VALUE,' ') &lt;&gt; ' '
join BAPPSPECTABLE_VALUE bvq on
bvq.SERV_PROV_CODE = bvd.SERV_PROV_CODE
AND bvq.B1_PER_ID1 = bvd.B1_PER_ID1 
AND bvq.B1_PER_ID2 = bvd.B1_PER_ID2
AND bvq.B1_PER_ID3 = bvd.B1_PER_ID3
AND bvq.GROUP_NAME = 'WO_APU'
AND bvq.TABLE_NAME = 'ACTUAL PRODUCTION UNITS'
AND bvq.COLUMN_NAME = 'Quantity' 
AND bvq.ROW_INDEX = bvd.ROW_INDEX 
AND ISNULL(bvq.ATTRIBUTE_VALUE,' ') &lt;&gt; ' '
join BAPPSPECTABLE_VALUE bvu on
bvu.SERV_PROV_CODE = bvq.SERV_PROV_CODE
AND bvu.B1_PER_ID1 = bvq.B1_PER_ID1 
AND bvu.B1_PER_ID2 = bvq.B1_PER_ID2
AND bvu.B1_PER_ID3 = bvq.B1_PER_ID3
AND bvu.GROUP_NAME = 'WO_APU'
AND bvu.TABLE_NAME = 'ACTUAL PRODUCTION UNITS'
AND bvu.COLUMN_NAME = 'Weight Unit' 
AND bvu.ROW_INDEX = bvq.ROW_INDEX 
AND ISNULL(bvu.ATTRIBUTE_VALUE,' ') &lt;&gt; ' '
WHERE   P.b1_PER_TYPE = 'Work Order'
 AND P.B1_PER_SUB_TYPE = 'Public Service'
  AND P.SERV_PROV_CODE='KNOXVILLE'
  AND P.B1_APPL_STATUS = 'Completed'
  AND bvd.ATTRIBUTE_VALUE BETWEEN @StartDate and @EndDate
group by
	G.R3_SUBGROUP_DESC,CONVERT(DATETIME, bvd.ATTRIBUTE_VALUE), b.B1_CHECKLIST_COMMENT, bvt.ATTRIBUTE_VALUE, P.b1_appl_status
order by
	G.R3_SUBGROUP_DESC,CONVERT(DATETIME, bvd.ATTRIBUTE_VALUE), b.B1_CHECKLIST_COMMENT, bvt.ATTRIBUTE_VALUE, P.b1_appl_status</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ORGAN">
          <DataField>Organ</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROD_DATE">
          <DataField>prod_date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="TASK">
          <DataField>Task</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LOADS">
          <DataField>Loads</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="POUNDS">
          <DataField>Pounds</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="WORK_CENTER">
          <DataField>work_center</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="B1_APPL_STATUS">
          <DataField>b1_appl_status</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
