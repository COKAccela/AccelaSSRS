                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>       The Department of Engineering will collect on the Cashier’s Check ten (10) days prior to this Agreement’s expiration date, unless the Department has determined that it will release the Check and no extension is required.</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Normal</FontWeight>
